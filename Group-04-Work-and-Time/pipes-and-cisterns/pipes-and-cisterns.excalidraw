    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 829,
      "width": 288,
      "height": 231,
      "text": "LOGIC:\nStep 1: A=1/12 per hr, B=1/18 per hr\nStep 2: Combined = 1/12+1/18\n  = 3/36+2/36 = 5/36 per hr\nStep 3: Time = 1÷(5/36) = 36/5 = 7.2 hrs\n\nTRICK (formula):\nab/(a+b) = 12×18/(12+18) = 216/30 = 7.2\n\n  A ──→ 1/12/hr ──┐\n  B ──→ 1/18/hr ──┤──→ 5/36/hr\n                  └──→ 7.2 hrs\n\n7.2 hrs = 7 hrs 12 min\n\nAnswer: 7 hours 12 minutes ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A=1/12 per hr, B=1/18 per hr\nStep 2: Combined = 1/12+1/18\n  = 3/36+2/36 = 5/36 per hr\nStep 3: Time = 1÷(5/36) = 36/5 = 7.2 hrs\n\nTRICK (formula):\nab/(a+b) = 12×18/(12+18) = 216/30 = 7.2\n\n  A ──→ 1/12/hr ──┐\n  B ──→ 1/18/hr ──┤──→ 5/36/hr\n                  └──→ 7.2 hrs\n\n7.2 hrs = 7 hrs 12 min\n\nAnswer: 7 hours 12 minutes ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
