    },
    {
      "id": "el_50",
      "type": "text",
      "x": 65,
      "y": 1698,
      "width": 296,
      "height": 245,
      "text": "LOGIC:\nStep 1: A=1/10, B=1/15. A works all 8h\n  A's work = 8/10 = 4/5. Left for B = 1/5\nStep 2: B time = (1/5)÷(1/15) = 3 hrs\n  B closed after 3h (5h before end)\n\nTRICK (LCM units):\nLCM(10,15)=30 → A=3/hr, B=2/hr\nA does 8×3=24. B does 30-24=6 units\nB time = 6/2 = 3 hrs\n\n  0─────3hr────────────8hr\n  |═A+B═|═════A only═══|\n\nVerify: A(24)+B(6)=30 ✓\n\nAnswer: B was closed after 3 hours ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5000,
      "version": 1,
      "versionNonce": 50,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A=1/10, B=1/15. A works all 8h\n  A's work = 8/10 = 4/5. Left for B = 1/5\nStep 2: B time = (1/5)÷(1/15) = 3 hrs\n  B closed after 3h (5h before end)\n\nTRICK (LCM units):\nLCM(10,15)=30 → A=3/hr, B=2/hr\nA does 8×3=24. B does 30-24=6 units\nB time = 6/2 = 3 hrs\n\n  0─────3hr────────────8hr\n  |═A+B═|═════A only═══|\n\nVerify: A(24)+B(6)=30 ✓\n\nAnswer: B was closed after 3 hours ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
