    {
      "id": "el_10",
      "type": "text",
      "x": 1005,
      "y": 100,
      "width": 356,
      "height": 22,
      "text": "Leak Midway Formula",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 17,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
