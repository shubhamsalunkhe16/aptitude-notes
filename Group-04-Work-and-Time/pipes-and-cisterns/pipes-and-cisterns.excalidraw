    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 289,
      "height": 188,
      "text": "If pipe fills in n hours:\n  Rate = 1/n (per hour)\n\nTwo pipes A(a hrs) + B(b hrs):\n  Combined = 1/a + 1/b\n  Time = ab/(a+b)\n\nWHY: Each pipe fills a fraction per\n  hour. Combined rate = sum of rates.\n  Time = 1/(sum) = ab/(a+b).\n\nEx: A=6h, B=12h → Time=6×12/18=4h",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 500,
      "version": 1,
      "versionNonce": 5,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f0"
      ],
      "containerId": null,
      "originalText": "If pipe fills in n hours:\n  Rate = 1/n (per hour)\n\nTwo pipes A(a hrs) + B(b hrs):\n  Combined = 1/a + 1/b\n  Time = ab/(a+b)\n\nWHY: Each pipe fills a fraction per\n  hour. Combined rate = sum of rates.\n  Time = 1/(sum) = ab/(a+b).\n\nEx: A=6h, B=12h → Time=6×12/18=4h",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
