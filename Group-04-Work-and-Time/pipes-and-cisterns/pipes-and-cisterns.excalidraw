    {
      "id": "el_48",
      "type": "text",
      "x": 65,
      "y": 1617,
      "width": 830,
      "height": 49,
      "text": "Two pipes A and B fill a tank in 10 and 15 hours. Both are\nopened but B is closed some time before the tank is full.\nTank fills in 8 hours. When was B closed?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4800,
      "version": 1,
      "versionNonce": 48,
