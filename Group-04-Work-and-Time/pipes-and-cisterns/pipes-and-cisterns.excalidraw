    {
      "id": "el_43",
      "type": "text",
      "x": 1005,
      "y": 1161,
      "width": 787,
      "height": 49,
      "text": "Two pipes A and B can fill a tank in 20 and 30 minutes.\nThey are opened alternately for 1 minute each, starting\nwith A. When will the tank be full?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
