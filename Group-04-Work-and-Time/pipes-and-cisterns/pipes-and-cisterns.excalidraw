    {
      "id": "el_53",
      "type": "text",
      "x": 535,
      "y": 1617,
      "width": 830,
      "height": 49,
      "text": "An inlet pipe fills at 5 litres/min. An outlet drains at 7\nlitres/min. If the tank has 200 litres, when will it be\nempty?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
