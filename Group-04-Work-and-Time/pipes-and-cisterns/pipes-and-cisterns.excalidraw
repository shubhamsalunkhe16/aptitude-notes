    {
      "id": "el_23",
      "type": "text",
      "x": 535,
      "y": 748,
      "width": 830,
      "height": 49,
      "text": "A pipe can fill a tank in 10 hours. A leak can empty it in\n15 hours. If both work together, how long to fill the\ntank?",
      "fontSize": 13,
