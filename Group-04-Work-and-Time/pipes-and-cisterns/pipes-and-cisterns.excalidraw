    },
    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1698,
      "width": 274,
      "height": 245,
      "text": "LOGIC:\nStep 1: Inlet=+5, Outlet=-7 L/min\n  Net = 5-7 = -2 L/min (draining!)\nStep 2: 200 litres at -2 L/min\n  Time = 200/2 = 100 minutes\n\nTRICK (sign check):\nOutlet > Inlet → NEVER fills, drains!\n\n  Inlet ──→ +5 L/min ──┐\n  Outlet ──→ -7 L/min ──┤ Net = -2\n                        └──→ draining!\n\nDrain time = Volume/|Net rate|\n= 200/2 = 100 min\n\nAnswer: Empty in 100 minutes ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Inlet=+5, Outlet=-7 L/min\n  Net = 5-7 = -2 L/min (draining!)\nStep 2: 200 litres at -2 L/min\n  Time = 200/2 = 100 minutes\n\nTRICK (sign check):\nOutlet > Inlet → NEVER fills, drains!\n\n  Inlet ──→ +5 L/min ──┐\n  Outlet ──→ -7 L/min ──┤ Net = -2\n                        └──→ draining!\n\nDrain time = Volume/|Net rate|\n= 200/2 = 100 min\n\nAnswer: Empty in 100 minutes ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
