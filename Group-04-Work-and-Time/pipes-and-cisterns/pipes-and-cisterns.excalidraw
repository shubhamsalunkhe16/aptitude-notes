      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_60",
      "type": "text",
      "x": 1005,
      "y": 1682,
      "width": 274,
      "height": 231,
      "text": "LOGIC:\nStep 1: A+B=1/6, B+C=1/8, A+C=1/12\n  Add all: 2(A+B+C) = 1/6+1/8+1/12\n  = 4/24+3/24+2/24 = 9/24 = 3/8\nStep 2: A+B+C = 3/16 → Time = 16/3 hrs\n\nTRICK (LCM units):\nLCM(6,8,12)=24 → A+B=4, B+C=3, A+C=2\n2(A+B+C)=9 → A+B+C=4.5/hr\nTime = 24/4.5 = 16/3 = 5h 20m\n\n  A+B=4 ─┐\n  B+C=3 ─┤ sum=9, half=4.5\n  A+C=2 ─┘\n\nAnswer: 5 hours 20 minutes ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
