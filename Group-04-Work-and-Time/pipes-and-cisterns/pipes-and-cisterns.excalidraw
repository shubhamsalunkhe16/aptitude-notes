    {
      "id": "el_18",
      "type": "text",
      "x": 65,
      "y": 748,
      "width": 816,
      "height": 49,
      "text": "Pipe A fills a tank in 12 hours and Pipe B fills it in 18\nhours. If both are opened together, how long will it take\nto fill the tank?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1800,
      "version": 1,
