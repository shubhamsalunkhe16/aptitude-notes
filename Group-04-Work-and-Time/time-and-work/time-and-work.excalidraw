    {
      "id": "el_54",
      "type": "text",
      "x": 65,
      "y": 1751,
      "width": 830,
      "height": 49,
      "text": "10 men can finish a work in 8 days working 6 hours/day.\nHow many days will 15 men take working 8 hours/day for the\nsame work?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5400,
      "version": 1,
      "versionNonce": 54,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "10 men can finish a work in 8 days working 6 hours/day.\nHow many days will 15 men take working 8 hours/day for the\nsame work?",
