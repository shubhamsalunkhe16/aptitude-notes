    {
      "id": "el_26",
      "type": "text",
      "x": 65,
      "y": 892,
      "width": 411,
      "height": 274,
      "text": "LOGIC:\nStep 1: Anil = 1/10 per day, Pankaj = 1/15 per day\nStep 2: Together = 1/10 + 1/15 = 3/30 + 2/30 = 5/30 = 1/6\nStep 3: Time = 1 ÷ (1/6) = 6 days\n\nTRICK (LCM method):\nLCM(10,15) = 30 → Anil=3, Pankaj=2\n\n       (30) Total Work\n         |\n    -----+-----\n    |          |\n   (3)        (2)  ← Eff (3+2 = 5/day)\n  (10)       (15)\n  Anil      Pankaj\n\nTogether = 5/day → 30/5 = 6 days\n\nAnswer: 6 days ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2600,
      "version": 1,
      "versionNonce": 26,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Anil = 1/10 per day, Pankaj = 1/15 per day\nStep 2: Together = 1/10 + 1/15 = 3/30 + 2/30 = 5/30 = 1/6\nStep 3: Time = 1 ÷ (1/6) = 6 days\n\nTRICK (LCM method):\nLCM(10,15) = 30 → Anil=3, Pankaj=2\n\n       (30) Total Work\n         |\n    -----+-----\n    |          |\n   (3)        (2)  ← Eff (3+2 = 5/day)\n  (10)       (15)\n  Anil      Pankaj\n\nTogether = 5/day → 30/5 = 6 days\n\nAnswer: 6 days ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
