    {
      "id": "el_34",
      "type": "text",
      "x": 1005,
      "y": 811,
      "width": 830,
      "height": 49,
      "text": "Aman can do a work in 30 days and Raman in 20 days. They\nstart together but Raman leaves after 10 days. In how many\ntotal days will the work be finished?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
