    {
      "id": "el_29",
      "type": "text",
      "x": 535,
      "y": 811,
      "width": 787,
      "height": 49,
      "text": "A can do a work in 10 days, B in 12 days, and C in 15\ndays. If all three work together, in how many days will\nthe work be finished?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
