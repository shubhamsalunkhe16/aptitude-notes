    {
      "id": "el_24",
      "type": "text",
      "x": 65,
      "y": 811,
      "width": 744,
      "height": 49,
      "text": "Anil can complete a work in 10 days and Pankaj can\ncomplete it in 15 days. How many days will they take\nworking together?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
