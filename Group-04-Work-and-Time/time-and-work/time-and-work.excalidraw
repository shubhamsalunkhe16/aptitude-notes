    {
      "id": "el_17",
      "type": "text",
      "x": 535,
      "y": 497,
      "width": 258,
      "height": 172,
      "text": "n days → (100/n)% per day\nx%/day → (100/x) days\n\n1/2=50%  1/3=33.3%  1/4=25%\n1/5=20%  1/8=12.5%  1/10=10%\n\nWHY: 1/n of total work per day\n  = (1/n)×100 = (100/n)% per day.\n\nEx: 8 days → 100/8 = 12.5%/day\n  25%/day → 100/25 = 4 days",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1700,
      "version": 1,
      "versionNonce": 17,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f4"
      ],
      "containerId": null,
      "originalText": "n days → (100/n)% per day\nx%/day → (100/x) days\n\n1/2=50%  1/3=33.3%  1/4=25%\n1/5=20%  1/8=12.5%  1/10=10%\n\nWHY: 1/n of total work per day\n  = (1/n)×100 = (100/n)% per day.\n\nEx: 8 days → 100/8 = 12.5%/day\n  25%/day → 100/25 = 4 days",
      "autoResize": true,
