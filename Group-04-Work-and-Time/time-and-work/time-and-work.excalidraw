    {
      "id": "el_79",
      "type": "text",
      "x": 1005,
      "y": 2221,
      "width": 816,
      "height": 49,
      "text": "20 men can finish a work in 30 days. After working for 10\ndays, 10 more men join them. In how many more days will\nthe remaining work be finished?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
