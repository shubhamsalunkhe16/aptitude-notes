    },
    {
      "id": "el_90",
      "type": "text",
      "x": 535,
      "y": 2736,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1864ab",
      "backgroundColor": "transparent",
