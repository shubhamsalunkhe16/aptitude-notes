    {
      "id": "el_89",
      "type": "text",
      "x": 535,
      "y": 2677,
      "width": 830,
      "height": 49,
      "text": "A can do a piece of work in 12 days. A works for 8 days\nand then B finishes the remaining work in 6 days. How long\nwould A and B together take to do the whole work?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8900,
      "version": 1,
      "versionNonce": 89,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
