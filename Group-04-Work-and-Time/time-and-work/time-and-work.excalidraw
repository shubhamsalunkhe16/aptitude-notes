      "roundness": null
    },
    {
      "id": "el_46",
      "type": "text",
      "x": 535,
      "y": 1362,
      "width": 382,
      "height": 260,
      "text": "LOGIC:\nStep 1: A=1/12, B=1/15. In 2-day cycle:\n  Work = 1/12+1/15 = 5/60+4/60 = 9/60 = 3/20\nStep 2: 6 cycles (12d) = 6×3/20 = 18/20 = 9/10\n  Left=1/10. Day13(A): 1/12 done, left=1/10-1/12=1/60\n  Day14(B): (1/60)÷(1/15) = 15/60 = 1/4 day\n\nTRICK (LCM method):\nLCM(12,15)=60 → A=5/day, B=4/day\n\n|D1 |D2 |D3 |D4 | ... |D13|D14|\n| A | B | A | B | ... | A | B |\n  2-day cycle = 9 units\n\n6 cycles=12d→54 done. Left=6\nDay13(A):5→left=1. Day14(B):1/4 day\n\nAnswer: 13¼ days ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4600,
      "version": 1,
      "versionNonce": 46,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A=1/12, B=1/15. In 2-day cycle:\n  Work = 1/12+1/15 = 5/60+4/60 = 9/60 = 3/20\nStep 2: 6 cycles (12d) = 6×3/20 = 18/20 = 9/10\n  Left=1/10. Day13(A): 1/12 done, left=1/10-1/12=1/60\n  Day14(B): (1/60)÷(1/15) = 15/60 = 1/4 day\n\nTRICK (LCM method):\nLCM(12,15)=60 → A=5/day, B=4/day\n\n|D1 |D2 |D3 |D4 | ... |D13|D14|\n| A | B | A | B | ... | A | B |\n  2-day cycle = 9 units\n\n6 cycles=12d→54 done. Left=6\nDay13(A):5→left=1. Day14(B):1/4 day\n\nAnswer: 13¼ days ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
