      "groupIds": [
        "type_14"
      ],
      "containerId": null,
      "originalText": "A can do a piece of work in 12 days. A works for 8 days\nand then B finishes the remaining work in 6 days. How long\nwould A and B together take to do the whole work?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
