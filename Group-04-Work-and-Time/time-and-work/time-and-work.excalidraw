    {
      "id": "el_86",
      "type": "text",
      "x": 65,
      "y": 2758,
      "width": 296,
      "height": 274,
      "text": "LOGIC:\nStep 1: A=1/10, B=1/15 per day\n  Together = 1/10+1/15 = 3/30+2/30 = 1/6\nStep 2: 4 days work = 4×(1/6) = 4/6 = 2/3\n  Left = 1 - 2/3 = 1/3\n\nTRICK (LCM method):\nLCM(10,15)=30 → A=3, B=2, Together=5\n\n       (30) Total Work\n         |\n    -----+-----\n   (3)        (2)  ← 3+2=5/day\n  (10)       (15)\n\n4 days = 4×5=20 done, left=30-20=10\nFraction = 10/30 = 1/3\n\nAnswer: 1/3 of the work is left ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8600,
      "version": 1,
      "versionNonce": 86,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_13"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A=1/10, B=1/15 per day\n  Together = 1/10+1/15 = 3/30+2/30 = 1/6\nStep 2: 4 days work = 4×(1/6) = 4/6 = 2/3\n  Left = 1 - 2/3 = 1/3\n\nTRICK (LCM method):\nLCM(10,15)=30 → A=3, B=2, Together=5\n\n       (30) Total Work\n         |\n    -----+-----\n   (3)        (2)  ← 3+2=5/day\n  (10)       (15)\n\n4 days = 4×5=20 done, left=30-20=10\nFraction = 10/30 = 1/3\n\nAnswer: 1/3 of the work is left ✓",
      "autoResize": true,
