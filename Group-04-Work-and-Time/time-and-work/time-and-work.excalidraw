    {
      "id": "el_44",
      "type": "text",
      "x": 535,
      "y": 1281,
      "width": 816,
      "height": 49,
      "text": "A can do a work in 12 days and B in 15 days. They work on\nalternate days starting with A. In how many days will the\nwork be completed?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4400,
      "version": 1,
      "versionNonce": 44,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "A can do a work in 12 days and B in 15 days. They work on\nalternate days starting with A. In how many days will the\nwork be completed?",
      "autoResize": true,
