    {
      "id": "el_64",
      "type": "text",
      "x": 1005,
      "y": 1751,
      "width": 801,
      "height": 49,
      "text": "A and B together can do a work in 10 days, B and C in 12\ndays, A and C in 15 days. How long will A, B, and C\ntogether take? How long will A alone take?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6400,
      "version": 1,
      "versionNonce": 64,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "A and B together can do a work in 10 days, B and C in 12\ndays, A and C in 15 days. How long will A, B, and C\ntogether take? How long will A alone take?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
