    },
    {
      "id": "el_66",
      "type": "text",
      "x": 1005,
      "y": 1832,
      "width": 310,
      "height": 288,
      "text": "LOGIC:\nStep 1: A+B=1/10, B+C=1/12, A+C=1/15\n  Add all: 2(A+B+C) = 1/10+1/12+1/15\n  = 6/60+5/60+4/60 = 15/60 = 1/4\nStep 2: A+B+C = 1/8 → Together = 8 days\n  A = 1/8-1/12 = 1/24 → 24d\n  B = 1/8-1/15 = 7/120 → 17⅐d\n\nTRICK (LCM method):\nLCM(10,12,15)=60 → A+B=6, B+C=5, A+C=4\n2(A+B+C)=15 → A+B+C=7.5\n\n  A+B=6 ──┐\n  B+C=5 ──┤ sum=15 → half=7.5/day\n  A+C=4 ──┘\n  A=7.5-5=2.5  B=3.5  C=1.5\n\nTogether=60/7.5=8d\n\nAnswer: Together 8d, A=24d, B=17⅐d, C=40d ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6600,
      "version": 1,
      "versionNonce": 66,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A+B=1/10, B+C=1/12, A+C=1/15\n  Add all: 2(A+B+C) = 1/10+1/12+1/15\n  = 6/60+5/60+4/60 = 15/60 = 1/4\nStep 2: A+B+C = 1/8 → Together = 8 days\n  A = 1/8-1/12 = 1/24 → 24d\n  B = 1/8-1/15 = 7/120 → 17⅐d\n\nTRICK (LCM method):\nLCM(10,12,15)=60 → A+B=6, B+C=5, A+C=4\n2(A+B+C)=15 → A+B+C=7.5\n\n  A+B=6 ──┐\n  B+C=5 ──┤ sum=15 → half=7.5/day\n  A+C=4 ──┘\n  A=7.5-5=2.5  B=3.5  C=1.5\n\nTogether=60/7.5=8d\n\nAnswer: Together 8d, A=24d, B=17⅐d, C=40d ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
