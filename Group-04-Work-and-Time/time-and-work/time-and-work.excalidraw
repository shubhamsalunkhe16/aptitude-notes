      "type": "text",
      "x": 1005,
      "y": 1281,
      "width": 830,
      "height": 49,
      "text": "A is twice as efficient as B. B alone can finish a work in\n18 days. In how many days can they finish it working\ntogether?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
