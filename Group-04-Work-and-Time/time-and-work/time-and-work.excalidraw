      "versionNonce": 90,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_14"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_91",
      "type": "text",
      "x": 535,
      "y": 2758,
      "width": 296,
      "height": 216,
      "text": "LOGIC:\nStep 1: A=1/12. In 8d, A does 8/12=2/3\n  B does remaining 1/3 in 6d\nStep 2: B's rate = (1/3)/6 = 1/18\n  Together = 1/12+1/18 = 3/36+2/36 = 5/36\n  Time = 36/5 = 7⅕ days\n\nTRICK (LCM method):\nWork=12, A=1/day. A does 8, left=4\nB does 4 in 6d → B=2/3/day → B alone=18d\nLCM(12,18)=36 → A=3, B=2, Together=5\n\nTogether = 36/5 = 7⅕ days\n\nAnswer: Together 7⅕ days ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 9100,
      "version": 1,
      "versionNonce": 91,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_14"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A=1/12. In 8d, A does 8/12=2/3\n  B does remaining 1/3 in 6d\nStep 2: B's rate = (1/3)/6 = 1/18\n  Together = 1/12+1/18 = 3/36+2/36 = 5/36\n  Time = 36/5 = 7⅕ days\n\nTRICK (LCM method):\nWork=12, A=1/day. A does 8, left=4\nB does 4 in 6d → B=2/3/day → B alone=18d\nLCM(12,18)=36 → A=3, B=2, Together=5\n\nTogether = 36/5 = 7⅕ days\n\nAnswer: Together 7⅕ days ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
