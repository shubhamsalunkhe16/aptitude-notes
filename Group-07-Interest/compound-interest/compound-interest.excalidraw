    {
      "id": "el_36",
      "type": "text",
      "x": 65,
      "y": 1114,
      "width": 415,
      "height": 49,
      "text": "The difference between compound interest and simple\ninterest on a certain sum at 10% per annum for 3 years is\nRs.155. Find the sum.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3600,
      "version": 1,
      "versionNonce": 36,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "The difference between compound interest and simple\ninterest on a certain sum at 10% per annum for 3 years is\nRs.155. Find the sum.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
