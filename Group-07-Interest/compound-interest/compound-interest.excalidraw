    {
      "id": "el_66",
      "type": "text",
      "x": 65,
      "y": 1895,
      "width": 415,
      "height": 49,
      "text": "The population of a town is 200000. It grows at 10% in the\nfirst year, 15% in the second year, and 20% in the third\nyear. Find the population after 3 years.",
      "fontSize": 13,
