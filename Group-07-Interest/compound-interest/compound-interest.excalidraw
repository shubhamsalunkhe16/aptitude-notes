    },
    {
      "id": "el_38",
      "type": "text",
      "x": 65,
      "y": 1195,
      "width": 267,
      "height": 260,
      "text": "LOGIC:\nStep 1: CI-SI for 3yr at 10%\n  155 = P×(0.1)²×(3+0.1)\n  155 = P×0.031\nStep 2: P = 155/0.031 = 5000\n\n  SI: |██████████████████| 1500\n  CI: |██████████████████|░░░| 1655\n  Diff = 155 → solve for P\n\nTRICK:\nFormula: CI-SI = P×(R/100)²×(3+R/100)\nP = Diff / [(R/100)²×(3+R/100)]\n= 155/0.031 = 5000\n\n  Check: SI=1500, CI=1655, Diff=155 ✓\n\nAnswer: P = Rs.5000 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3800,
      "version": 1,
      "versionNonce": 38,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: CI-SI for 3yr at 10%\n  155 = P×(0.1)²×(3+0.1)\n  155 = P×0.031\nStep 2: P = 155/0.031 = 5000\n\n  SI: |██████████████████| 1500\n  CI: |██████████████████|░░░| 1655\n  Diff = 155 → solve for P\n\nTRICK:\nFormula: CI-SI = P×(R/100)²×(3+R/100)\nP = Diff / [(R/100)²×(3+R/100)]\n= 155/0.031 = 5000\n\n  Check: SI=1500, CI=1655, Diff=155 ✓\n\nAnswer: P = Rs.5000 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
