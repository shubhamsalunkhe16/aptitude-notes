    {
      "id": "el_31",
      "type": "text",
      "x": 1005,
      "y": 717,
      "width": 415,
      "height": 33,
      "text": "Find the difference between compound interest and simple\ninterest on Rs.5000 at 8% per annum for 2 years.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
