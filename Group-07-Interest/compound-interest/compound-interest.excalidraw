    },
    {
      "id": "el_37",
      "type": "text",
      "x": 65,
      "y": 1173,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
