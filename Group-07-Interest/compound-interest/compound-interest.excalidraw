    },
    {
      "id": "el_28",
      "type": "text",
      "x": 535,
      "y": 766,
      "width": 260,
      "height": 202,
      "text": "LOGIC:\nStep 1: P=8000, R=15%, T=2\nStep 2: A = 8000×(1.15)²\n  = 8000×1.3225 = 10580\n\nTRICK:\nYr1: 8000 + 1200 = 9200\nYr2: 9200 + 1380 = 10580\n(15% of 8000=1200, 15% of 9200=1380)\n\n  8000─[×1.15]→9200─[×1.15]→10580\n  CI = 10580 - 8000 = 2580\n\nAnswer: Amount = Rs.10580 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2800,
      "version": 1,
      "versionNonce": 28,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: P=8000, R=15%, T=2\nStep 2: A = 8000×(1.15)²\n  = 8000×1.3225 = 10580\n\nTRICK:\nYr1: 8000 + 1200 = 9200\nYr2: 9200 + 1380 = 10580\n(15% of 8000=1200, 15% of 9200=1380)\n\n  8000─[×1.15]→9200─[×1.15]→10580\n  CI = 10580 - 8000 = 2580\n\nAnswer: Amount = Rs.10580 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
