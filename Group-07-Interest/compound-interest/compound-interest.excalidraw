      "originalText": "CI on a sum for 2 yrs at 5% is Rs.1025. Find the sum.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_42",
