    },
    {
      "id": "el_33",
      "type": "text",
      "x": 1005,
      "y": 782,
      "width": 281,
      "height": 231,
      "text": "LOGIC:\nStep 1: SI = 5000×8×2/100 = 800\n  CI: A = 5000×(1.08)² = 5832\n  CI = 832\nStep 2: Diff = 832-800 = 32\n\n  SI: |████████████████████| 800 (flat)\n  CI: |████████████████████|░░| 832\n  Diff = 32 (interest on Yr1 interest)\n\nTRICK:\nFor 2 yrs: CI-SI = P×(R/100)²\n= 5000×(0.08)² = 5000×0.0064 = 32\n(interest on 1st year's interest)\n\nAnswer: Diff = Rs.32 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3300,
      "version": 1,
      "versionNonce": 33,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: SI = 5000×8×2/100 = 800\n  CI: A = 5000×(1.08)² = 5832\n  CI = 832\nStep 2: Diff = 832-800 = 32\n\n  SI: |████████████████████| 800 (flat)\n  CI: |████████████████████|░░| 832\n  Diff = 32 (interest on Yr1 interest)\n\nTRICK:\nFor 2 yrs: CI-SI = P×(R/100)²\n= 5000×(0.08)² = 5000×0.0064 = 32\n(interest on 1st year's interest)\n\nAnswer: Diff = Rs.32 ✓",
      "autoResize": true,
