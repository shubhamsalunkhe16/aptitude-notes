    {
      "id": "el_76",
      "type": "text",
      "x": 1005,
      "y": 1866,
      "width": 830,
      "height": 49,
      "text": "The simple interest on a certain sum is Rs.50 per year. If\nthe rate of interest is increased by 2%, the simple\ninterest increases by Rs.40 per year. Find the principal.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7600,
      "version": 1,
      "versionNonce": 76,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "The simple interest on a certain sum is Rs.50 per year. If\nthe rate of interest is increased by 2%, the simple\ninterest increases by Rs.40 per year. Find the principal.",
