    {
      "id": "el_66",
      "type": "text",
      "x": 65,
      "y": 1866,
      "width": 816,
      "height": 49,
      "text": "A loan of Rs.3000 is borrowed at 10% simple interest per\nannum and repaid in 3 equal annual installments. Find the\nvalue of each installment.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6600,
      "version": 1,
      "versionNonce": 66,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "A loan of Rs.3000 is borrowed at 10% simple interest per\nannum and repaid in 3 equal annual installments. Find the\nvalue of each installment.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_67",
      "type": "text",
      "x": 65,
      "y": 1925,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6700,
      "version": 1,
      "versionNonce": 67,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_68",
      "type": "text",
      "x": 65,
      "y": 1947,
      "width": 288,
      "height": 202,
      "text": "LOGIC:\nStep 1: P=3000, R=10%, n=3 installments\nStep 2: x = P×100/[n×100 + n(n-1)/2 × R]\n  = 300000/[300 + 3×10] = 300000/330\n  = 909.09\n\nTRICK:\nDenom = n×100 + n(n-1)×R/2\n= 300 + 30 = 330\nx = 300000/330 = 909.09\n\n  3000 ──→ Pay 909.09 × 3 installments\n\nAnswer: Installment = Rs.909.09 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6800,
      "version": 1,
      "versionNonce": 68,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: P=3000, R=10%, n=3 installments\nStep 2: x = P×100/[n×100 + n(n-1)/2 × R]\n  = 300000/[300 + 3×10] = 300000/330\n  = 909.09\n\nTRICK:\nDenom = n×100 + n(n-1)×R/2\n= 300 + 30 = 330\nx = 300000/330 = 909.09\n\n  3000 ──→ Pay 909.09 × 3 installments\n\nAnswer: Installment = Rs.909.09 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
