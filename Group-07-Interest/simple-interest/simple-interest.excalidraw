    {
      "id": "el_86",
      "type": "text",
      "x": 535,
      "y": 2250,
      "width": 816,
      "height": 49,
      "text": "A sum of money amounts to Rs.2200 in 2 years and Rs.2800\nin 5 years at simple interest. Find the principal and the\nrate of interest.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
