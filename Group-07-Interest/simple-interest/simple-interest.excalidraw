    {
      "id": "el_71",
      "type": "text",
      "x": 535,
      "y": 1866,
      "width": 816,
      "height": 49,
      "text": "A sum of money amounts to Rs.1380 in 3 years and Rs.1500\nin 5 years at simple interest. Find the principal and the\nrate of interest.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7100,
      "version": 1,
      "versionNonce": 71,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "A sum of money amounts to Rs.1380 in 3 years and Rs.1500\nin 5 years at simple interest. Find the principal and the\nrate of interest.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_72",
      "type": "text",
      "x": 535,
      "y": 1925,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7200,
      "version": 1,
      "versionNonce": 72,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_73",
      "type": "text",
      "x": 535,
      "y": 1947,
      "width": 267,
      "height": 202,
      "text": "LOGIC:\nStep 1: SI(2yr) = 1500-1380 = 120\n  SI/yr = 60, SI(3yr) = 180\nStep 2: P = 1380-180 = 1200\n  R = 100×180/(1200×3) = 5%\n\nTRICK:\nSI/yr = (A2-A1)/(T2-T1)\n= (1500-1380)/2 = 60\nP = A1 - SI/yr × T1 = 1380-180 = 1200\n\n  P=1200 ──→ 1380(3yr) ──→ 1500(5yr)\n\nAnswer: P = Rs.1200, R = 5% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7300,
      "version": 1,
      "versionNonce": 73,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: SI(2yr) = 1500-1380 = 120\n  SI/yr = 60, SI(3yr) = 180\nStep 2: P = 1380-180 = 1200\n  R = 100×180/(1200×3) = 5%\n\nTRICK:\nSI/yr = (A2-A1)/(T2-T1)\n= (1500-1380)/2 = 60\nP = A1 - SI/yr × T1 = 1380-180 = 1200\n\n  P=1200 ──→ 1380(3yr) ──→ 1500(5yr)\n\nAnswer: P = Rs.1200, R = 5% ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
