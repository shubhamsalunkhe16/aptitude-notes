    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 937,
      "width": 267,
      "height": 274,
      "text": "LOGIC:\nStep 1: 12=2²×3, 18=2×3², 24=2³×3\nStep 2: All primes with HIGHEST power\n  2³(max) and 3²(max)\nStep 3: LCM=2³×3²=8×9=72\n  Verify: 72/12=6✓ 72/18=4✓ 72/24=3✓\n\nTRICK (table method):\n  Primes:  2  |  3\n  ------+----+----\n  12    | 2² | 3¹\n  18    | 2¹ | 3²\n  24    | 2³ | 3¹\n  ------+----+----\n  MAX   | 2³ | 3²  → LCM\n\nLCM = 8×9 = 72\n\nAnswer: LCM = 72 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 12=2²×3, 18=2×3², 24=2³×3\nStep 2: All primes with HIGHEST power\n  2³(max) and 3²(max)\nStep 3: LCM=2³×3²=8×9=72\n  Verify: 72/12=6✓ 72/18=4✓ 72/24=3✓\n\nTRICK (table method):\n  Primes:  2  |  3\n  ------+----+----\n  12    | 2² | 3¹\n  18    | 2¹ | 3²\n  24    | 2³ | 3¹\n  ------+----+----\n  MAX   | 2³ | 3²  → LCM\n\nLCM = 8×9 = 72\n\nAnswer: LCM = 72 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
