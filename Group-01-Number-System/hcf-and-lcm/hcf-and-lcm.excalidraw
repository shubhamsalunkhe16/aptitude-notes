    },
    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1861,
      "width": 274,
      "height": 260,
      "text": "LOGIC:\nStep 1: \"Exactly divisible\" = find LCM\n  12=2²×3, 15=3×5, 20=2²×5\nStep 2: LCM = 2²×3×5 = 60\n  Verify: 60/12=5✓ 60/15=4✓ 60/20=3✓\n\nTRICK (table method):\n  Primes:  2  |  3  |  5\n  ------+----+----+----\n  12    | 2² | 3¹ |  -\n  15    |  -  | 3¹ | 5¹\n  20    | 2² |  -  | 5¹\n  ------+----+----+----\n  MAX   | 2² | 3¹ | 5¹\n\nLCM = 4×3×5 = 60\n\nAnswer: Smallest number = 60 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: \"Exactly divisible\" = find LCM\n  12=2²×3, 15=3×5, 20=2²×5\nStep 2: LCM = 2²×3×5 = 60\n  Verify: 60/12=5✓ 60/15=4✓ 60/20=3✓\n\nTRICK (table method):\n  Primes:  2  |  3  |  5\n  ------+----+----+----\n  12    | 2² | 3¹ |  -\n  15    |  -  | 3¹ | 5¹\n  20    | 2² |  -  | 5¹\n  ------+----+----+----\n  MAX   | 2² | 3¹ | 5¹\n\nLCM = 4×3×5 = 60\n\nAnswer: Smallest number = 60 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
