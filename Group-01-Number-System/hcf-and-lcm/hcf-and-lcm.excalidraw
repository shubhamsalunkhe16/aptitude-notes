    },
    {
      "id": "el_19",
      "type": "text",
      "x": 65,
      "y": 931,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1900,
      "version": 1,
      "versionNonce": 19,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 953,
      "width": 281,
      "height": 288,
      "text": "LOGIC:\nStep 1: 36=2²×3², 48=2⁴×3¹\nStep 2: Common primes with LOWEST power\n  2²(min of 2,4) and 3¹(min of 2,1)\nStep 3: HCF = 2²×3 = 4×3 = 12\n\nTRICK (factor tree):\n       36           48\n      / \\          / \\\n     2  18        2  24\n       / \\          / \\\n      2   9        2  12\n         / \\         / \\\n        3   3       2   6\n                       / \\\n                      2   3\n\nCommon: 2²×3 = 12\n\nAnswer: HCF = 12 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
