    {
      "id": "el_65",
      "type": "text",
      "x": 65,
      "y": 2285,
      "width": 296,
      "height": 260,
      "text": "LOGIC:\nStep 1: Nums: 2,4,8 → HCF=2, LCM=8\n  Dens: 3,9,27 → HCF=3, LCM=27\nStep 2: HCF(fracs)=HCF(num)/LCM(den)=2/27\n  LCM(fracs)=LCM(num)/HCF(den)=8/3\n\nTRICK (fraction HCF/LCM rules):\n  ┌───────────────────────────────┐\n  │ HCF = HCF(nums)/LCM(dens)    │\n  │     = 2/27                    │\n  │ LCM = LCM(nums)/HCF(dens)    │\n  │     = 8/3                     │\n  └───────────────────────────────┘\n\nVerify: (8/3)÷(2/3)=4✓\n(8/3)÷(4/9)=6✓ (8/3)÷(8/27)=9✓\n\nAnswer: HCF = 2/27, LCM = 8/3 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6500,
      "version": 1,
      "versionNonce": 65,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Nums: 2,4,8 → HCF=2, LCM=8\n  Dens: 3,9,27 → HCF=3, LCM=27\nStep 2: HCF(fracs)=HCF(num)/LCM(den)=2/27\n  LCM(fracs)=LCM(num)/HCF(den)=8/3\n\nTRICK (fraction HCF/LCM rules):\n  ┌───────────────────────────────┐\n  │ HCF = HCF(nums)/LCM(dens)    │\n  │     = 2/27                    │\n  │ LCM = LCM(nums)/HCF(dens)    │\n  │     = 8/3                     │\n  └───────────────────────────────┘\n\nVerify: (8/3)÷(2/3)=4✓\n(8/3)÷(4/9)=6✓ (8/3)÷(8/27)=9✓\n\nAnswer: HCF = 2/27, LCM = 8/3 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
