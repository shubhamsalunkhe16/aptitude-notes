      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "HCF of two numbers is 6 and LCM is 180. If one number is\n36, find the other.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_74",
      "type": "text",
      "x": 1005,
      "y": 2279,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7400,
      "version": 1,
      "versionNonce": 74,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_75",
      "type": "text",
      "x": 1005,
      "y": 2301,
      "width": 245,
      "height": 231,
      "text": "LOGIC:\nStep 1: LCM×HCF = a×b\n  180×6 = 36×b → 1080=36b → b=30\nStep 2: Verify: 36=2²×3², 30=2×3×5\n  HCF=2×3=6✓ LCM=2²×3²×5=180✓\n\nTRICK (formula):\nb = (LCM×HCF)/a = (180×6)/36 = 30\n\n  ┌───────────────────────────┐\n  │  a×b = LCM×HCF           │\n  │  36×b = 180×6 = 1080     │\n  │  b = 30                  │\n  └───────────────────────────┘\n\nAnswer: Other number = 30 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7500,
      "version": 1,
      "versionNonce": 75,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: LCM×HCF = a×b\n  180×6 = 36×b → 1080=36b → b=30\nStep 2: Verify: 36=2²×3², 30=2×3×5\n  HCF=2×3=6✓ LCM=2²×3²×5=180✓\n\nTRICK (formula):\nb = (LCM×HCF)/a = (180×6)/36 = 30\n\n  ┌───────────────────────────┐\n  │  a×b = LCM×HCF           │\n  │  36×b = 180×6 = 1080     │\n  │  b = 30                  │\n  └───────────────────────────┘\n\nAnswer: Other number = 30 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    }
