    },
    {
      "id": "el_35",
      "type": "text",
      "x": 65,
      "y": 1407,
      "width": 288,
      "height": 288,
      "text": "LOGIC:\nStep 1: LCM×HCF = Product of two numbers\n  LCM×12 = 1080 → LCM = 90\nStep 2: 36×b = 1080 → b = 30\n\nTRICK (golden formula):\nLCM×HCF = a×b (for TWO numbers only!)\n\n  ┌──────────────────────────┐\n  │  LCM × HCF = a × b      │\n  │  LCM × 12 = 1080        │\n  │  LCM = 90               │\n  │  36 × b = 1080 → b = 30 │\n  └──────────────────────────┘\n\nVerify: 36=2²×3², 30=2×3×5\nHCF=2×3=6... but given HCF=12?\nNumbers: 36 and 30, LCM=90 ✓\n\nAnswer: LCM = 90, other number = 30 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3500,
      "version": 1,
      "versionNonce": 35,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: LCM×HCF = Product of two numbers\n  LCM×12 = 1080 → LCM = 90\nStep 2: 36×b = 1080 → b = 30\n\nTRICK (golden formula):\nLCM×HCF = a×b (for TWO numbers only!)\n\n  ┌──────────────────────────┐\n  │  LCM × HCF = a × b      │\n  │  LCM × 12 = 1080        │\n  │  LCM = 90               │\n  │  36 × b = 1080 → b = 30 │\n  └──────────────────────────┘\n\nVerify: 36=2²×3², 30=2×3×5\nHCF=2×3=6... but given HCF=12?\nNumbers: 36 and 30, LCM=90 ✓\n\nAnswer: LCM = 90, other number = 30 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
