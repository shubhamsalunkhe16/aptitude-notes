    {
      "id": "el_68",
      "type": "text",
      "x": 535,
      "y": 2236,
      "width": 415,
      "height": 33,
      "text": "Two bells ring at intervals of 8 and 12 minutes. They ring\ntogether at 12:00 PM. When will they next ring together?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
