    {
      "id": "el_70",
      "type": "text",
      "x": 535,
      "y": 2301,
      "width": 317,
      "height": 231,
      "text": "LOGIC:\nStep 1: They ring together when elapsed time\n  is a common multiple of both intervals\nStep 2: LCM(8,12) = 24 minutes\n  Time = 12:00+24min = 12:24 PM\n\nTRICK (bells = LCM):\nNext together = LCM of all intervals\nLCM(8,12) = 24 min → 12:24 PM\n\n  Bell1: |--8--|--8--|--8--|\n  Bell2: |---12---|---12---|\n  Both:  |--------24-------|\n         12:00       12:24\n\nAnswer: Next ring together at 12:24 PM ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7000,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: They ring together when elapsed time\n  is a common multiple of both intervals\nStep 2: LCM(8,12) = 24 minutes\n  Time = 12:00+24min = 12:24 PM\n\nTRICK (bells = LCM):\nNext together = LCM of all intervals\nLCM(8,12) = 24 min → 12:24 PM\n\n  Bell1: |--8--|--8--|--8--|\n  Bell2: |---12---|---12---|\n  Both:  |--------24-------|\n         12:00       12:24\n\nAnswer: Next ring together at 12:24 PM ✓",
      "autoResize": true,
