    {
      "id": "el_33",
      "type": "text",
      "x": 65,
      "y": 1342,
      "width": 415,
      "height": 33,
      "text": "HCF of two numbers is 12. One number is 36, product of\nnumbers is 1080. Find LCM and the other number.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
