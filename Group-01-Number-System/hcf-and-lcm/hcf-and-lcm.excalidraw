    {
      "id": "el_45",
      "type": "text",
      "x": 1005,
      "y": 1407,
      "width": 288,
      "height": 216,
      "text": "LOGIC:\nStep 1: N divides (49-1), (65-1), (97-1)\n  = N divides 48, 64, 96\nStep 2: HCF(48,64,96)\n  48=2⁴×3, 64=2⁶, 96=2⁵×3\n  HCF = 2⁴ = 16\n\nTRICK (same remainder):\nLargest N dividing X,Y,Z leaving rem R:\n= HCF(X-R, Y-R, Z-R)\n= HCF(48, 64, 96) = 16\n\nVerify: 49/16=3r1✓ 65/16=4r1✓ 97/16=6r1✓\n\nAnswer: Largest number = 16 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4500,
      "version": 1,
      "versionNonce": 45,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: N divides (49-1), (65-1), (97-1)\n  = N divides 48, 64, 96\nStep 2: HCF(48,64,96)\n  48=2⁴×3, 64=2⁶, 96=2⁵×3\n  HCF = 2⁴ = 16\n\nTRICK (same remainder):\nLargest N dividing X,Y,Z leaving rem R:\n= HCF(X-R, Y-R, Z-R)\n= HCF(48, 64, 96) = 16\n\nVerify: 49/16=3r1✓ 65/16=4r1✓ 97/16=6r1✓\n\nAnswer: Largest number = 16 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
