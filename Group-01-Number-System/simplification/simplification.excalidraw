    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 844,
      "width": 252,
      "height": 245,
      "text": "LOGIC:\nStep 1: Division first: 12/4=3\n  = 18+3×3-2\nStep 2: Multiply: 3×3=9\n  = 18+9-2 = 25\n\nTRICK:\nBODMAS: D and M left to right first\nThen A and S left to right\n\n  18 + 12/4 × 3 - 2\n       ───\n  18 +  3  × 3 - 2\n        ─────\n  18 +    9    - 2  = 25\n\nAnswer: 25 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Division first: 12/4=3\n  = 18+3×3-2\nStep 2: Multiply: 3×3=9\n  = 18+9-2 = 25\n\nTRICK:\nBODMAS: D and M left to right first\nThen A and S left to right\n\n  18 + 12/4 × 3 - 2\n       ───\n  18 +  3  × 3 - 2\n        ─────\n  18 +    9    - 2  = 25\n\nAnswer: 25 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
