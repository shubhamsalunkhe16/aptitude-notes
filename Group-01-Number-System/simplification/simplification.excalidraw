    {
      "id": "el_50",
      "type": "text",
      "x": 65,
      "y": 1649,
      "width": 238,
      "height": 216,
      "text": "LOGIC:\nStep 1: 37.5% = 3/8\nStep 2: 3/8 × 480 = 3×60 = 180\n\nTRICK:\nMemorize % to fraction:\n12.5%=1/8, 25%=1/4, 33.3%=1/3\n37.5%=3/8, 62.5%=5/8, 75%=3/4\nTIP: x% of y = y% of x\n\n  |████ 37.5% ████|░░░ 62.5% ░░░|\n  37.5% = 3/8\n  3/8 × 480 = 180\n\nAnswer: 180 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5000,
      "version": 1,
      "versionNonce": 50,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
