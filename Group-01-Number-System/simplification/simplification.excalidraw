    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 383,
      "height": 250,
      "text": "a/b + c/d = (ad + bc) / bd\na/b - c/d = (ad - bc) / bd\na/b x c/d = ac / bd\na/b / c/d = a/b x d/c = ad/bc\n\nDecimal to Fraction: 0.375 = 375/1000 = 3/8\nFraction to Decimal: 3/8 = 0.375\n\nCommon: 1/8=0.125, 1/6=0.1667, 1/3=0.333\n\nWHY: a/b+c/d → common den bd, so\nad/bd+bc/bd=(ad+bc)/bd\n  Division by fraction=multiply by its reciprocal\n\nEx: 2/3+1/4 = (8+3)/12 = 11/12 ✓\n  2/3÷1/4 = 2/3×4/1 = 8/3 ✓",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "a/b + c/d = (ad + bc) / bd\na/b - c/d = (ad - bc) / bd\na/b x c/d = ac / bd\na/b / c/d = a/b x d/c = ad/bc\n\nDecimal to Fraction: 0.375 = 375/1000 = 3/8\nFraction to Decimal: 3/8 = 0.375\n\nCommon: 1/8=0.125, 1/6=0.1667, 1/3=0.333\n\nWHY: a/b+c/d → common den bd, so\nad/bd+bc/bd=(ad+bc)/bd\n  Division by fraction=multiply by its reciprocal\n\nEx: 2/3+1/4 = (8+3)/12 = 11/12 ✓\n  2/3÷1/4 = 2/3×4/1 = 8/3 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
