    {
      "id": "el_50",
      "type": "text",
      "x": 65,
      "y": 1713,
      "width": 332,
      "height": 274,
      "text": "LOGIC:\nStep 1: Divide: 1/3=0.333..., 5/6=0.8333...\n  7/11=0.636363...\nStep 2: Check den for terminating vs recurring\n  Only 2s and 5s→terminates, else→recurs\n\nTRICK (quick check):\nDen has only 2,5 factors→terminates\nDen has 3,7,11 etc→recurring\n\n  Den factors → Type:\n  2,5 only   → Terminating (1/4, 3/8)\n  3,7,11...  → Recurring   (1/3, 7/11)\n\n  1/3  = 0.333...  (3 in den)\n  5/6  = 0.8333... (3 in den)\n  7/11 = 0.6363... (11 in den)\n\nAnswer: 0.3, 0.83, 0.63 (all recurring) ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5000,
      "version": 1,
      "versionNonce": 50,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Divide: 1/3=0.333..., 5/6=0.8333...\n  7/11=0.636363...\nStep 2: Check den for terminating vs recurring\n  Only 2s and 5s→terminates, else→recurs\n\nTRICK (quick check):\nDen has only 2,5 factors→terminates\nDen has 3,7,11 etc→recurring\n\n  Den factors → Type:\n  2,5 only   → Terminating (1/4, 3/8)\n  3,7,11...  → Recurring   (1/3, 7/11)\n\n  1/3  = 0.333...  (3 in den)\n  5/6  = 0.8333... (3 in den)\n  7/11 = 0.6363... (11 in den)\n\nAnswer: 0.3, 0.83, 0.63 (all recurring) ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
