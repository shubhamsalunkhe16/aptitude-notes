    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1713,
      "width": 267,
      "height": 245,
      "text": "LOGIC:\nStep 1: Let x=0.666... 10x=6.666...\n  10x-x=6→x=6/9=2/3\nStep 2: 0.4545...=45/99=5/11\n  0.1666...: x=0.1666, 10x=1.666\n  10x-x=1.5→x=1.5/9=15/90=1/6\n\nTRICK (9s rule):\nPure: repeating/9s → 6/9, 45/99\nMixed: (all-nonrep)/(9s+0s)\n\n  Pure:  0.6...  → 6/9  = 2/3\n  Pure:  0.45... → 45/99 = 5/11\n  Mixed: 0.16... → (16-1)/90 = 1/6\n         1 rep→9, 1 nonrep→0 → den=90\n\nAnswer: 2/3, 5/11, 1/6 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Let x=0.666... 10x=6.666...\n  10x-x=6→x=6/9=2/3\nStep 2: 0.4545...=45/99=5/11\n  0.1666...: x=0.1666, 10x=1.666\n  10x-x=1.5→x=1.5/9=15/90=1/6\n\nTRICK (9s rule):\nPure: repeating/9s → 6/9, 45/99\nMixed: (all-nonrep)/(9s+0s)\n\n  Pure:  0.6...  → 6/9  = 2/3\n  Pure:  0.45... → 45/99 = 5/11\n  Mixed: 0.16... → (16-1)/90 = 1/6\n         1 rep→9, 1 nonrep→0 → den=90\n\nAnswer: 2/3, 5/11, 1/6 ✓",
      "autoResize": true,
