    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 906,
      "width": 303,
      "height": 231,
      "text": "LOGIC:\nStep 1: LCM(3,5,7,8)=840\nStep 2: 2/3=560, 3/5=504, 4/7=480, 5/8=525\n  Sort: 480<504<525<560\n  = 4/7 < 3/5 < 5/8 < 2/3\n\nTRICK (decimal conversion):\nConvert to decimals for quick compare:\n  4/7=0.571, 3/5=0.600\n  5/8=0.625, 2/3=0.667\nSort decimals → done!\n\n  4/7 < 3/5 < 5/8 < 2/3\n  .571  .600  .625  .667\n\nAnswer: 4/7 < 3/5 < 5/8 < 2/3 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: LCM(3,5,7,8)=840\nStep 2: 2/3=560, 3/5=504, 4/7=480, 5/8=525\n  Sort: 480<504<525<560\n  = 4/7 < 3/5 < 5/8 < 2/3\n\nTRICK (decimal conversion):\nConvert to decimals for quick compare:\n  4/7=0.571, 3/5=0.600\n  5/8=0.625, 2/3=0.667\nSort decimals → done!\n\n  4/7 < 3/5 < 5/8 < 2/3\n  .571  .600  .625  .667\n\nAnswer: 4/7 < 3/5 < 5/8 < 2/3 ✓",
      "autoResize": true,
