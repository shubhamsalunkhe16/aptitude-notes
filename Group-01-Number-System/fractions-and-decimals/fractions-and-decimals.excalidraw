    {
      "id": "el_63",
      "type": "text",
      "x": 65,
      "y": 2088,
      "width": 787,
      "height": 33,
      "text": "A has 1/3 of total money. B has 1/4 of total. C has the\nremaining Rs.500. Find the total.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
