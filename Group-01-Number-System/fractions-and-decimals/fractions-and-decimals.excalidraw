    {
      "id": "el_35",
      "type": "text",
      "x": 65,
      "y": 1332,
      "width": 288,
      "height": 202,
      "text": "LOGIC:\nStep 1: LCM(3,4,6)=12\n  2/3=8/12, 3/4=9/12, 1/6=2/12\nStep 2: 8/12+9/12-2/12 = 15/12 = 5/4\n\nTRICK (cross multiply for 2):\nDo 2/3+3/4 first = (8+9)/12 = 17/12\nThen 17/12-1/6 = (17-2)/12 = 15/12 = 5/4\n\n  2/3 + 3/4 - 1/6\n  = 8/12+9/12-2/12\n  = 15/12 = 5/4 = 1 1/4\n\nAnswer: 5/4 or 1 1/4 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3500,
      "version": 1,
      "versionNonce": 35,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: LCM(3,4,6)=12\n  2/3=8/12, 3/4=9/12, 1/6=2/12\nStep 2: 8/12+9/12-2/12 = 15/12 = 5/4\n\nTRICK (cross multiply for 2):\nDo 2/3+3/4 first = (8+9)/12 = 17/12\nThen 17/12-1/6 = (17-2)/12 = 15/12 = 5/4\n\n  2/3 + 3/4 - 1/6\n  = 8/12+9/12-2/12\n  = 15/12 = 5/4 = 1 1/4\n\nAnswer: 5/4 or 1 1/4 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
