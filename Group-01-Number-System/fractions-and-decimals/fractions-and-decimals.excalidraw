    {
      "id": "el_65",
      "type": "text",
      "x": 65,
      "y": 2153,
      "width": 260,
      "height": 260,
      "text": "LOGIC:\nStep 1: A+B = 1/3+1/4 = 7/12\n  C = 1-7/12 = 5/12\nStep 2: 5/12 of Total=500\n  Total = 500×12/5 = Rs.1200\n  Verify: A=400, B=300, C=500✓\n\nTRICK (LCM parts):\nLCM(3,4)=12. A=4 parts, B=3 parts\nC=12-4-3=5 parts = Rs.500\n1 part=100 → Total=12×100=Rs.1200\n\n  Total |████████████| = 12 parts\n  A     |████|         = 4 parts\n  B     |███|          = 3 parts\n  C     |█████|        = 5 parts=500\n\nAnswer: Total = Rs.1200 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6500,
      "version": 1,
      "versionNonce": 65,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A+B = 1/3+1/4 = 7/12\n  C = 1-7/12 = 5/12\nStep 2: 5/12 of Total=500\n  Total = 500×12/5 = Rs.1200\n  Verify: A=400, B=300, C=500✓\n\nTRICK (LCM parts):\nLCM(3,4)=12. A=4 parts, B=3 parts\nC=12-4-3=5 parts = Rs.500\n1 part=100 → Total=12×100=Rs.1200\n\n  Total |████████████| = 12 parts\n  A     |████|         = 4 parts\n  B     |███|          = 3 parts\n  C     |█████|        = 5 parts=500\n\nAnswer: Total = Rs.1200 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    }
