    {
      "id": "el_45",
      "type": "text",
      "x": 1005,
      "y": 1332,
      "width": 317,
      "height": 231,
      "text": "LOGIC:\nStep 1: Count decimal places→zeros in den\n  0.125=125/1000, 0.375=375/1000, 0.04=4/100\nStep 2: Simplify by GCD\n  125/1000÷125=1/8, 375/1000÷125=3/8\n  4/100÷4=1/25\n\nTRICK (memorize common ones):\n0.5=1/2  0.25=1/4  0.125=1/8\n0.2=1/5  0.04=1/25 0.008=1/125\n\n  0.125 → 125/1000 → ÷125 → 1/8\n  0.375 → 375/1000 → ÷125 → 3/8\n  0.04  →   4/100  → ÷4   → 1/25\n\nAnswer: 1/8, 3/8, 1/25 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4500,
      "version": 1,
      "versionNonce": 45,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Count decimal places→zeros in den\n  0.125=125/1000, 0.375=375/1000, 0.04=4/100\nStep 2: Simplify by GCD\n  125/1000÷125=1/8, 375/1000÷125=3/8\n  4/100÷4=1/25\n\nTRICK (memorize common ones):\n0.5=1/2  0.25=1/4  0.125=1/8\n0.2=1/5  0.04=1/25 0.008=1/125\n\n  0.125 → 125/1000 → ÷125 → 1/8\n  0.375 → 375/1000 → ÷125 → 3/8\n  0.04  →   4/100  → ÷4   → 1/25\n\nAnswer: 1/8, 3/8, 1/25 ✓",
      "autoResize": true,
