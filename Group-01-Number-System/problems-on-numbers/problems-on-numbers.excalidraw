    },
    {
      "id": "el_26",
      "type": "text",
      "x": 65,
      "y": 829,
      "width": 281,
      "height": 188,
      "text": "LOGIC:\nStep 1: Let L and S. L+S=40, L-S=12\n  Add: 2L=52→L=26. Sub: 2S=28→S=14\nStep 2: Check: 26+14=40✓ 26-14=12✓\n\nTRICK (formula):\nLarger = (Sum+Diff)/2 = (40+12)/2 = 26\nSmaller = (Sum-Diff)/2 = (40-12)/2 = 14\n\n  |◄──── 40 (sum) ────►|\n  |◄─ 14 ─►|◄── 26 ──►|\n\nAnswer: 26 and 14 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2600,
      "version": 1,
      "versionNonce": 26,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Let L and S. L+S=40, L-S=12\n  Add: 2L=52→L=26. Sub: 2S=28→S=14\nStep 2: Check: 26+14=40✓ 26-14=12✓\n\nTRICK (formula):\nLarger = (Sum+Diff)/2 = (40+12)/2 = 26\nSmaller = (Sum-Diff)/2 = (40-12)/2 = 14\n\n  |◄──── 40 (sum) ────►|\n  |◄─ 14 ─►|◄── 26 ──►|\n\nAnswer: 26 and 14 ✓",
      "autoResize": true,
