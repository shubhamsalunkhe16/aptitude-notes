    {
      "id": "el_31",
      "type": "text",
      "x": 535,
      "y": 829,
      "width": 310,
      "height": 173,
      "text": "LOGIC:\nStep 1: a+b=12, a×b=35\n  b=12-a → a(12-a)=35 → a²-12a+35=0\nStep 2: (a-5)(a-7)=0 → a=5,b=7 or a=7,b=5\n  Numbers: 57 or 75. Check: 5+7=12✓ 5×7=35✓\n\nTRICK (quadratic shortcut):\nDigits are roots of: t²-(sum)t+(product)=0\nt²-12t+35=0 → t=5,7\nNumber = 57 or 75\n\nAnswer: 57 or 75 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3100,
      "version": 1,
      "versionNonce": 31,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: a+b=12, a×b=35\n  b=12-a → a(12-a)=35 → a²-12a+35=0\nStep 2: (a-5)(a-7)=0 → a=5,b=7 or a=7,b=5\n  Numbers: 57 or 75. Check: 5+7=12✓ 5×7=35✓\n\nTRICK (quadratic shortcut):\nDigits are roots of: t²-(sum)t+(product)=0\nt²-12t+35=0 → t=5,7\nNumber = 57 or 75\n\nAnswer: 57 or 75 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
