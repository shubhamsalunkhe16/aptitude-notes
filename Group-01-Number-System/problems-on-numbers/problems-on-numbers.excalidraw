    {
      "id": "el_56",
      "type": "text",
      "x": 65,
      "y": 1564,
      "width": 281,
      "height": 216,
      "text": "LOGIC:\nStep 1: Largest 4-digit=9999\n  9999÷13=769 rem 2\nStep 2: Subtract remainder: 9999-2=9997\n  Check: 9997/13=769 exactly ✓\n\nTRICK (formula):\nLargest N-digit ÷ X = N - (N mod X)\n= 9999 - 2 = 9997\nSmallest: N + (X - N mod X)\n\n  9997  9998  9999\n   ✓           (rem 2→subtract)\n\nAnswer: 9997 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5600,
      "version": 1,
      "versionNonce": 56,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Largest 4-digit=9999\n  9999÷13=769 rem 2\nStep 2: Subtract remainder: 9999-2=9997\n  Check: 9997/13=769 exactly ✓\n\nTRICK (formula):\nLargest N-digit ÷ X = N - (N mod X)\n= 9999 - 2 = 9997\nSmallest: N + (X - N mod X)\n\n  9997  9998  9999\n   ✓           (rem 2→subtract)\n\nAnswer: 9997 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
