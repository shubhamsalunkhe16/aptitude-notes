    },
    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 414,
      "height": 219,
      "text": "If Sum = S,  Difference = D:\n  Larger  = (S + D) / 2\n  Smaller = (S - D) / 2\n  Product = (S² - D²) / 4\n\n(a+b)² = a² + b² + 2ab\n(a-b)² = a² + b² - 2ab\na² - b² = (a+b)(a-b)\n\nWHY: L+S=S, L-S=D → add: 2L=S+D → L=(S+D)/2\n  Product=L×S = (S+D)/2 × (S-D)/2 = (S²-D²)/4\n\nEx: S=20, D=6 → L=13, S=7, Product=(400-36)/4=91=13×7\n✓",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "If Sum = S,  Difference = D:\n  Larger  = (S + D) / 2\n  Smaller = (S - D) / 2\n  Product = (S² - D²) / 4\n\n(a+b)² = a² + b² + 2ab\n(a-b)² = a² + b² - 2ab\na² - b² = (a+b)(a-b)\n\nWHY: L+S=S, L-S=D → add: 2L=S+D → L=(S+D)/2\n  Product=L×S = (S+D)/2 × (S-D)/2 = (S²-D²)/4\n\nEx: S=20, D=6 → L=13, S=7, Product=(400-36)/4=91=13×7\n✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
