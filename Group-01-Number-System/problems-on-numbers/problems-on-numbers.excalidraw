    {
      "id": "el_24",
      "type": "text",
      "x": 65,
      "y": 764,
      "width": 801,
      "height": 33,
      "text": "The sum of two numbers is 40 and their difference is 12.\nFind both numbers.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2400,
