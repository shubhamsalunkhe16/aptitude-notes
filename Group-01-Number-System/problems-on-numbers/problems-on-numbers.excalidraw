    {
      "id": "el_51",
      "type": "text",
      "x": 1005,
      "y": 1183,
      "width": 281,
      "height": 216,
      "text": "LOGIC:\nStep 1: Find cycle: 7¹→3, 7²→1, 7³→3...\n  Cycle period=2. 23 mod 2=1 → rem=3\n\nTRICK (-1 shortcut):\n7 mod 4 = 3 = -1 (mod 4)\n(-1)^odd = -1 = 4-1 = 3\n(-1)^even = 1\n\n7^23 = (-1)^23 = -1 ≡ 3 (mod 4)\n\nRule: If N≡-1(mod D):\n  odd power → D-1 | even power → 1\n\nAnswer: Remainder = 3 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5100,
      "version": 1,
      "versionNonce": 51,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Find cycle: 7¹→3, 7²→1, 7³→3...\n  Cycle period=2. 23 mod 2=1 → rem=3\n\nTRICK (-1 shortcut):\n7 mod 4 = 3 = -1 (mod 4)\n(-1)^odd = -1 = 4-1 = 3\n(-1)^even = 1\n\n7^23 = (-1)^23 = -1 ≡ 3 (mod 4)\n\nRule: If N≡-1(mod D):\n  odd power → D-1 | even power → 1\n\nAnswer: Remainder = 3 ✓",
      "autoResize": true,
