    {
      "id": "el_36",
      "type": "text",
      "x": 1005,
      "y": 845,
      "width": 274,
      "height": 188,
      "text": "LOGIC:\nStep 1: Num-Rev=27 → 9(a-b)=27 → a-b=3\n  a+b=11. Add: 2a=14→a=7, b=4\nStep 2: Number=74, Rev=47. 74-47=27✓\n\nTRICK:\nDiff of 2-digit & reverse = 9|a-b|\n27/9=3 → digit diff=3\na-b=3, a+b=11 → a=7, b=4\n\n  [7|4]=74  [4|7]=47  74-47=27✓\n\nAnswer: 74 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3600,
      "version": 1,
      "versionNonce": 36,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Num-Rev=27 → 9(a-b)=27 → a-b=3\n  a+b=11. Add: 2a=14→a=7, b=4\nStep 2: Number=74, Rev=47. 74-47=27✓\n\nTRICK:\nDiff of 2-digit & reverse = 9|a-b|\n27/9=3 → digit diff=3\na-b=3, a+b=11 → a=7, b=4\n\n  [7|4]=74  [4|7]=47  74-47=27✓\n\nAnswer: 74 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
