    {
      "id": "el_46",
      "type": "text",
      "x": 535,
      "y": 1183,
      "width": 296,
      "height": 216,
      "text": "LOGIC:\nStep 1: 352836 → Digits: 3 5 2 8 3 6\n  By 4: last 2=36, 36/4=9 → YES\n  By 9: 3+5+2+8+3+6=27, 27/9=3 → YES\n  By 11: odd(6+8+5)=19, even(3+2+3)=8\n  |19-8|=11 → YES\n\nTRICK (divisibility rules):\nBy 4 → check last 2 digits only\nBy 9 → digit sum ÷ 9\nBy 11 → |odd pos sum - even pos sum| ÷ 11\nBy 6 = check 2 AND 3\nBy 12 = check 3 AND 4\n\nAnswer: Divisible by 4, 9, and 11 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4600,
      "version": 1,
      "versionNonce": 46,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 352836 → Digits: 3 5 2 8 3 6\n  By 4: last 2=36, 36/4=9 → YES\n  By 9: 3+5+2+8+3+6=27, 27/9=3 → YES\n  By 11: odd(6+8+5)=19, even(3+2+3)=8\n  |19-8|=11 → YES\n\nTRICK (divisibility rules):\nBy 4 → check last 2 digits only\nBy 9 → digit sum ÷ 9\nBy 11 → |odd pos sum - even pos sum| ÷ 11\nBy 6 = check 2 AND 3\nBy 12 = check 3 AND 4\n\nAnswer: Divisible by 4, 9, and 11 ✓",
      "autoResize": true,
