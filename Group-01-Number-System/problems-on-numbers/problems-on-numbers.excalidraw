    {
      "id": "el_29",
      "type": "text",
      "x": 535,
      "y": 764,
      "width": 787,
      "height": 33,
      "text": "A two-digit number has digits whose sum is 12 and whose\nproduct is 35. Find the number.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
