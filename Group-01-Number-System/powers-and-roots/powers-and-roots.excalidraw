    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 359,
      "height": 188,
      "text": "1=1   2=4   3=9   4=16   5=25   6=36\n7=49  8=64  9=81  10=100 11=121 12=144\n13=169 14=196 15=225 16=256 17=289 18=324\n19=361 20=400 21=441 22=484 23=529 24=576\n25=625 26=676 27=729 28=784 29=841 30=900\nTRICK: (a5)^2 = a(a+1) followed by 25\n\nWHY: (10a+5)^2 = 100a^2+100a+25 = 100a(a+1)+25\n  So prefix=a(a+1), suffix=25\n\nEx: 35^2 → 3×4=12, append 25 → 1225 ✓\n  65^2 → 6×7=42, append 25 → 4225 ✓",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "1=1   2=4   3=9   4=16   5=25   6=36\n7=49  8=64  9=81  10=100 11=121 12=144\n13=169 14=196 15=225 16=256 17=289 18=324\n19=361 20=400 21=441 22=484 23=529 24=576\n25=625 26=676 27=729 28=784 29=841 30=900\nTRICK: (a5)^2 = a(a+1) followed by 25\n\nWHY: (10a+5)^2 = 100a^2+100a+25 = 100a(a+1)+25\n  So prefix=a(a+1), suffix=25\n\nEx: 35^2 → 3×4=12, append 25 → 1225 ✓\n  65^2 → 6×7=42, append 25 → 4225 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
