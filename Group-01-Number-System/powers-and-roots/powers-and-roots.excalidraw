    {
      "id": "el_66",
      "type": "text",
      "x": 1005,
      "y": 1543,
      "width": 267,
      "height": 202,
      "text": "LOGIC:\nStep 1: 7's cycle: 7,9,3,1 (period=4)\nStep 2: 245%4 = 1 → 1st in cycle = 7\n\nTRICK:\nPeriod-4 digits: 2,3,7,8\nn mod 4 → pick from cycle\nIf remainder=0 → use LAST in cycle\n\n  7^1=7  7^2=9  7^3=3  7^4=1\n   [1]    [2]    [3]    [4]\n  245 mod 4 = 1 → pick [1] = 7\n\nAnswer: Unit digit = 7 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6600,
      "version": 1,
      "versionNonce": 66,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 7's cycle: 7,9,3,1 (period=4)\nStep 2: 245%4 = 1 → 1st in cycle = 7\n\nTRICK:\nPeriod-4 digits: 2,3,7,8\nn mod 4 → pick from cycle\nIf remainder=0 → use LAST in cycle\n\n  7^1=7  7^2=9  7^3=3  7^4=1\n   [1]    [2]    [3]    [4]\n  245 mod 4 = 1 → pick [1] = 7\n\nAnswer: Unit digit = 7 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
