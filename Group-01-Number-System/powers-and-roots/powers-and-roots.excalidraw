    {
      "id": "el_71",
      "type": "text",
      "x": 65,
      "y": 1909,
      "width": 310,
      "height": 202,
      "text": "LOGIC:\nStep 1: 3^n mod 5 cycle: 3,4,2,1 (period=4)\nStep 2: 50%4=2 → 2nd in cycle = 4\n\nTRICK:\nFermat's: 3^4≡1(mod 5)\n3^50 = (3^4)^12 × 3^2 = 1×9 = 4(mod 5)\nFind cycle mod divisor, then use it\n\n  3^1≡3  3^2≡4  3^3≡2  3^4≡1 (mod 5)\n   [1]    [2]    [3]    [4]\n  50 mod 4 = 2 → pick [2] = 4\n\nAnswer: Remainder = 4 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7100,
      "version": 1,
      "versionNonce": 71,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 3^n mod 5 cycle: 3,4,2,1 (period=4)\nStep 2: 50%4=2 → 2nd in cycle = 4\n\nTRICK:\nFermat's: 3^4≡1(mod 5)\n3^50 = (3^4)^12 × 3^2 = 1×9 = 4(mod 5)\nFind cycle mod divisor, then use it\n\n  3^1≡3  3^2≡4  3^3≡2  3^4≡1 (mod 5)\n   [1]    [2]    [3]    [4]\n  50 mod 4 = 2 → pick [2] = 4\n\nAnswer: Remainder = 4 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
