    {
      "id": "el_46",
      "type": "text",
      "x": 535,
      "y": 1178,
      "width": 245,
      "height": 202,
      "text": "LOGIC:\nStep 1: 288 = 144×2 = 12²×2\nStep 2: √288 = √(144×2) = 12√2\n\nTRICK:\nFind largest perfect square factor\n288/4=72, 72/4=18, 18/9=2\n144×2 → 12√2\n\n  288 = 2⁵ × 3²\n      = (2² × 3)² × 2\n      = 12² × 2  → √288 = 12√2\n\nAnswer: 12√2 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4600,
      "version": 1,
      "versionNonce": 46,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 288 = 144×2 = 12²×2\nStep 2: √288 = √(144×2) = 12√2\n\nTRICK:\nFind largest perfect square factor\n288/4=72, 72/4=18, 18/9=2\n144×2 → 12√2\n\n  288 = 2⁵ × 3²\n      = (2² × 3)² × 2\n      = 12² × 2  → √288 = 12√2\n\nAnswer: 12√2 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
