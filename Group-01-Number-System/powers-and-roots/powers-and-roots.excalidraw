    {
      "id": "el_51",
      "type": "text",
      "x": 1005,
      "y": 1162,
      "width": 267,
      "height": 216,
      "text": "LOGIC:\nStep 1: 5832 = 2³×3⁶ = (2×9)³ = 18³\nStep 2: ∛5832 = 18\n\nTRICK:\nLast digit 2 → answer ends in 8\nRemove last 3 digits: 5 → nearest\ncube below = 1³=1, so tens=1\nAnswer = 18\n\n  5832 → unit=2 → cube root ends in 8\n  5    → 1³=1 < 5 < 2³=8 → tens=1\n  ∛5832 = 18\n\nAnswer: 18 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5100,
      "version": 1,
      "versionNonce": 51,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 5832 = 2³×3⁶ = (2×9)³ = 18³\nStep 2: ∛5832 = 18\n\nTRICK:\nLast digit 2 → answer ends in 8\nRemove last 3 digits: 5 → nearest\ncube below = 1³=1, so tens=1\nAnswer = 18\n\n  5832 → unit=2 → cube root ends in 8\n  5    → 1³=1 < 5 < 2³=8 → tens=1\n  ∛5832 = 18\n\nAnswer: 18 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
