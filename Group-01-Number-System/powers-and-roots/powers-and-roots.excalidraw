    {
      "id": "el_26",
      "type": "text",
      "x": 65,
      "y": 797,
      "width": 296,
      "height": 202,
      "text": "LOGIC:\nStep 1: Numerator: 2^5 × 2^3 = 2^8\nStep 2: 2^8 / 2^4 = 2^(8-4) = 2^4 = 16\n\nTRICK:\nSame base → add/subtract exponents\nNum: 5+3=8, then 8-4=4\n2^4 = 16\n\n  2^5 × 2^3     2^8\n  ────────── = ───── = 2^(8-4) = 2^4 = 16\n     2^4        2^4\n\nAnswer: 16 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2600,
      "version": 1,
      "versionNonce": 26,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Numerator: 2^5 × 2^3 = 2^8\nStep 2: 2^8 / 2^4 = 2^(8-4) = 2^4 = 16\n\nTRICK:\nSame base → add/subtract exponents\nNum: 5+3=8, then 8-4=4\n2^4 = 16\n\n  2^5 × 2^3     2^8\n  ────────── = ───── = 2^(8-4) = 2^4 = 16\n     2^4        2^4\n\nAnswer: 16 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
