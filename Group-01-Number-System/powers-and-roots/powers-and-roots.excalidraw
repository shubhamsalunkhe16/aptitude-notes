    {
      "id": "el_31",
      "type": "text",
      "x": 535,
      "y": 781,
      "width": 245,
      "height": 231,
      "text": "LOGIC:\nStep 1: Num exponent: 4+(-2)+1 = 3\n  Den exponent: 2+(-1) = 1\nStep 2: 3^3/3^1 = 3^2 = 9\n\nTRICK:\nCollect all exponents, subtract\nNum total - Den total = 3-1 = 2\n3^2 = 9\n\n  Num: +4 -2 +1 = 3\n  Den: +2 -1     = 1\n  ─────────────────\n  Net: 3-1 = 2 → 3^2 = 9\n\nAnswer: 9 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3100,
      "version": 1,
      "versionNonce": 31,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Num exponent: 4+(-2)+1 = 3\n  Den exponent: 2+(-1) = 1\nStep 2: 3^3/3^1 = 3^2 = 9\n\nTRICK:\nCollect all exponents, subtract\nNum total - Den total = 3-1 = 2\n3^2 = 9\n\n  Num: +4 -2 +1 = 3\n  Den: +2 -1     = 1\n  ─────────────────\n  Net: 3-1 = 2 → 3^2 = 9\n\nAnswer: 9 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
