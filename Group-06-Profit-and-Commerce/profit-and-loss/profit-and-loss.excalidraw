    {
      "id": "el_35",
      "type": "text",
      "x": 65,
      "y": 1263,
      "width": 231,
      "height": 173,
      "text": "LOGIC:\nStep 1: CP = SP x 100/(100+P%)\nStep 2: = 540 x 100/108 = Rs.500\n\n  CP=500 --+8%--> SP=540\n\nTRICK:\n108% of CP = 540\nCP = 540/1.08 = Rs.500\nFor LOSS: CP = SP x 100/(100-L%)\n\nAnswer: CP = Rs.500 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
