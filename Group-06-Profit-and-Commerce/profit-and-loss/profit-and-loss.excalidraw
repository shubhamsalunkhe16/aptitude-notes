      "roundness": null
    },
    {
      "id": "el_60",
      "type": "text",
      "x": 1005,
      "y": 1618,
      "width": 245,
      "height": 188,
      "text": "LOGIC:\nStep 1: CP=5x, SP=7x, Profit=2x\nStep 2: P% = (2x/5x) x 100 = 40%\n\n  CP |=====|       = 5 parts\n  SP |=======|     = 7 parts\n\nTRICK:\nP% = (b-a)/a x 100 = (7-5)/5 x 100\n= 2/5 x 100 = 40%\nIf a>b → Loss% = (a-b)/a x 100\n\nAnswer: Profit = 40% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6000,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: CP=5x, SP=7x, Profit=2x\nStep 2: P% = (2x/5x) x 100 = 40%\n\n  CP |=====|       = 5 parts\n  SP |=======|     = 7 parts\n\nTRICK:\nP% = (b-a)/a x 100 = (7-5)/5 x 100\n= 2/5 x 100 = 40%\nIf a>b → Loss% = (a-b)/a x 100\n\nAnswer: Profit = 40% ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
