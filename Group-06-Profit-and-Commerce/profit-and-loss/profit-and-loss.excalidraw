    },
    {
      "id": "el_70",
      "type": "text",
      "x": 535,
      "y": 1988,
      "width": 288,
      "height": 173,
      "text": "LOGIC:\nStep 1: Let CP=300. Part1 CP=200\n  SP1 = 200x1.2 = 240\nStep 2: Break-even: SP2=300-240=60\nStep 3: Loss on 100 = 40 → 40%\n\nTRICK:\n2/3 at +20% earns 2/3x20=13.33% on total\nRemaining 1/3 must lose 13.33%\nLoss on 1/3 = 13.33/(1/3) = 40%\n\nAnswer: Sell rest at 40% loss ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7000,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Let CP=300. Part1 CP=200\n  SP1 = 200x1.2 = 240\nStep 2: Break-even: SP2=300-240=60\nStep 3: Loss on 100 = 40 → 40%\n\nTRICK:\n2/3 at +20% earns 2/3x20=13.33% on total\nRemaining 1/3 must lose 13.33%\nLoss on 1/3 = 13.33/(1/3) = 40%\n\nAnswer: Sell rest at 40% loss ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
