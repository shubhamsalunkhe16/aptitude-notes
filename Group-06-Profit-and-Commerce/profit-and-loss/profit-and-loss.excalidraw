    {
      "id": "el_50",
      "type": "text",
      "x": 65,
      "y": 1602,
      "width": 245,
      "height": 173,
      "text": "LOGIC:\nStep 1: Let CP per item = 1\n  CP of 20 = 20, SP of 16 = 20\nStep 2: SP per item = 20/16 = 1.25\nStep 3: P% = 0.25/1 x 100 = 25%\n\nTRICK:\nP% = (X-Y)/Y x 100\n= (20-16)/16 x 100 = 25%\nX>Y=Profit, X<Y=Loss\n\nAnswer: Profit = 25% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5000,
      "version": 1,
      "versionNonce": 50,
      "isDeleted": false,
