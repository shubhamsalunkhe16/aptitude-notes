    {
      "id": "el_25",
      "type": "text",
      "x": 535,
      "y": 938,
      "width": 267,
      "height": 173,
      "text": "LOGIC:\nStep 1: Loss = CP-SP = 800-680 = 120\nStep 2: L% = (120/800) x 100 = 15%\n\n  CP |████████████████████| 100%\n  SP |█████████████████   |  85%\n\nTRICK:\n120/800 = 3/20 = 15%\nOr: SP/CP = 680/800 = 0.85 → 15% loss\n\nAnswer: Loss = 15% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
