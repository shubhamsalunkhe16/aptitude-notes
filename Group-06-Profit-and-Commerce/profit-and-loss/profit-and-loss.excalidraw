      "x": 65,
      "y": 1907,
      "width": 816,
      "height": 33,
      "text": "A sells to B at 20% profit. B sells to C at 10% loss. A's\nCP=1000. Find C's price.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
