    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 954,
      "width": 274,
      "height": 159,
      "text": "LOGIC:\nStep 1: Profit = SP-CP = 620-500 = 120\nStep 2: P% = (120/500) x 100 = 24%\n\n  CP=500 ---+120---> SP=620\n\nTRICK:\nSP/CP = 620/500 = 1.24 → 24% profit\nOr: 120/500 = 24/100 instantly\n\nAnswer: Profit = 24% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Profit = SP-CP = 620-500 = 120\nStep 2: P% = (120/500) x 100 = 24%\n\n  CP=500 ---+120---> SP=620\n\nTRICK:\nSP/CP = 620/500 = 1.24 → 24% profit\nOr: 120/500 = 24/100 instantly\n\nAnswer: Profit = 24% ✓",
      "autoResize": true,
