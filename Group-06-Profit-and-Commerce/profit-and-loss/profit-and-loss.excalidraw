    {
      "id": "el_75",
      "type": "text",
      "x": 1005,
      "y": 1988,
      "width": 303,
      "height": 159,
      "text": "LOGIC:\nStep 1: 1000→+10%→1100→+20%→1320→+25%→1650\nStep 2: Each stage: SP = CP x (1+P%/100)\n\nTRICK:\nMultiply all multipliers:\n1000 x 1.1 x 1.2 x 1.25 = 1650\n= 1000 x 1.65 = Rs.1650\nOverall P% = 65%\n\nAnswer: Customer price = Rs.1650 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7500,
      "version": 1,
      "versionNonce": 75,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 1000→+10%→1100→+20%→1320→+25%→1650\nStep 2: Each stage: SP = CP x (1+P%/100)\n\nTRICK:\nMultiply all multipliers:\n1000 x 1.1 x 1.2 x 1.25 = 1650\n= 1000 x 1.65 = Rs.1650\nOverall P% = 65%\n\nAnswer: Customer price = Rs.1650 ✓",
      "autoResize": true,
