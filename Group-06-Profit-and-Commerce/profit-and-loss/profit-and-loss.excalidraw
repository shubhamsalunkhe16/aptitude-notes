    {
      "id": "el_68",
      "type": "text",
      "x": 535,
      "y": 1907,
      "width": 816,
      "height": 49,
      "text": "A merchant sells 2/3 of his goods at 20% profit. At what\npercentage loss must he sell the remaining goods to break\neven overall?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6800,
      "version": 1,
      "versionNonce": 68,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
