    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 938,
      "width": 245,
      "height": 173,
      "text": "LOGIC:\nStep 1: SP = CP x (100+P%)/100\nStep 2: = 1500 x 120/100 = Rs.1800\n\n  1500 ----+20%----> 1800\n\nTRICK:\n20% of 1500 = 300\nSP = 1500+300 = 1800\nFor LOSS: SP = CP x (100-L%)/100\n\nAnswer: SP = Rs.1800 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
