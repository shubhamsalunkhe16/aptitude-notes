    {
      "id": "el_45",
      "type": "text",
      "x": 1005,
      "y": 1279,
      "width": 288,
      "height": 159,
      "text": "LOGIC:\nStep 1: Charges for 1000g, gives 900g\nStep 2: Extra = 1000-900 = 100g\nStep 3: Gain% = (100/900) x 100 = 11.11%\n\nTRICK:\nFormula: (True-False)/False x 100\n= (1000-900)/900 x 100 = 11.11%\nBase is always FALSE weight!\n\nAnswer: Gain = 11.11% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
