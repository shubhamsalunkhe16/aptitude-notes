      ],
      "containerId": null,
      "originalText": "A trader wants 20% profit after giving 10% discount. If CP\nis Rs.500, what should be the marked price?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_44",
      "type": "text",
      "x": 1005,
      "y": 1315,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4400,
      "version": 1,
      "versionNonce": 44,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_45",
      "type": "text",
      "x": 1005,
      "y": 1337,
      "width": 324,
      "height": 202,
      "text": "LOGIC:\nStep 1: SP needed = 500x120/100 = 600\nStep 2: 90% of MP = 600\n        MP = 600/0.9 = Rs.666.67\n\n  CP=500 ──+33%──→ MP=666.67 ──-10%──→ SP=600\n  (need 20% profit on CP=500)\n\nTRICK:\nMP = CP x (100+P%)/(100-D%)\n= 500 x 120/90 = Rs.666.67\nMarkup = (666.67-500)/500 = 33.33%\n\nAnswer: MP = Rs.666.67 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4500,
      "version": 1,
      "versionNonce": 45,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: SP needed = 500x120/100 = 600\nStep 2: 90% of MP = 600\n        MP = 600/0.9 = Rs.666.67\n\n  CP=500 ──+33%──→ MP=666.67 ──-10%──→ SP=600\n  (need 20% profit on CP=500)\n\nTRICK:\nMP = CP x (100+P%)/(100-D%)\n= 500 x 120/90 = Rs.666.67\nMarkup = (666.67-500)/500 = 33.33%\n\nAnswer: MP = Rs.666.67 ✓",
