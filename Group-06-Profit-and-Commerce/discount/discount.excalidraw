      "roundness": null
    },
    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 406,
      "height": 266,
      "text": "Two successive discounts d1% and d2%:\n  SP = MP × (100-d1)/100 × (100-d2)/100\n\nSingle equivalent discount:\n  = d1 + d2 - (d1 × d2)/100\n\nThree successive discounts d1, d2, d3:\nSP = MP × (100-d1)/100 × (100-d2)/100 × (100-d3)/100\n\nOrder does NOT matter:\n  20% then 10% = 10% then 20% = 28%\n\nWHY: 2nd discount applies to already-reduced price.\n  d1+d2 overcounts, so subtract overlap d1×d2/100.\n\nEx: d1=20%, d2=10%\n  Equiv = 20+10-(200/100) = 28% (not 30%)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "Two successive discounts d1% and d2%:\n  SP = MP × (100-d1)/100 × (100-d2)/100\n\nSingle equivalent discount:\n  = d1 + d2 - (d1 × d2)/100\n\nThree successive discounts d1, d2, d3:\nSP = MP × (100-d1)/100 × (100-d2)/100 × (100-d3)/100\n\nOrder does NOT matter:\n  20% then 10% = 10% then 20% = 28%\n\nWHY: 2nd discount applies to already-reduced price.\n  d1+d2 overcounts, so subtract overlap d1×d2/100.\n\nEx: d1=20%, d2=10%\n  Equiv = 20+10-(200/100) = 28% (not 30%)",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
