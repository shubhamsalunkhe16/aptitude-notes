    },
    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 969,
      "width": 281,
      "height": 202,
      "text": "LOGIC:\nStep 1: 600 = MP x 75/100\nStep 2: MP = 600 x 100/75 = Rs.800\nStep 3: Check: 25% of 800=200, SP=600 ✓\n\n  MP=? ──-25%──→ SP=600\n  MP=800 ──-200──→ SP=600\n\nTRICK:\nMP = SP x 100/(100-D%)\n= 600 x 100/75 = Rs.800\n75% of MP = SP → MP = SP/0.75\n\nAnswer: Marked Price = Rs.800 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 600 = MP x 75/100\nStep 2: MP = 600 x 100/75 = Rs.800\nStep 3: Check: 25% of 800=200, SP=600 ✓\n\n  MP=? ──-25%──→ SP=600\n  MP=800 ──-200──→ SP=600\n\nTRICK:\nMP = SP x 100/(100-D%)\n= 600 x 100/75 = Rs.800\n75% of MP = SP → MP = SP/0.75\n\nAnswer: Marked Price = Rs.800 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
