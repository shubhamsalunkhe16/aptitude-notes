    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 969,
      "width": 260,
      "height": 173,
      "text": "LOGIC:\nStep 1: Disc = 15% of 800 = Rs.120\nStep 2: SP = 800-120 = Rs.680\n\n  MP=800 ---15% off---> SP=680\n\nTRICK:\nSP = MP x (100-D%)/100\n= 800 x 85/100 = Rs.680\n(100-D%) gives SP as % of MP\n\nAnswer: Discount=Rs.120, SP=Rs.680 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Disc = 15% of 800 = Rs.120\nStep 2: SP = 800-120 = Rs.680\n\n  MP=800 ---15% off---> SP=680\n\nTRICK:\nSP = MP x (100-D%)/100\n= 800 x 85/100 = Rs.680\n(100-D%) gives SP as % of MP\n\nAnswer: Discount=Rs.120, SP=Rs.680 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
