    {
      "id": "el_58",
      "type": "text",
      "x": 1005,
      "y": 1640,
      "width": 773,
      "height": 33,
      "text": "Which is better: a flat 40% discount OR two successive\ndiscounts of 25% and 20%? Compare for MP = Rs.1000.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5800,
      "version": 1,
      "versionNonce": 58,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "Which is better: a flat 40% discount OR two successive\ndiscounts of 25% and 20%? Compare for MP = Rs.1000.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_59",
      "type": "text",
      "x": 1005,
      "y": 1683,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5900,
      "version": 1,
      "versionNonce": 59,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_60",
      "type": "text",
      "x": 1005,
      "y": 1705,
      "width": 339,
      "height": 216,
      "text": "LOGIC:\nStep 1: Flat 40%: SP = 1000x0.6 = 600\nStep 2: 25%+20%: 1000→750→600\n  Both give SP = Rs.600\n\n  Flat:  MP=1000 ──-40%──→ SP=600\n  Succ:  MP=1000 ──-25%──→ 750 ──-20%──→ SP=600\n\nTRICK:\nEquiv = 25+20-(25x20)/100 = 40%\nSame as flat! Both equal here.\nRule: d1+d2 > flat always UNLESS\nd1+d2-(d1d2/100) = flat exactly\n\nAnswer: Both are equal at 40% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6000,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Flat 40%: SP = 1000x0.6 = 600\nStep 2: 25%+20%: 1000→750→600\n  Both give SP = Rs.600\n\n  Flat:  MP=1000 ──-40%──→ SP=600\n  Succ:  MP=1000 ──-25%──→ 750 ──-20%──→ SP=600\n\nTRICK:\nEquiv = 25+20-(25x20)/100 = 40%\nSame as flat! Both equal here.\nRule: d1+d2 > flat always UNLESS\nd1+d2-(d1d2/100) = flat exactly\n\nAnswer: Both are equal at 40% ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
