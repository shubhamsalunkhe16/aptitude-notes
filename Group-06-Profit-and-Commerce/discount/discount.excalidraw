    {
      "id": "el_43",
      "type": "text",
      "x": 1005,
      "y": 1272,
      "width": 830,
      "height": 33,
      "text": "A trader wants 20% profit after giving 10% discount. If CP\nis Rs.500, what should be the marked price?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
