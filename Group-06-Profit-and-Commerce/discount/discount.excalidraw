    },
    {
      "id": "el_49",
      "type": "text",
      "x": 65,
      "y": 1683,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#862e9c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4900,
      "version": 1,
      "versionNonce": 49,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_50",
      "type": "text",
      "x": 65,
      "y": 1705,
      "width": 267,
      "height": 202,
      "text": "LOGIC:\nStep 1: Pays for 2, gets 3 items\nStep 2: Savings = 1 out of 3\nStep 3: D% = (1/3) x 100 = 33.33%\n\n  Pays: |===|===|   | 2 items\n  Gets: |===|===|===| 3 items\n\nTRICK:\nD% = Free/(Buy+Free) x 100\nB1G1=50%, B2G1=33%, B3G1=25%\nTRAP: denom = TOTAL items!\n\nAnswer: Effective discount = 33.33% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5000,
      "version": 1,
      "versionNonce": 50,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Pays for 2, gets 3 items\nStep 2: Savings = 1 out of 3\nStep 3: D% = (1/3) x 100 = 33.33%\n\n  Pays: |===|===|   | 2 items\n  Gets: |===|===|===| 3 items\n\nTRICK:\nD% = Free/(Buy+Free) x 100\nB1G1=50%, B2G1=33%, B3G1=25%\nTRAP: denom = TOTAL items!\n\nAnswer: Effective discount = 33.33% ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
