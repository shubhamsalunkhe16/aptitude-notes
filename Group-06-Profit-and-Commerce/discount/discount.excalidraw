    },
    {
      "id": "el_25",
      "type": "text",
      "x": 535,
      "y": 969,
      "width": 303,
      "height": 202,
      "text": "LOGIC:\nStep 1: Discount = 1500-1200 = Rs.300\nStep 2: D% = (300/1500) x 100 = 20%\n\n  MP |████████████████████| 1500 (100%)\n  SP |████████████████    | 1200 (80%)\n     |                |░░░| Disc=300 (20%)\n\nTRICK:\nSP/MP = 1200/1500 = 4/5 = 80%\nDiscount = 100%-80% = 20%\nTRAP: D% is on MP, NOT on SP!\n\nAnswer: Discount = 20% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2500,
      "version": 1,
      "versionNonce": 25,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Discount = 1500-1200 = Rs.300\nStep 2: D% = (300/1500) x 100 = 20%\n\n  MP |████████████████████| 1500 (100%)\n  SP |████████████████    | 1200 (80%)\n     |                |░░░| Disc=300 (20%)\n\nTRICK:\nSP/MP = 1200/1500 = 4/5 = 80%\nDiscount = 100%-80% = 20%\nTRAP: D% is on MP, NOT on SP!\n\nAnswer: Discount = 20% ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
