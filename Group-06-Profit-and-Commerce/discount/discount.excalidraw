    {
      "id": "el_7",
      "type": "text",
      "x": 535,
      "y": 100,
      "width": 401,
      "height": 17,
      "text": "Successive Discount Formulas",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#2f9e44",
