    {
      "id": "el_53",
      "type": "text",
      "x": 535,
      "y": 1640,
      "width": 830,
      "height": 49,
      "text": "Shop A offers 30% discount. Shop B offers successive\ndiscounts of 20% and 15%. Which is better for the buyer on\nsame MP?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5300,
      "version": 1,
      "versionNonce": 53,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "Shop A offers 30% discount. Shop B offers successive\ndiscounts of 20% and 15%. Which is better for the buyer on\nsame MP?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_54",
      "type": "text",
      "x": 535,
      "y": 1699,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5400,
      "version": 1,
      "versionNonce": 54,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1721,
      "width": 324,
      "height": 231,
      "text": "LOGIC:\nStep 1: Let MP=100\n  A: 30% flat → SP=70\n  B: 100→80→68 (SP=68)\nStep 2: B cheaper by Rs.2 per 100\n\n  Shop A: MP=100 ──-30%──→ SP=70\n  Shop B: MP=100 ──-20%──→ 80 ──-15%──→ SP=68\n\nTRICK:\nB equiv = 20+15-(20x15)/100 = 32%\nA=30% vs B=32% → B is better!\n  A: pay 70, B: pay 68\nBuyer saves more at Shop B\n\nAnswer: Shop B is better (32% vs 30%) ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Let MP=100\n  A: 30% flat → SP=70\n  B: 100→80→68 (SP=68)\nStep 2: B cheaper by Rs.2 per 100\n\n  Shop A: MP=100 ──-30%──→ SP=70\n  Shop B: MP=100 ──-20%──→ 80 ──-15%──→ SP=68\n\nTRICK:\nB equiv = 20+15-(20x15)/100 = 32%\nA=30% vs B=32% → B is better!\n  A: pay 70, B: pay 68\nBuyer saves more at Shop B\n\nAnswer: Shop B is better (32% vs 30%) ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
