    {
      "id": "el_10",
      "type": "text",
      "x": 1005,
      "y": 100,
      "width": 397,
      "height": 15,
      "text": "Markup & Profit After Discount",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
