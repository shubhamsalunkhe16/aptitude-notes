    {
      "id": "el_50",
      "type": "text",
      "x": 65,
      "y": 1361,
      "width": 317,
      "height": 188,
      "text": "LOGIC:\nStep 1: Century: 1600→0, 300→1\nStep 2: Years 1901-1946 (46yr)\n  Leap=11, Ord=35 → 35+22=57%7=1\nStep 3: Months Jan-Jul: 3+0+3+2+3+2+3=16%7=2\nStep 4: Day: 15%7=1\n  Total = 1+1+2+1 = 5\n\nTRICK:\n5 = Friday (0=Sun...6=Sat)\nSame method every time!\n\nAnswer: Friday ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5000,
