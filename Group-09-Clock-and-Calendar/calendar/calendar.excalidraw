    },
    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 672,
      "width": 260,
      "height": 188,
      "text": "LOGIC:\nStep 1: Century: 1600→0, 300→1 = 1\nStep 2: Years 1901-1949 (49yr)\n  Leap=12, Ord=37 → 37+24=61%7=5\nStep 3: Months: 0 (Jan), Day: 26%7=5\nStep 4: Total = 1+5+0+5 = 11%7 = 4\n\nTRICK:\n4 = Thursday (0=Sun...6=Sat)\nAdd: century + years + months + day\nAll mod 7 at the end\n\nAnswer: Thursday ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Century: 1600→0, 300→1 = 1\nStep 2: Years 1901-1949 (49yr)\n  Leap=12, Ord=37 → 37+24=61%7=5\nStep 3: Months: 0 (Jan), Day: 26%7=5\nStep 4: Total = 1+5+0+5 = 11%7 = 4\n\nTRICK:\n4 = Thursday (0=Sun...6=Sat)\nAdd: century + years + months + day\nAll mod 7 at the end\n\nAnswer: Thursday ✓",
      "autoResize": true,
