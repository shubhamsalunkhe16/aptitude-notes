    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 372,
      "width": 328,
      "height": 156,
      "text": "Same calendar = same start day + same type\n\nOrdinary year repeats: +6, +11, +11\nLeap year repeats: every 28 years\n\nCount cumulative odd days until\nsum mod 7 = 0, then verify same\ntype (ordinary/leap)\n\n400 years = exact repeat (0 odd days)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
