    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 312,
      "height": 172,
      "text": "Odd Days = remainder when total days / 7\n\nDay Code:\n0=Sun  1=Mon  2=Tue  3=Wed\n4=Thu  5=Fri  6=Sat\n\nMonth Codes (odd days per month):\nJan=3  Feb=0/1  Mar=3  Apr=2\nMay=3  Jun=2    Jul=3  Aug=3\nSep=2  Oct=3    Nov=2  Dec=3\n(Feb=0 ordinary, 1 leap)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 500,
      "version": 1,
      "versionNonce": 5,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f0"
      ],
      "containerId": null,
      "originalText": "Odd Days = remainder when total days / 7\n\nDay Code:\n0=Sun  1=Mon  2=Tue  3=Wed\n4=Thu  5=Fri  6=Sat\n\nMonth Codes (odd days per month):\nJan=3  Feb=0/1  Mar=3  Apr=2\nMay=3  Jun=2    Jul=3  Aug=3\nSep=2  Oct=3    Nov=2  Dec=3\n(Feb=0 ordinary, 1 leap)",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
