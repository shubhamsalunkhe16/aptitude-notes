    {
      "id": "el_60",
      "type": "text",
      "x": 1005,
      "y": 1361,
      "width": 252,
      "height": 173,
      "text": "LOGIC:\nStep 1: Wed=3, Fri=5, gap=2\n  First Fri = Mar 1+2 = Mar 3\nStep 2: Then +7 each: 3,10,17,24,31\n\nTRICK:\nGap = target - known day code\nIf gap<0: add 7\nFirst = known_date + gap\nThen every +7 until month ends\n\nAnswer: 3, 10, 17, 24, 31 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
