    {
      "id": "el_40",
      "type": "text",
      "x": 535,
      "y": 1038,
      "width": 260,
      "height": 173,
      "text": "LOGIC:\nStep 1: 100yr = 76ord+24leap\n  = 76+48 = 124, 124%7 = 5\nStep 2: 200yr=10%7=3, 300yr=15%7=1\n  400yr=20%7=6+extra leap=0\n\nTRICK:\nMemorize: 100→5, 200→3, 300→1, 400→0\nPattern repeats every 400 years\n400yr = 0 → calendar repeats!\n\nAnswer: 300yrs=1, 400yrs=0 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
