    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 258,
      "height": 141,
      "text": "Ordinary year (365d) → 1 odd day\nLeap year (366d)     → 2 odd days\n\nCentury odd days:\n100 yrs → 5    200 yrs → 3\n300 yrs → 1    400 yrs → 0\n\nPattern repeats: 0, 5, 3, 1\n(for 400, 100, 200, 300)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
