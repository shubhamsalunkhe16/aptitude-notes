    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 672,
      "width": 252,
      "height": 216,
      "text": "LOGIC:\nStep 1: Odd days = total days mod 7\n  10/7 = 1 week + 3 remainder\nStep 2: 3 odd days\n\nTRICK:\nJust divide by 7, take remainder\n15 days → 15%7 = 1 odd day\n365 days → 365%7 = 1 odd day\n366 days → 366%7 = 2 odd days\n\n  Day codes: 0=Sun 1=Mon 2=Tue\n  3=Wed 4=Thu 5=Fri 6=Sat\n\nAnswer: 10 days = 3 odd days ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Odd days = total days mod 7\n  10/7 = 1 week + 3 remainder\nStep 2: 3 odd days\n\nTRICK:\nJust divide by 7, take remainder\n15 days → 15%7 = 1 odd day\n365 days → 365%7 = 1 odd day\n366 days → 366%7 = 2 odd days\n\n  Day codes: 0=Sun 1=Mon 2=Tue\n  3=Wed 4=Thu 5=Fri 6=Sat\n\nAnswer: 10 days = 3 odd days ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
