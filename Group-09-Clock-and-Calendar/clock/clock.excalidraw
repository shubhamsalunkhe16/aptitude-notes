    {
      "id": "el_11",
      "type": "text",
      "x": 1005,
      "y": 125,
      "width": 344,
      "height": 110,
      "text": "Between H and (H+1) o'clock:\n  M = (30H + theta) x 2/11\n  M = (30H - theta) x 2/11\n\nTwo solutions (reject if M<0 or M>=60)\nOverlap: theta=0  Right: theta=90  Straight:\ntheta=180",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1100,
      "version": 1,
      "versionNonce": 11,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f2"
      ],
      "containerId": null,
      "originalText": "Between H and (H+1) o'clock:\n  M = (30H + theta) x 2/11\n  M = (30H - theta) x 2/11\n\nTwo solutions (reject if M<0 or M>=60)\nOverlap: theta=0  Right: theta=90  Straight:\ntheta=180",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
