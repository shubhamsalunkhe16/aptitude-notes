    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 383,
      "height": 78,
      "text": "Hour hand   = 0.5° per min = 30° per hr\nMinute hand = 6° per min   = 360° per hr\n\nRelative speed = 6 - 0.5 = 5.5° per min\n(minute hand gains 5.5° every min over hour hand)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
