      ],
      "containerId": null,
      "originalText": "Hour hand   = 0.5° per min = 30° per hr\nMinute hand = 6° per min   = 360° per hr\n\nRelative speed = 6 - 0.5 = 5.5° per min\n(minute hand gains 5.5° every min over hour hand)",
      "autoResize": true,
