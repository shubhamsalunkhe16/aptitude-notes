    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 310,
      "width": 359,
      "height": 110,
      "text": "             12 hrs | 24 hrs\nOverlap(0):    11   |   22   (NOT 12/24!)\nRight(90):     22   |   44\nStraight(180): 11   |   22   (NOT 12/24!)\nAny theta:     22   |   44\n\nTime between overlaps = 12/11 hr = 65min 27sec",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
