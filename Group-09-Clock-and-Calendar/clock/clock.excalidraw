    {
      "id": "el_66",
      "type": "text",
      "x": 1005,
      "y": 1299,
      "width": 224,
      "height": 159,
      "text": "LOGIC:\nStep 1: Elapsed = 12 hours\n  Gain = 5×12 = 60 min = 1 hr\nStep 2: Clock = 8PM + 1hr = 9PM\n\nTRICK:\nGains → FAST → shows MORE\nLoses → SLOW → shows LESS\nClock = actual ± (rate × hours)\n\nAnswer: 9:00 PM ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
