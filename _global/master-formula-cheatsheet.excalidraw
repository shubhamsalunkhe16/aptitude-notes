      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_151",
      "type": "text",
      "x": 1022,
      "y": 5640,
      "width": 273,
      "height": 219,
      "text": "Same direction (overtaking):\n  Relative = S1 - S2\n  ──→  ──→\n\nOpposite direction (crossing):\n  Relative = S1 + S2\n  ──→  ←──\n\nWHY: Gap between trains closes at\n  combined rate (opp) or difference\n  rate (same dir).\n\nEx: 60 & 40 km/h → Opp=100,\n  Same=20 km/h",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 15100,
      "version": 1,
      "versionNonce": 151,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_8_2"
      ],
      "containerId": null,
      "originalText": "Same direction (overtaking):\n  Relative = S1 - S2\n  ──→  ──→\n\nOpposite direction (crossing):\n  Relative = S1 + S2\n  ──→  ←──\n\nWHY: Gap between trains closes at\n  combined rate (opp) or difference\n  rate (same dir).\n\nEx: 60 & 40 km/h → Opp=100,\n  Same=20 km/h",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_152",
      "type": "rectangle",
      "x": 50,
      "y": 5912,
