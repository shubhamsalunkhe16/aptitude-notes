    {
      "id": "el_498",
      "type": "text",
      "x": 1022,
      "y": 18816,
      "width": 293,
      "height": 18,
      "text": "Sphere & Hemisphere",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
