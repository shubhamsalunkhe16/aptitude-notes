    {
      "id": "el_78",
      "type": "text",
      "x": 62,
      "y": 2981,
      "width": 401,
      "height": 18,
      "text": "BODMAS Order of Operations",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
