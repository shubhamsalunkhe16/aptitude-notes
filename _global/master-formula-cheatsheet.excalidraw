    {
      "id": "el_150",
      "type": "text",
      "x": 1022,
      "y": 5618,
      "width": 216,
      "height": 18,
      "text": "Relative Speed",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
