    {
      "id": "el_603",
      "type": "text",
      "x": 62,
      "y": 23356,
      "width": 339,
      "height": 18,
      "text": "Arithmetic Series (AP)",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 60300,
      "version": 1,
      "versionNonce": 603,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_35_0"
      ],
      "containerId": null,
      "originalText": "Arithmetic Series (AP)",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_604",
      "type": "text",
      "x": 62,
      "y": 23378,
      "width": 289,
      "height": 172,
      "text": "nth term:  a(n) = a + (n-1)d\nSum of n:  S(n) = n/2 x [2a + (n-1)d]\n\nWHY: Each term adds d to previous.\n  a, a+d, a+2d... so nth = a+(n-1)d\n\nEx: a=3, d=5 → 3,8,13,18...\n  6th term = 3 + 5x5 = 28\n\nCommon diff d = a(2)-a(1) = constant\nMissing term = (prev + next) / 2",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 60400,
      "version": 1,
      "versionNonce": 604,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_35_0"
      ],
      "containerId": null,
      "originalText": "nth term:  a(n) = a + (n-1)d\nSum of n:  S(n) = n/2 x [2a + (n-1)d]\n\nWHY: Each term adds d to previous.\n  a, a+d, a+2d... so nth = a+(n-1)d\n\nEx: a=3, d=5 → 3,8,13,18...\n  6th term = 3 + 5x5 = 28\n\nCommon diff d = a(2)-a(1) = constant\nMissing term = (prev + next) / 2",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
