    {
      "id": "el_51",
      "type": "text",
      "x": 1022,
      "y": 1974,
      "width": 293,
      "height": 18,
      "text": "Digits & Estimation",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5100,
      "version": 1,
      "versionNonce": 51,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_2_5"
      ],
      "containerId": null,
      "originalText": "Digits & Estimation",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
