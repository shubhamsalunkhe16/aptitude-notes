      ],
      "containerId": null,
      "originalText": "Squares: 1,4,9,16,25,36,49,64,81,100\nCubes:   1,8,27,64,125,216,343,512\n\nn^2+1: 2,5,10,17,26   n^2-1: 0,3,8,15,24\nn(n+1): 2,6,12,20,30  n^3+1: 2,9,28,65\n\nEx: Series 2,5,10,17,26 → n^2+1\n  n=1:1+1=2, n=2:4+1=5, n=5:25+1=26",
      "autoResize": true,
      "lineHeight": 1.2,
