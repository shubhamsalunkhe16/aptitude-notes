    {
      "id": "el_372",
      "type": "text",
      "x": 542,
      "y": 14688,
      "width": 324,
      "height": 18,
      "text": "Splitting Sum Formula",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 37200,
      "version": 1,
      "versionNonce": 372,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_21_4"
      ],
      "containerId": null,
      "originalText": "Splitting Sum Formula",
      "autoResize": true,
