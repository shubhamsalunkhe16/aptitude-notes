    {
      "id": "el_514",
      "type": "text",
      "x": 1022,
      "y": 19540,
      "width": 367,
      "height": 172,
      "text": "Gen +2: Grandfather, Grandmother\nGen +1: Father, Mother, Uncle, Aunt\nGen  0: Self, Brother, Sister, Spouse\nGen -1: Son, Daughter, Nephew, Niece\nGen -2: Grandson, Granddaughter\n\nWHY: Count parent/child words to find gap.\n  Each \"parent\" goes UP 1, \"child\" goes DOWN 1.\n\nEx: \"Father's father\" = 2 ups = Gen +2\n  = Grandfather",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 51400,
      "version": 1,
      "versionNonce": 514,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_29_2"
      ],
      "containerId": null,
      "originalText": "Gen +2: Grandfather, Grandmother\nGen +1: Father, Mother, Uncle, Aunt\nGen  0: Self, Brother, Sister, Spouse\nGen -1: Son, Daughter, Nephew, Niece\nGen -2: Grandson, Granddaughter\n\nWHY: Count parent/child words to find gap.\n  Each \"parent\" goes UP 1, \"child\" goes DOWN 1.\n\nEx: \"Father's father\" = 2 ups = Gen +2\n  = Grandfather",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
