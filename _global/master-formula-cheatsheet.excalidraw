    {
      "id": "el_351",
      "type": "text",
      "x": 62,
      "y": 14095,
      "width": 386,
      "height": 18,
      "text": "Doubling & Effective Rate",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 35100,
      "version": 1,
      "versionNonce": 351,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_20_3"
      ],
      "containerId": null,
      "originalText": "Doubling & Effective Rate",
