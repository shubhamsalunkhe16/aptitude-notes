    {
      "id": "el_420",
      "type": "text",
      "x": 1022,
      "y": 16164,
      "width": 232,
      "height": 18,
      "text": "Leap Year Rules",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
