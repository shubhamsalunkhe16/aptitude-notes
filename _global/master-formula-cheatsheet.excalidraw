        "f_34_2"
      ],
      "containerId": null,
      "originalText": "Two-Row & Rectangular",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_595",
      "type": "text",
      "x": 1022,
      "y": 22754,
      "width": 336,
      "height": 203,
      "text": "Two rows facing each other:\n  Opposite = directly facing in other row\n  Left/Right depends on person's own facing\n\nRectangular table:\n  Number seats clockwise\n  Opposite = across the table\n\nWHY: Two-row is like a mirror; left/right\n  flips when facing direction reverses.\n\nEx: Row1 faces S, Row2 faces N, 4 per row\n  R1-pos3 faces R2-pos3 (same column)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 59500,
      "version": 1,
      "versionNonce": 595,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_34_2"
      ],
      "containerId": null,
      "originalText": "Two rows facing each other:\n  Opposite = directly facing in other row\n  Left/Right depends on person's own facing\n\nRectangular table:\n  Number seats clockwise\n  Opposite = across the table\n\nWHY: Two-row is like a mirror; left/right\n  flips when facing direction reverses.\n\nEx: Row1 faces S, Row2 faces N, 4 per row\n  R1-pos3 faces R2-pos3 (same column)",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
