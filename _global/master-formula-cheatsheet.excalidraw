    {
      "id": "el_11",
      "type": "text",
      "x": 1005,
      "y": 125,
      "width": 266,
      "height": 125,
      "text": "x% of y = (x/100) × y\n% change = (change/original) × 100\n\nSuccessive: a% then b%\n= a + b + ab/100\n\nIf A is x% more than B:\nB is [x/(100+x)]×100 % less than A",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
