      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_166",
      "type": "text",
      "x": 1022,
      "y": 6310,
      "width": 312,
      "height": 234,
      "text": "SAME DISTANCE (go & return):\n  Avg = 2×S1×S2 / (S1+S2)\n  Ex: 40 & 60 → 2×40×60/100 = 48\n  NOT 50! (more time at slow speed)\n\nSAME TIME (drive 2hrs each):\n  Avg = (S1+S2) / 2\n  Ex: 40 & 60 → (40+60)/2 = 50\n\n1/3 EACH at 3 speeds:\n  Avg = 3/(1/S1 + 1/S2 + 1/S3)\n\nWHY: Avg=Total D / Total T.\n  Same D: T=D/S1+D/S2 → harmonic mean.\n  Same T: D=S1×T+S2×T → arithmetic mean.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 16600,
      "version": 1,
      "versionNonce": 166,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_9_2"
      ],
      "containerId": null,
      "originalText": "SAME DISTANCE (go & return):\n  Avg = 2×S1×S2 / (S1+S2)\n  Ex: 40 & 60 → 2×40×60/100 = 48\n  NOT 50! (more time at slow speed)\n\nSAME TIME (drive 2hrs each):\n  Avg = (S1+S2) / 2\n  Ex: 40 & 60 → (40+60)/2 = 50\n\n1/3 EACH at 3 speeds:\n  Avg = 3/(1/S1 + 1/S2 + 1/S3)\n\nWHY: Avg=Total D / Total T.\n  Same D: T=D/S1+D/S2 → harmonic mean.\n  Same T: D=S1×T+S2×T → arithmetic mean.",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
