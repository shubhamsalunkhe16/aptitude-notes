    },
    {
      "id": "el_577",
      "type": "text",
      "x": 542,
      "y": 22068,
      "width": 305,
      "height": 141,
      "text": "\"k times AS FAST as B\":\n  Sa = k × Sb\n  Ex: 5/3 times as fast → Sa = 5/3 Sb\n\n\"k times FASTER than B\" (ambiguous!):\n  Some mean Sa = (1+k) × Sb\n  Ex: 5/3 times faster → Sa = 8/3 Sb\n\nAlways check which interpretation fits!",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 57700,
      "version": 1,
      "versionNonce": 577,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_33_1"
      ],
      "containerId": null,
      "originalText": "\"k times AS FAST as B\":\n  Sa = k × Sb\n  Ex: 5/3 times as fast → Sa = 5/3 Sb\n\n\"k times FASTER than B\" (ambiguous!):\n  Some mean Sa = (1+k) × Sb\n  Ex: 5/3 times faster → Sa = 8/3 Sb\n\nAlways check which interpretation fits!",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
