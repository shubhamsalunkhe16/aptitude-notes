    },
    {
      "id": "el_598",
      "type": "text",
      "x": 62,
      "y": 23025,
      "width": 375,
      "height": 219,
      "text": "FACING CENTER:  Left=Clockwise  Right=Anti-CW\nFACING OUTSIDE: Left=Anti-CW   Right=Clockwise\n  (REVERSED from facing center!)\n\nLINEAR same dir: use normal left/right\nLINEAR two rows: each person's OWN perspective\n\"Xth to left of B\" = start at B, go left X times\n\nWHY: Looking at center, your left hand\n  traces CW arc. Facing out, it reverses\n  because you turned 180°.\n\nEx: 6 in circle facing center, A at pos 1\n  2nd left of A = 2 CW = pos 3",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 59800,
      "version": 1,
      "versionNonce": 598,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_34_3"
      ],
      "containerId": null,
      "originalText": "FACING CENTER:  Left=Clockwise  Right=Anti-CW\nFACING OUTSIDE: Left=Anti-CW   Right=Clockwise\n  (REVERSED from facing center!)\n\nLINEAR same dir: use normal left/right\nLINEAR two rows: each person's OWN perspective\n\"Xth to left of B\" = start at B, go left X times\n\nWHY: Looking at center, your left hand\n  traces CW arc. Facing out, it reverses\n  because you turned 180°.\n\nEx: 6 in circle facing center, A at pos 1\n  2nd left of A = 2 CW = pos 3",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
