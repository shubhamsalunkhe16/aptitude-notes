      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_499",
      "type": "text",
      "x": 1022,
      "y": 18838,
      "width": 328,
      "height": 250,
      "text": "SPHERE (r):\n  Volume = (4/3)*pi*r^3\n  SA = 4*pi*r^2\n\nHEMISPHERE (r):\n  Volume = (2/3)*pi*r^3\n  CSA = 2*pi*r^2\n  TSA = 3*pi*r^2\n\nHOLLOW CYLINDER (R, r, h):\n  Volume = pi*h*(R^2 - r^2)\n\nWHY: Sphere SA = exactly 4 great circles.\n  Hemisphere TSA = dome(2πr²) + base(πr²).\n\nEx: r=7 → SA=4×22/7×49=616",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 49900,
      "version": 1,
      "versionNonce": 499,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_28_2"
      ],
      "containerId": null,
      "originalText": "SPHERE (r):\n  Volume = (4/3)*pi*r^3\n  SA = 4*pi*r^2\n\nHEMISPHERE (r):\n  Volume = (2/3)*pi*r^3\n  CSA = 2*pi*r^2\n  TSA = 3*pi*r^2\n\nHOLLOW CYLINDER (R, r, h):\n  Volume = pi*h*(R^2 - r^2)\n\nWHY: Sphere SA = exactly 4 great circles.\n  Hemisphere TSA = dome(2πr²) + base(πr²).\n\nEx: r=7 → SA=4×22/7×49=616",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
