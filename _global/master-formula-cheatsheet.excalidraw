      "y": 22732,
      "width": 324,
      "height": 18,
      "text": "Two-Row & Rectangular",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
