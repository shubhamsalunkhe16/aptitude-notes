    {
      "id": "el_495",
      "type": "text",
      "x": 542,
      "y": 18816,
      "width": 232,
      "height": 18,
      "text": "Cylinder & Cone",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 49500,
      "version": 1,
      "versionNonce": 495,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_28_1"
      ],
      "containerId": null,
      "originalText": "Cylinder & Cone",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_496",
      "type": "text",
      "x": 542,
      "y": 18838,
      "width": 328,
      "height": 234,
      "text": "CYLINDER (r, h):\n  Volume = pi*r^2*h\n  CSA = 2*pi*r*h\n  TSA = 2*pi*r(r + h)\n\nCONE (r, h, slant l):\n  l = sqrt(r^2 + h^2)\n  Volume = (1/3)*pi*r^2*h\n  CSA = pi*r*l\n  TSA = pi*r(r + l)\n\nWHY: Cone = 1/3 of cylinder with same base\n  and height. CSA unrolls to a sector.\n\nEx: r=7, h=10 → Cyl V=1540, Cone V=513.3",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 49600,
      "version": 1,
      "versionNonce": 496,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_28_1"
      ],
      "containerId": null,
      "originalText": "CYLINDER (r, h):\n  Volume = pi*r^2*h\n  CSA = 2*pi*r*h\n  TSA = 2*pi*r(r + h)\n\nCONE (r, h, slant l):\n  l = sqrt(r^2 + h^2)\n  Volume = (1/3)*pi*r^2*h\n  CSA = pi*r*l\n  TSA = pi*r(r + l)\n\nWHY: Cone = 1/3 of cylinder with same base\n  and height. CSA unrolls to a sector.\n\nEx: r=7, h=10 → Cyl V=1540, Cone V=513.3",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
