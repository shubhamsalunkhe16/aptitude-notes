    },
    {
      "id": "el_169",
      "type": "text",
      "x": 62,
      "y": 6628,
      "width": 273,
      "height": 219,
      "text": "Same dir (chase/overtake):\n  ──→  ──→  Rel = S1 - S2\n\nOpposite dir (meeting):\n  ──→  ←──  Rel = S1 + S2\n\nCatch-up time = Gap / Rel speed\n\nWHY: Objects approach each other;\n  gap closes at combined rate (opp)\n  or difference rate (same dir).\n\nEx: S1=60, S2=40 → Rel_opp=100,\n  Rel_same=20 km/h",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 16900,
      "version": 1,
      "versionNonce": 169,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_9_3"
      ],
      "containerId": null,
      "originalText": "Same dir (chase/overtake):\n  ──→  ──→  Rel = S1 - S2\n\nOpposite dir (meeting):\n  ──→  ←──  Rel = S1 + S2\n\nCatch-up time = Gap / Rel speed\n\nWHY: Objects approach each other;\n  gap closes at combined rate (opp)\n  or difference rate (same dir).\n\nEx: S1=60, S2=40 → Rel_opp=100,\n  Rel_same=20 km/h",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
