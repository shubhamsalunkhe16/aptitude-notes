    {
      "id": "el_123",
      "type": "text",
      "x": 62,
      "y": 4594,
      "width": 309,
      "height": 18,
      "text": "Average Age of Group",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
