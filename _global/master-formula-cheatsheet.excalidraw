      "versionNonce": 462,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_26_4"
      ],
      "containerId": null,
      "originalText": "Sector, Arc & Path",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_463",
      "type": "text",
      "x": 542,
      "y": 17830,
      "width": 312,
      "height": 188,
      "text": "Sector: Area = (θ/360) × πr²\nArc = (θ/360) × 2πr\nArea = (1/2) × arc × r\n\nPath around rectangle (width w):\n  Outer: 2w(L + B + 2w)\n  Inner: 2w(L + B - 2w)\n\nWHY: Sector is θ/360 fraction of the\n  full circle, so area = fraction × πr².\n\nEx: θ=90, r=14 → Area=1/4×π×196=154",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 46300,
      "version": 1,
      "versionNonce": 463,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_26_4"
      ],
      "containerId": null,
      "originalText": "Sector: Area = (θ/360) × πr²\nArc = (θ/360) × 2πr\nArea = (1/2) × arc × r\n\nPath around rectangle (width w):\n  Outer: 2w(L + B + 2w)\n  Inner: 2w(L + B - 2w)\n\nWHY: Sector is θ/360 fraction of the\n  full circle, so area = fraction × πr².\n\nEx: θ=90, r=14 → Area=1/4×π×196=154",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
