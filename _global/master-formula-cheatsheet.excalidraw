      "containerId": null,
      "originalText": "Mirror Image of Clock",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_445",
      "type": "text",
      "x": 1022,
      "y": 17175,
      "width": 359,
      "height": 219,
      "text": "Mirror time = 11:60 - Actual time\n\nIf actual = H:M\n  Mirror = (11-H):(60-M)\n\nSpecial: 12:00 and 6:00 look same in mirror\n\nEx: 3:20 -> 8:40   7:45 -> 4:15\n\nWHY: Mirror flips left-right. 12 stays at top.\nHands swap symmetrically about 12-6 axis.\nSubtract from 12:00 (=11:60) to get mirror.\n\nEx: 2:15 → (11-2):(60-15) = 9:45",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 44500,
      "version": 1,
      "versionNonce": 445,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_25_5"
      ],
      "containerId": null,
      "originalText": "Mirror time = 11:60 - Actual time\n\nIf actual = H:M\n  Mirror = (11-H):(60-M)\n\nSpecial: 12:00 and 6:00 look same in mirror\n\nEx: 3:20 -> 8:40   7:45 -> 4:15\n\nWHY: Mirror flips left-right. 12 stays at top.\nHands swap symmetrically about 12-6 axis.\nSubtract from 12:00 (=11:60) to get mirror.\n\nEx: 2:15 → (11-2):(60-15) = 9:45",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
