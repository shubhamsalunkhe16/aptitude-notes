      "roundness": null
    },
    {
      "id": "el_526",
      "type": "text",
      "x": 542,
      "y": 20164,
      "width": 406,
      "height": 125,
      "text": "A=26  B=25  C=24  D=23  E=22  F=21  G=20  H=19  I=18\nJ=17  K=16  L=15  M=14  N=13  O=12  P=11  Q=10  R=9\nS=8   T=7   U=6   V=5   W=4   X=3   Y=2   Z=1\n\nWHY: 26 letters total. Reverse pos = 27-Fwd.\n  A is 1st from front = 26th from back.\n\nEx: G = 7 forward → 27-7 = 20 reverse",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 52600,
      "version": 1,
      "versionNonce": 526,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_30_1"
      ],
      "containerId": null,
      "originalText": "A=26  B=25  C=24  D=23  E=22  F=21  G=20  H=19  I=18\nJ=17  K=16  L=15  M=14  N=13  O=12  P=11  Q=10  R=9\nS=8   T=7   U=6   V=5   W=4   X=3   Y=2   Z=1\n\nWHY: 26 letters total. Reverse pos = 27-Fwd.\n  A is 1st from front = 26th from back.\n\nEx: G = 7 forward → 27-7 = 20 reverse",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
