    {
      "id": "el_475",
      "type": "text",
      "x": 542,
      "y": 18183,
      "width": 320,
      "height": 203,
      "text": "Angle │ sin    │ cos    │ tan\n──────┼────────┼────────┼────────\n 30°  │ 1/2    │ √3/2   │ 1/√3\n 45°  │ 1/√2   │ 1/√2   │ 1\n 60°  │ √3/2   │ 1/2    │ √3\n\n√3 ≈ 1.732   1/√3 ≈ 0.577\n√2 ≈ 1.414   1/√2 ≈ 0.707\n\nWHY: Derived from 30-60-90 (sides 1:√3:2)\n  and 45-45-90 (sides 1:1:√2) triangles.\n\nEx: sin30°=1/2 because opp=1, hyp=2",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 47500,
      "version": 1,
      "versionNonce": 475,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_27_1"
      ],
      "containerId": null,
      "originalText": "Angle │ sin    │ cos    │ tan\n──────┼────────┼────────┼────────\n 30°  │ 1/2    │ √3/2   │ 1/√3\n 45°  │ 1/√2   │ 1/√2   │ 1\n 60°  │ √3/2   │ 1/2    │ √3\n\n√3 ≈ 1.732   1/√3 ≈ 0.577\n√2 ≈ 1.414   1/√2 ≈ 0.707\n\nWHY: Derived from 30-60-90 (sides 1:√3:2)\n  and 45-45-90 (sides 1:1:√2) triangles.\n\nEx: sin30°=1/2 because opp=1, hyp=2",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
