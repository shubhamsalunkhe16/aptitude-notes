    {
      "id": "el_234",
      "type": "text",
      "x": 1022,
      "y": 8971,
      "width": 278,
      "height": 18,
      "text": "Chain Rule (Mixed)",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 23400,
      "version": 1,
      "versionNonce": 234,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_13_2"
      ],
      "containerId": null,
      "originalText": "Chain Rule (Mixed)",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_235",
      "type": "text",
      "x": 1022,
      "y": 8993,
      "width": 328,
      "height": 188,
      "text": "Step 1: Identify each variable\nStep 2: Mark Direct (D) or Inverse (I)\nStep 3: Set up proportion chain\n  Direct → same order ratio\n  Inverse → flipped ratio\nStep 4: Multiply all ratios = answer ratio\n\nWHY: Each variable contributes its own\nratio. Multiply them all to combine.\n\nEx: 8 men, 6 hrs → 6 men, 8 hrs\n  ? = 12 × (8/6) × (6/8) = 12 days",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 23500,
      "version": 1,
      "versionNonce": 235,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_13_2"
      ],
      "containerId": null,
      "originalText": "Step 1: Identify each variable\nStep 2: Mark Direct (D) or Inverse (I)\nStep 3: Set up proportion chain\n  Direct → same order ratio\n  Inverse → flipped ratio\nStep 4: Multiply all ratios = answer ratio\n\nWHY: Each variable contributes its own\nratio. Multiply them all to combine.\n\nEx: 8 men, 6 hrs → 6 men, 8 hrs\n  ? = 12 × (8/6) × (6/8) = 12 days",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_236",
      "type": "rectangle",
      "x": 50,
      "y": 9234,
