    {
      "id": "el_492",
      "type": "text",
      "x": 62,
      "y": 18816,
      "width": 201,
      "height": 18,
      "text": "Cube & Cuboid",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 49200,
      "version": 1,
      "versionNonce": 492,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_28_0"
      ],
      "containerId": null,
      "originalText": "Cube & Cuboid",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_493",
      "type": "text",
      "x": 62,
      "y": 18838,
      "width": 359,
      "height": 234,
      "text": "CUBE (side a):\n  Volume = a^3\n  TSA = 6a^2,  LSA = 4a^2\n  Diagonal = a*sqrt(3)\n\nCUBOID (l x b x h):\n  Volume = l*b*h\n  TSA = 2(lb + bh + hl)\n  LSA = 2h(l + b)\n  Diagonal = sqrt(l^2 + b^2 + h^2)\n\nWHY: Cube has 6 identical faces (6a^2),\n  4 lateral + 2 top/bottom. V = area x height.\n\nEx: a=5 → V=125, TSA=150, Diag=5√3",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 49300,
      "version": 1,
      "versionNonce": 493,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_28_0"
      ],
      "containerId": null,
      "originalText": "CUBE (side a):\n  Volume = a^3\n  TSA = 6a^2,  LSA = 4a^2\n  Diagonal = a*sqrt(3)\n\nCUBOID (l x b x h):\n  Volume = l*b*h\n  TSA = 2(lb + bh + hl)\n  LSA = 2h(l + b)\n  Diagonal = sqrt(l^2 + b^2 + h^2)\n\nWHY: Cube has 6 identical faces (6a^2),\n  4 lateral + 2 top/bottom. V = area x height.\n\nEx: a=5 → V=125, TSA=150, Diag=5√3",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
