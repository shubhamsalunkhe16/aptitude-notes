    {
      "id": "el_9",
      "type": "text",
      "x": 542,
      "y": 144,
      "width": 355,
      "height": 18,
      "text": "Operations on Fractions",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#2f9e44",
