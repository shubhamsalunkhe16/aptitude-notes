      "roundness": null
    },
    {
      "id": "el_154",
      "type": "text",
      "x": 62,
      "y": 5942,
      "width": 289,
      "height": 234,
      "text": "Speed change → inverse time ratio\nS1:S2 = a:b → T1:T2 = b:a\n\nEqual trains cross pole T1,T2:\n  Opp: 2×T1×T2/(T1+T2)\n  Same: 2×T1×T2/(T1-T2)\n\nLate/Early → D=S1×S2×ΔT/(S2-S1)\n\nWHY (equal trains): L=S1×T1=S2×T2,\n  D=2L. Opp: T=2L/(S1+S2). Substitute\n  S=L/T to get harmonic mean formula.\n\nEx: T1=20s, T2=30s → Opp=\n  2×20×30/50 = 24s",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 15400,
      "version": 1,
      "versionNonce": 154,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_8_3"
      ],
      "containerId": null,
      "originalText": "Speed change → inverse time ratio\nS1:S2 = a:b → T1:T2 = b:a\n\nEqual trains cross pole T1,T2:\n  Opp: 2×T1×T2/(T1+T2)\n  Same: 2×T1×T2/(T1-T2)\n\nLate/Early → D=S1×S2×ΔT/(S2-S1)\n\nWHY (equal trains): L=S1×T1=S2×T2,\n  D=2L. Opp: T=2L/(S1+S2). Substitute\n  S=L/T to get harmonic mean formula.\n\nEx: T1=20s, T2=30s → Opp=\n  2×20×30/50 = 24s",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
