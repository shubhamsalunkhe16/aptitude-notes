    {
      "id": "el_384",
      "type": "text",
      "x": 1022,
      "y": 15056,
      "width": 424,
      "height": 14,
      "text": "Combination (Order does NOT matter)",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 11,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 38400,
      "version": 1,
      "versionNonce": 384,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_22_2"
      ],
      "containerId": null,
      "originalText": "Combination (Order does NOT matter)",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_385",
      "type": "text",
      "x": 1022,
      "y": 15078,
      "width": 305,
      "height": 156,
      "text": "nCr = n! / [r!(n-r)!]\nnCr = nC(n-r)   nC0 = nCn = 1\nnCr = nPr / r!\nHandshakes = nC2 = n(n-1)/2\nDiagonals = n(n-3)/2\n\nWHY: nCr = nPr / r! because we remove\n  r! duplicate orderings of same group.\n\nEx: 7C3 = (7×6×5)/(3×2×1) = 210/6 = 35",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 38500,
      "version": 1,
      "versionNonce": 385,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_22_2"
      ],
      "containerId": null,
      "originalText": "nCr = n! / [r!(n-r)!]\nnCr = nC(n-r)   nC0 = nCn = 1\nnCr = nPr / r!\nHandshakes = nC2 = n(n-1)/2\nDiagonals = n(n-3)/2\n\nWHY: nCr = nPr / r! because we remove\n  r! duplicate orderings of same group.\n\nEx: 7C3 = (7×6×5)/(3×2×1) = 210/6 = 35",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
