    },
    {
      "id": "el_10",
      "type": "text",
      "x": 542,
      "y": 166,
      "width": 359,
      "height": 281,
      "text": "Addition/Subtraction: Take LCM of denominators\n  a/b + c/d = (ad + bc) / bd\n  a/b - c/d = (ad - bc) / bd\n\nMultiplication: num × num / den × den\n  a/b × c/d = ac / bd\n\nDivision: Multiply by reciprocal\n  a/b ÷ c/d = a/b × d/c = ad / bc\n\nComparing: a/b vs c/d → cross multiply\n  If ad > bc then a/b > c/d\n\nWHY: Division by c/d = how many c/d fit in a/b\n  = a/b × d/c (flip the divisor and multiply)\n\nEx: 3/4 ÷ 2/5 = 3/4 × 5/2 = 15/8\n  Cross-check: 3/4 vs 2/5 → 15>8 → 3/4 > 2/5 ✓",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1000,
      "version": 1,
      "versionNonce": 10,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_0_1"
      ],
      "containerId": null,
      "originalText": "Addition/Subtraction: Take LCM of denominators\n  a/b + c/d = (ad + bc) / bd\n  a/b - c/d = (ad - bc) / bd\n\nMultiplication: num × num / den × den\n  a/b × c/d = ac / bd\n\nDivision: Multiply by reciprocal\n  a/b ÷ c/d = a/b × d/c = ad / bc\n\nComparing: a/b vs c/d → cross multiply\n  If ad > bc then a/b > c/d\n\nWHY: Division by c/d = how many c/d fit in a/b\n  = a/b × d/c (flip the divisor and multiply)\n\nEx: 3/4 ÷ 2/5 = 3/4 × 5/2 = 15/8\n  Cross-check: 3/4 vs 2/5 → 15>8 → 3/4 > 2/5 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
