      ],
      "containerId": null,
      "originalText": "Avg = Sum / n\nSum = Avg × n\n\nAvg of 1 to n = (n+1)/2\nAvg of first n even = (n+1)\nAvg of first n odd = n\n\nWeighted Avg = Σwᵢxᵢ / Σwᵢ",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
