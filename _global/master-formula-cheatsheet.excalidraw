    {
      "id": "el_561",
      "type": "text",
      "x": 1022,
      "y": 21328,
      "width": 432,
      "height": 18,
      "text": "Selection & Constraint Rules",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 56100,
      "version": 1,
      "versionNonce": 561,
      "isDeleted": false,
      "boundElements": null,
