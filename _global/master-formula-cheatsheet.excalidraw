    {
      "id": "el_555",
      "type": "text",
      "x": 62,
      "y": 21328,
      "width": 432,
      "height": 18,
      "text": "Core Logical Reasoning Rules",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
