    {
      "id": "el_306",
      "type": "text",
      "x": 62,
      "y": 11833,
      "width": 247,
      "height": 18,
      "text": "Overtime Formula",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 30600,
      "version": 1,
      "versionNonce": 306,
      "isDeleted": false,
