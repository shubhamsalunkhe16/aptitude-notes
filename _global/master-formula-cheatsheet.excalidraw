    {
      "id": "el_43",
      "type": "text",
      "x": 1022,
      "y": 1725,
      "width": 414,
      "height": 203,
      "text": "1=1     2=8     3=27    4=64    5=125\n6=216   7=343   8=512   9=729   10=1000\n11=1331  12=1728  13=2197  14=2744  15=3375\n\nCube unit digit: 1->1 2->8 3->7 4->4 5->5\n  6->6 7->3 8->2 9->9 0->0 (2<->8, 3<->7 swap)\n\nWHY: Cube unit digits follow from (d^3 mod 10)\n  2 and 8 swap, 3 and 7 swap, rest stay same\n\nEx: Cube root of 4913 → unit digit 3→answer ends in 7\n  Remove last 3 digits: 4→nearest cube 1^3=1, tens=1\n  Answer=17. 17^3=4913 ✓",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4300,
      "version": 1,
      "versionNonce": 43,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_2_2"
      ],
      "containerId": null,
      "originalText": "1=1     2=8     3=27    4=64    5=125\n6=216   7=343   8=512   9=729   10=1000\n11=1331  12=1728  13=2197  14=2744  15=3375\n\nCube unit digit: 1->1 2->8 3->7 4->4 5->5\n  6->6 7->3 8->2 9->9 0->0 (2<->8, 3<->7 swap)\n\nWHY: Cube unit digits follow from (d^3 mod 10)\n  2 and 8 swap, 3 and 7 swap, rest stay same\n\nEx: Cube root of 4913 → unit digit 3→answer ends in 7\n  Remove last 3 digits: 4→nearest cube 1^3=1, tens=1\n  Answer=17. 17^3=4913 ✓",
      "autoResize": true,
