    {
      "id": "el_228",
      "type": "text",
      "x": 62,
      "y": 8971,
      "width": 262,
      "height": 18,
      "text": "Direct Proportion",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
