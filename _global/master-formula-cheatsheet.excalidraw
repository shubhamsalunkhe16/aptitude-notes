    },
    {
      "id": "el_562",
      "type": "text",
      "x": 1022,
      "y": 21350,
      "width": 406,
      "height": 234,
      "text": "\"At least one of A,B\" → A or B or both\n\"At most one of A,B\" → not both; 0 or 1\n\"Exactly one of A,B\" → XOR (one in, one out)\n\"If A then B\" → A selected → B must be selected\n\"A and B not together\" → pick A → drop B\n\"A only if B\" → A → B (A requires B)\n\nTRICK: Convert all rules to IF-THEN + contrapositive\n\nWHY: IF-THEN chains let you derive forced picks\n  and eliminations. Contrapositive doubles each\n  rule's power (~B → ~A).\n\nEx: If A→B and B→C: pick A → must pick B,C\n  Contrapositive: drop C → must drop B,A",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 56200,
      "version": 1,
      "versionNonce": 562,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_32_2"
      ],
      "containerId": null,
      "originalText": "\"At least one of A,B\" → A or B or both\n\"At most one of A,B\" → not both; 0 or 1\n\"Exactly one of A,B\" → XOR (one in, one out)\n\"If A then B\" → A selected → B must be selected\n\"A and B not together\" → pick A → drop B\n\"A only if B\" → A → B (A requires B)\n\nTRICK: Convert all rules to IF-THEN + contrapositive\n\nWHY: IF-THEN chains let you derive forced picks\n  and eliminations. Contrapositive doubles each\n  rule's power (~B → ~A).\n\nEx: If A→B and B→C: pick A → must pick B,C\n  Contrapositive: drop C → must drop B,A",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_563",
