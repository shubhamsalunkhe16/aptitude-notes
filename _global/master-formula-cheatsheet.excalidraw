    {
      "id": "el_462",
      "type": "text",
      "x": 542,
      "y": 17808,
      "width": 278,
      "height": 18,
      "text": "Sector, Arc & Path",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
