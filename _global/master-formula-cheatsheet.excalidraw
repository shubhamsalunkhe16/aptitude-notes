    {
      "id": "el_423",
      "type": "text",
      "x": 62,
      "y": 16498,
      "width": 324,
      "height": 18,
      "text": "Calendar Repeat Rules",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 42300,
