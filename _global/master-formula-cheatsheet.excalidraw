      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_532",
      "type": "text",
      "x": 62,
      "y": 20373,
      "width": 359,
      "height": 172,
      "text": "+1 shift: A->B, B->C, ... Z->A (Caesar cipher)\n+2 shift: A->C, B->D, ... Y->A, Z->B\n-1 shift: A->Z, B->A, C->B, ... Z->Y\n\nWHY: Like a rotating wheel of 26 letters.\n  Shift N = move N steps forward on wheel.\n\nEx: +3 shift on W(23): (23+3-1)%26+1 = 26 = Z\n\nFormula: New = (Old + N - 1) mod 26 + 1\nWrap: After Z comes A; Before A comes Z",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 53200,
      "version": 1,
      "versionNonce": 532,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_30_3"
      ],
      "containerId": null,
      "originalText": "+1 shift: A->B, B->C, ... Z->A (Caesar cipher)\n+2 shift: A->C, B->D, ... Y->A, Z->B\n-1 shift: A->Z, B->A, C->B, ... Z->Y\n\nWHY: Like a rotating wheel of 26 letters.\n  Shift N = move N steps forward on wheel.\n\nEx: +3 shift on W(23): (23+3-1)%26+1 = 26 = Z\n\nFormula: New = (Old + N - 1) mod 26 + 1\nWrap: After Z comes A; Before A comes Z",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
