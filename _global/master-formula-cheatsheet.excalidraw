    {
      "id": "el_237",
      "type": "text",
      "x": 62,
      "y": 9242,
      "width": 339,
      "height": 18,
      "text": "Man-Days-Hours Formula",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 23700,
      "version": 1,
      "versionNonce": 237,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_13_3"
      ],
      "containerId": null,
      "originalText": "Man-Days-Hours Formula",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_238",
      "type": "text",
      "x": 62,
      "y": 9264,
      "width": 336,
      "height": 219,
      "text": "M₁ × D₁ × H₁ = M₂ × D₂ × H₂\n(when work is same)\n\nM₁×D₁×H₁/W₁ = M₂×D₂×H₂/W₂\n(when work differs)\n\nTotal work = Men × Days × Hours\n\nWHY: Work is the product of all effort\nvariables. Equal work means equal products.\n\nEx: 10 men × 8 hrs × 5 days = 400\n  ? men × 10 hrs × 4 days = 400\n  ? = 400/40 = 10 men",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 23800,
      "version": 1,
      "versionNonce": 238,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_13_3"
      ],
      "containerId": null,
      "originalText": "M₁ × D₁ × H₁ = M₂ × D₂ × H₂\n(when work is same)\n\nM₁×D₁×H₁/W₁ = M₂×D₂×H₂/W₂\n(when work differs)\n\nTotal work = Men × Days × Hours\n\nWHY: Work is the product of all effort\nvariables. Equal work means equal products.\n\nEx: 10 men × 8 hrs × 5 days = 400\n  ? men × 10 hrs × 4 days = 400\n  ? = 400/40 = 10 men",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
