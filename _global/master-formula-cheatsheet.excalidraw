    {
      "id": "el_471",
      "type": "text",
      "x": 62,
      "y": 18161,
      "width": 309,
      "height": 18,
      "text": "Trigonometric Ratios",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 47100,
      "version": 1,
      "versionNonce": 471,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_27_0"
      ],
      "containerId": null,
      "originalText": "Trigonometric Ratios",
      "autoResize": true,
