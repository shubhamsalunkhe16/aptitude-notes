    {
      "id": "el_540",
      "type": "text",
      "x": 62,
      "y": 20657,
      "width": 278,
      "height": 18,
      "text": "Compass Directions",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#2f9e44",
