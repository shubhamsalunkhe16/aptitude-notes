    },
    {
      "id": "el_541",
      "type": "text",
      "x": 62,
      "y": 20679,
      "width": 414,
      "height": 188,
      "text": "8 Directions:\n  NW   N   NE        Cardinal: N, S, E, W (90° apart)\n    \\  |  /         Ordinal:  NE, NW, SE, SW (45°)\n  W --+-- E\n    /  |  \\         N=0°  E=90°  S=180°  W=270°\n  SW   S   SE       NE=45° SE=135° SW=225° NW=315°\n\nWHY: Full circle = 360°. 4 cardinals split it\n  into 90° sectors; ordinals bisect each at 45°.\n\nEx: Angle from N to SE = 135° (clockwise)\n  Opposite of NE = SW (flip both letters)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 54100,
      "version": 1,
      "versionNonce": 541,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_31_0"
      ],
      "containerId": null,
      "originalText": "8 Directions:\n  NW   N   NE        Cardinal: N, S, E, W (90° apart)\n    \\  |  /         Ordinal:  NE, NW, SE, SW (45°)\n  W --+-- E\n    /  |  \\         N=0°  E=90°  S=180°  W=270°\n  SW   S   SE       NE=45° SE=135° SW=225° NW=315°\n\nWHY: Full circle = 360°. 4 cardinals split it\n  into 90° sectors; ordinals bisect each at 45°.\n\nEx: Angle from N to SE = 135° (clockwise)\n  Opposite of NE = SW (flip both letters)",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_542",
