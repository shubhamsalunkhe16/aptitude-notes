      ],
      "containerId": null,
      "originalText": "       D\n      / \\\n     /   \\\n    S  ×  T\n\nCover D → S × T\nCover S → D / T\nCover T → D / S\n\nkm/h → m/s : × 5/18\nm/s → km/h : × 18/5\n\nWHY: 1 km=1000m, 1 hr=3600s\n  1 km/h = 1000/3600 = 5/18 m/s\n\nEx: 72 km/h = 72×5/18 = 20 m/s",
      "autoResize": true,
