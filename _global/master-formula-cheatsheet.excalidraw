    {
      "id": "el_516",
      "type": "text",
      "x": 62,
      "y": 19789,
      "width": 355,
      "height": 18,
      "text": "'Only' Keyword Patterns",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
