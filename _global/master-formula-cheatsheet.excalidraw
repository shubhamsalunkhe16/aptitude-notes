        "f_17_3"
      ],
      "containerId": null,
      "originalText": "Overtime Formula",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_307",
      "type": "text",
      "x": 62,
      "y": 11855,
      "width": 312,
      "height": 219,
      "text": "Overtime rate = Normal rate × multiplier\nCommon: 1.5× or 2× normal rate\n\nTotal pay = (Normal hrs × Normal rate)\n          + (OT hrs × OT rate)\n\nIf daily wage given:\n  Hourly rate = Daily wage / Normal hrs\n\nWHY: Overtime compensates extra effort\nbeyond normal hours at a premium rate.\n\nEx: Rs.480/8hrs → Rs.60/hr normal\n  OT rate = 1.5×60 = Rs.90/hr",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 30700,
      "version": 1,
      "versionNonce": 307,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_17_3"
      ],
      "containerId": null,
      "originalText": "Overtime rate = Normal rate × multiplier\nCommon: 1.5× or 2× normal rate\n\nTotal pay = (Normal hrs × Normal rate)\n          + (OT hrs × OT rate)\n\nIf daily wage given:\n  Hourly rate = Daily wage / Normal hrs\n\nWHY: Overtime compensates extra effort\nbeyond normal hours at a premium rate.\n\nEx: Rs.480/8hrs → Rs.60/hr normal\n  OT rate = 1.5×60 = Rs.90/hr",
      "autoResize": true,
