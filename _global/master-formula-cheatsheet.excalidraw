      "groupIds": [
        "f_30_2"
      ],
      "containerId": null,
      "originalText": "Mirror/Opposite Letter Pairs",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_529",
      "type": "text",
      "x": 1022,
      "y": 20164,
      "width": 312,
      "height": 141,
      "text": "A<->Z   B<->Y   C<->X   D<->W   E<->V\nF<->U   G<->T   H<->S   I<->R   J<->Q\nK<->P   L<->O   M<->N\n\nWHY: Mirror at center of alphabet.\n  Pair sums to 27: pos(A)+pos(Z)=1+26=27\n\nEx: Mirror of H? H=8, pair=27-8=19=S\n  So H <-> S",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 52900,
      "version": 1,
      "versionNonce": 529,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_30_2"
      ],
      "containerId": null,
      "originalText": "A<->Z   B<->Y   C<->X   D<->W   E<->V\nF<->U   G<->T   H<->S   I<->R   J<->Q\nK<->P   L<->O   M<->N\n\nWHY: Mirror at center of alphabet.\n  Pair sums to 27: pos(A)+pos(Z)=1+26=27\n\nEx: Mirror of H? H=8, pair=27-8=19=S\n  So H <-> S",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
