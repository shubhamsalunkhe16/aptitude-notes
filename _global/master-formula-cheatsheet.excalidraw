    {
      "id": "el_441",
      "type": "text",
      "x": 542,
      "y": 17153,
      "width": 339,
      "height": 18,
      "text": "Gaining / Losing Clock",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
