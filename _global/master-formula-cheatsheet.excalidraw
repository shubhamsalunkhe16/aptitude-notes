    },
    {
      "id": "el_379",
      "type": "text",
      "x": 62,
      "y": 15078,
      "width": 351,
      "height": 172,
      "text": "n! = n × (n-1) × ... × 1\n0! = 1,  1! = 1\n2!=2  3!=6  4!=24  5!=120  6!=720  7!=5040\n\nn!/k! = multiply top k terms\n10!/8! = 10×9 = 90\n\nWHY: n! counts all ways to arrange n items.\n  Each slot has one fewer choice: n,n-1,...,1\n\nEx: 5! = 5×4×3×2×1 = 120",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 37900,
      "version": 1,
      "versionNonce": 379,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_22_0"
      ],
      "containerId": null,
      "originalText": "n! = n × (n-1) × ... × 1\n0! = 1,  1! = 1\n2!=2  3!=6  4!=24  5!=120  6!=720  7!=5040\n\nn!/k! = multiply top k terms\n10!/8! = 10×9 = 90\n\nWHY: n! counts all ways to arrange n items.\n  Each slot has one fewer choice: n,n-1,...,1\n\nEx: 5! = 5×4×3×2×1 = 120",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_380",
      "type": "rectangle",
      "x": 530,
      "y": 15048,
      "width": 460,
      "height": 220,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#ebfbee",
