    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 372,
      "width": 242,
      "height": 110,
      "text": "Profit = SP - CP\nLoss = CP - SP\nP% = (Profit/CP) × 100\nSP = CP × (100+P%) / 100\n\nDiscount% = (Discount/MP) × 100\nSP = MP × (100-D%) / 100",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
