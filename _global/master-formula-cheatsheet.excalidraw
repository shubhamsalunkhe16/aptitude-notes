    {
      "id": "el_582",
      "type": "text",
      "x": 62,
      "y": 22348,
      "width": 247,
      "height": 18,
      "text": "Games & Circular",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 58200,
      "version": 1,
      "versionNonce": 582,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_33_3"
      ],
      "containerId": null,
      "originalText": "Games & Circular",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_583",
      "type": "text",
      "x": 62,
      "y": 22370,
      "width": 359,
      "height": 250,
      "text": "GAMES: Points = Distance\n  A gives B 20 pts in 100 → 100:80\n  Same formulas as races!\n\nCIRCULAR TRACK:\n  Same dir: Meet = Track/(S1-S2)\n  Opp dir: Meet = Track/(S1+S2)\n\nWHY: Same dir → faster gains 1 lap on slower.\n  Relative speed = S1-S2; time = Track/(S1-S2)\n\nEx: 400m track, 5 m/s & 3 m/s same dir\n  Meet = 400/(5-3) = 200s\n\n\"Beats by X m OR T sec\":\n  Sb = X/T (remaining dist ÷ extra time)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 58300,
      "version": 1,
      "versionNonce": 583,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_33_3"
      ],
      "containerId": null,
      "originalText": "GAMES: Points = Distance\n  A gives B 20 pts in 100 → 100:80\n  Same formulas as races!\n\nCIRCULAR TRACK:\n  Same dir: Meet = Track/(S1-S2)\n  Opp dir: Meet = Track/(S1+S2)\n\nWHY: Same dir → faster gains 1 lap on slower.\n  Relative speed = S1-S2; time = Track/(S1-S2)\n\nEx: 400m track, 5 m/s & 3 m/s same dir\n  Meet = 400/(5-3) = 200s\n\n\"Beats by X m OR T sec\":\n  Sb = X/T (remaining dist ÷ extra time)",
      "autoResize": true,
