      "roundness": null
    },
    {
      "id": "el_439",
      "type": "text",
      "x": 62,
      "y": 17175,
      "width": 359,
      "height": 203,
      "text": "             12 hrs | 24 hrs\nOverlap(0):    11   |   22   (NOT 12/24!)\nRight(90):     22   |   44\nStraight(180): 11   |   22   (NOT 12/24!)\nAny theta:     22   |   44\n\nTime between overlaps = 12/11 hr = 65min 27sec\n\nWHY: Minute hand laps hour hand 11 times in\n12 hrs (not 12, because they start together\nat 12:00 and meet again at next 12:00).\n\nEx: Overlaps at ~12:00, 1:05, 2:10... 10:54",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 43900,
      "version": 1,
      "versionNonce": 439,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_25_3"
      ],
      "containerId": null,
      "originalText": "             12 hrs | 24 hrs\nOverlap(0):    11   |   22   (NOT 12/24!)\nRight(90):     22   |   44\nStraight(180): 11   |   22   (NOT 12/24!)\nAny theta:     22   |   44\n\nTime between overlaps = 12/11 hr = 65min 27sec\n\nWHY: Minute hand laps hour hand 11 times in\n12 hrs (not 12, because they start together\nat 12:00 and meet again at next 12:00).\n\nEx: Overlaps at ~12:00, 1:05, 2:10... 10:54",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
