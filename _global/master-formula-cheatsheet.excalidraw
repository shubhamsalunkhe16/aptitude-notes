    {
      "id": "el_63",
      "type": "text",
      "x": 1022,
      "y": 2342,
      "width": 278,
      "height": 18,
      "text": "Divisibility Rules",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6300,
      "version": 1,
      "versionNonce": 63,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_3_2"
      ],
      "containerId": null,
      "originalText": "Divisibility Rules",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_64",
      "type": "text",
      "x": 1022,
      "y": 2364,
      "width": 383,
      "height": 203,
      "text": "By 2 → last digit even\nBy 3 → digit sum ÷ 3\nBy 4 → last 2 digits ÷ 4\nBy 5 → last digit 0 or 5\nBy 6 → div by 2 AND 3\nBy 8 → last 3 digits ÷ 8\nBy 9 → digit sum ÷ 9\nBy 11 → |odd-place sum - even-place sum| ÷ 11\n\nWHY: 10≡1(mod 3,9) so N≡digit sum(mod 3,9)\n  100≡1(mod 11 alternates ±1) → odd-even diff\n\nEx: 462 → 4+6+2=12 div by 3✓ |4+2-6|=0 div by 11✓",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6400,
      "version": 1,
      "versionNonce": 64,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_3_2"
      ],
      "containerId": null,
      "originalText": "By 2 → last digit even\nBy 3 → digit sum ÷ 3\nBy 4 → last 2 digits ÷ 4\nBy 5 → last digit 0 or 5\nBy 6 → div by 2 AND 3\nBy 8 → last 3 digits ÷ 8\nBy 9 → digit sum ÷ 9\nBy 11 → |odd-place sum - even-place sum| ÷ 11\n\nWHY: 10≡1(mod 3,9) so N≡digit sum(mod 3,9)\n  100≡1(mod 11 alternates ±1) → odd-even diff\n\nEx: 462 → 4+6+2=12 div by 3✓ |4+2-6|=0 div by 11✓",
      "autoResize": true,
