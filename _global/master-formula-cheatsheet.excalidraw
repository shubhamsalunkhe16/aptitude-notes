    {
      "id": "el_153",
      "type": "text",
      "x": 62,
      "y": 5920,
      "width": 262,
      "height": 18,
      "text": "Shortcut Formulas",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 15300,
      "version": 1,
      "versionNonce": 153,
      "isDeleted": false,
