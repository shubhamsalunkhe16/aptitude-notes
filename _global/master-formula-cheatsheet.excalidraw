      "roundness": null
    },
    {
      "id": "el_268",
      "type": "text",
      "x": 62,
      "y": 10513,
      "width": 312,
      "height": 219,
      "text": "Two discounts a% and b%:\n  Single = a + b - (a×b)/100 %\n  (minus, NOT plus!)\n\nL ↑ a%, B ↑ b% → Area change:\n  = a + b + (a×b)/100 %\n  (same as successive change!)\n  Use -ve for decrease\n\nWHY: Discount is successive subtraction,\nso cross-term is subtracted.\n\nEx: Discounts 20% and 10%:\n  Single = 20+10-(20×10)/100 = 28%",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 26800,
      "version": 1,
      "versionNonce": 268,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f_15_3"
      ],
      "containerId": null,
      "originalText": "Two discounts a% and b%:\n  Single = a + b - (a×b)/100 %\n  (minus, NOT plus!)\n\nL ↑ a%, B ↑ b% → Area change:\n  = a + b + (a×b)/100 %\n  (same as successive change!)\n  Use -ve for decrease\n\nWHY: Discount is successive subtraction,\nso cross-term is subtracted.\n\nEx: Discounts 20% and 10%:\n  Single = 20+10-(20×10)/100 = 28%",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
