    {
      "id": "el_252",
      "type": "text",
      "x": 62,
      "y": 9851,
      "width": 370,
      "height": 18,
      "text": "Capital Changes Mid-Year",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
