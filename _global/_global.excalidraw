    {
      "id": "el_95",
      "type": "text",
      "x": 65,
      "y": 2722,
      "width": 406,
      "height": 203,
      "text": "Draw family tree: + Male, - Female, === Marriage\nSimplify chains right-to-left:\n  Mother's husband = Father\n  Brother's son = Nephew | Sister's daughter = Niece\n  Son's wife = Daughter-in-law\n\nGeneration levels: +2=Grand, +1=Parent, 0=Self,\n-1=Child\n\n\"Only son of my mother\" = myself (male)\n\"Only daughter of my father\" = myself (female)\nhe/him/father/son = Male | she/her/mother/daughter =\nFemale",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 9500,
      "version": 1,
      "versionNonce": 95,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f30"
      ],
      "containerId": null,
      "originalText": "Draw family tree: + Male, - Female, === Marriage\nSimplify chains right-to-left:\n  Mother's husband = Father\n  Brother's son = Nephew | Sister's daughter = Niece\n  Son's wife = Daughter-in-law\n\nGeneration levels: +2=Grand, +1=Parent, 0=Self,\n-1=Child\n\n\"Only son of my mother\" = myself (male)\n\"Only daughter of my father\" = myself (female)\nhe/him/father/son = Male | she/her/mother/daughter =\nFemale",
      "autoResize": true,
