      "roundness": null
    },
    {
      "id": "el_38",
      "type": "text",
      "x": 1005,
      "y": 945,
      "width": 367,
      "height": 172,
      "text": "a:b = c:d -> ad = bc (extremes = means product)\nMean Proportional = sqrt(a x c)\nThird Proportional = b^2/a\nFourth Proportional = b.c/a\n\nDivide T in a:b:c -> A's share = a/(a+b+c) x T\nFrac ratios 1/2:1/3:1/4 -> LCM dens -> 6:4:3\n\nCombine: A:B=p:q, B:C=r:s -> LCM(q,r) to merge\nDuplicate ratio = a^2:b^2 | Inverse = b:a\nDirect: A up->B up | Inverse: A up->B down",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3800,
      "version": 1,
      "versionNonce": 38,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f11"
      ],
      "containerId": null,
      "originalText": "a:b = c:d -> ad = bc (extremes = means product)\nMean Proportional = sqrt(a x c)\nThird Proportional = b^2/a\nFourth Proportional = b.c/a\n\nDivide T in a:b:c -> A's share = a/(a+b+c) x T\nFrac ratios 1/2:1/3:1/4 -> LCM dens -> 6:4:3\n\nCombine: A:B=p:q, B:C=r:s -> LCM(q,r) to merge\nDuplicate ratio = a^2:b^2 | Inverse = b:a\nDirect: A up->B up | Inverse: A up->B down",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
