    {
      "id": "el_55",
      "type": "text",
      "x": 1005,
      "y": 1430,
      "width": 150,
      "height": 22,
      "text": "Discount",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 17,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
