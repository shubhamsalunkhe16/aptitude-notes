    },
    {
      "id": "el_53",
      "type": "text",
      "x": 535,
      "y": 1455,
      "width": 414,
      "height": 156,
      "text": "P% = (SP-CP)/CP x 100 | SP = CP x (100+P%)/100\nCP = SP x 100/(100+P%) | L%: use (100-L%)\n\nMP -> Disc -> SP -> compare with CP for P/L%\nMarkup m%, Disc d%: Net P% = (100+m)(100-d)/100 - 100\n\nDishonest dealer: Gain% = (True-False)/False x 100\nCP of X = SP of Y: P% = (X-Y)/Y x 100\nBuy X Get Y Free: D% = Y/(X+Y) x 100\nSame SP, same P%=L%: Always LOSS = P^2/100 %",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5300,
      "version": 1,
      "versionNonce": 53,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f16"
      ],
      "containerId": null,
      "originalText": "P% = (SP-CP)/CP x 100 | SP = CP x (100+P%)/100\nCP = SP x 100/(100+P%) | L%: use (100-L%)\n\nMP -> Disc -> SP -> compare with CP for P/L%\nMarkup m%, Disc d%: Net P% = (100+m)(100-d)/100 - 100\n\nDishonest dealer: Gain% = (True-False)/False x 100\nCP of X = SP of Y: P% = (X-Y)/Y x 100\nBuy X Get Y Free: D% = Y/(X+Y) x 100\nSame SP, same P%=L%: Always LOSS = P^2/100 %",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_54",
