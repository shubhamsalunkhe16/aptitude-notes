    {
      "id": "el_86",
      "type": "text",
      "x": 65,
      "y": 2475,
      "width": 351,
      "height": 156,
      "text": "A beats B by Xm in Dm race: Sa:Sb = D:(D-X)\nA beats B by Xm OR Ts: Sb = X/T\nHead start Xm for dead heat: D/(D-X) = Sa/Sb\n\nTransitive: A beats B by X, B beats C by Y\n  A beats C = X + Y - XY/D\n\nCircular track: same dir meet = Track/(S1-S2)\n  Opp dir meet = Track/(S1+S2)\nGames: points = distance, same formulas",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8600,
      "version": 1,
      "versionNonce": 86,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f27"
      ],
      "containerId": null,
      "originalText": "A beats B by Xm in Dm race: Sa:Sb = D:(D-X)\nA beats B by Xm OR Ts: Sb = X/T\nHead start Xm for dead heat: D/(D-X) = Sa/Sb\n\nTransitive: A beats B by X, B beats C by Y\n  A beats C = X + Y - XY/D\n\nCircular track: same dir meet = Track/(S1-S2)\n  Opp dir meet = Track/(S1+S2)\nGames: points = distance, same formulas",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
