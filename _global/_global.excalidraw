    {
      "id": "el_11",
      "type": "text",
      "x": 1005,
      "y": 125,
      "width": 375,
      "height": 219,
      "text": "BODMAS: Brackets, Orders, Div/Mul (L-R), Add/Sub\n(L-R)\n\n(a+b)^2 = a^2+2ab+b^2 | (a-b)^2 = a^2-2ab+b^2\na^2-b^2 = (a+b)(a-b)\n\na/b + c/d = (ad+bc)/bd | a/b / c/d = ad/bc\n\nRecurring: 0.ababab... = ab/99\nMixed: 0.1666... = (16-1)/90 = 1/6\nTerminating: den has only 2s and 5s as factors\n\n% shortcuts: 12.5%=1/8, 25%=1/4, 33.3%=1/3\nx% of y = y% of x (commutative)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1100,
      "version": 1,
      "versionNonce": 11,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f2"
      ],
      "containerId": null,
      "originalText": "BODMAS: Brackets, Orders, Div/Mul (L-R), Add/Sub\n(L-R)\n\n(a+b)^2 = a^2+2ab+b^2 | (a-b)^2 = a^2-2ab+b^2\na^2-b^2 = (a+b)(a-b)\n\na/b + c/d = (ad+bc)/bd | a/b / c/d = ad/bc\n\nRecurring: 0.ababab... = ab/99\nMixed: 0.1666... = (16-1)/90 = 1/6\nTerminating: den has only 2s and 5s as factors\n\n% shortcuts: 12.5%=1/8, 25%=1/4, 33.3%=1/3\nx% of y = y% of x (commutative)",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
