    {
      "id": "el_47",
      "type": "text",
      "x": 1005,
      "y": 1208,
      "width": 351,
      "height": 172,
      "text": "Cheaper(C) -- Mean(M) -- Dearer(D)\nRatio C:D = (D-M) : (M-C)\n\nMean price = (C.Qc + D.Qd) / (Qc+Qd)\n\nRemove & Replace (n times):\n  Final pure = V x (1 - x/V)^n\n  x = amount removed, V = total volume\n\nMilk:Water ratio change -> only water changes\nKeep milk constant, find new water needed",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4700,
      "version": 1,
      "versionNonce": 47,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f14"
      ],
      "containerId": null,
      "originalText": "Cheaper(C) -- Mean(M) -- Dearer(D)\nRatio C:D = (D-M) : (M-C)\n\nMean price = (C.Qc + D.Qd) / (Qc+Qd)\n\nRemove & Replace (n times):\n  Final pure = V x (1 - x/V)^n\n  x = amount removed, V = total volume\n\nMilk:Water ratio change -> only water changes\nKeep milk constant, find new water needed",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
