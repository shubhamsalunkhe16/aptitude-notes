    {
      "id": "el_104",
      "type": "text",
      "x": 65,
      "y": 3000,
      "width": 406,
      "height": 172,
      "text": "8 dirs: N NE E SE S SW W NW (45 deg apart)\nRight = CW 90 deg: N->E->S->W->N\nLeft = Anti-CW 90 deg: N->W->S->E->N\nOpposite: flip N<->S, E<->W (NE<->SW)\n\nDistance = sqrt(x^2 + y^2)\n  x = net East(+)/West(-), y = net North(+)/South(-)\nTriplets: 3,4,5 | 5,12,13 | 8,15,17\n\nShadows: Morning sun=E, shadow=W | Evening reversed\nMorning shadow left -> facing North",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 10400,
      "version": 1,
      "versionNonce": 104,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f33"
      ],
      "containerId": null,
      "originalText": "8 dirs: N NE E SE S SW W NW (45 deg apart)\nRight = CW 90 deg: N->E->S->W->N\nLeft = Anti-CW 90 deg: N->W->S->E->N\nOpposite: flip N<->S, E<->W (NE<->SW)\n\nDistance = sqrt(x^2 + y^2)\n  x = net East(+)/West(-), y = net North(+)/South(-)\nTriplets: 3,4,5 | 5,12,13 | 8,15,17\n\nShadows: Morning sun=E, shadow=W | Evening reversed\nMorning shadow left -> facing North",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
