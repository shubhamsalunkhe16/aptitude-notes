    {
      "id": "el_35",
      "type": "text",
      "x": 65,
      "y": 887,
      "width": 281,
      "height": 159,
      "text": "LOGIC:\nStep 1: A:B:C = 10k:15k:20k = 2:3:4\nStep 2: Total = 9 parts\nStep 3: A=9000x2/9=2000, B=3000, C=4000\n\nTRICK:\n1 part = 9000/9 = 1000\nA=2x1000, B=3x1000, C=4x1000\nCHECK: 2000+3000+4000=9000 ✓\n\nAnswer: A=2000, B=3000, C=4000 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
