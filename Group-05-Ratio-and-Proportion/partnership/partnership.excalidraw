      "roundness": null
    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 548,
      "width": 296,
      "height": 159,
      "text": "LOGIC:\nStep 1: Same duration → ratio = 3000:5000\nStep 2: = 3:5, total = 8 parts\nStep 3: A=1600x3/8=600, B=1600x5/8=1000\n\nTRICK:\n1 part = 1600/8 = 200\nA = 3x200=600, B = 5x200=1000\nCHECK: 600+1000 = 1600 ✓\n\nAnswer: A = Rs 600, B = Rs 1000 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Same duration → ratio = 3000:5000\nStep 2: = 3:5, total = 8 parts\nStep 3: A=1600x3/8=600, B=1600x5/8=1000\n\nTRICK:\n1 part = 1600/8 = 200\nA = 3x200=600, B = 5x200=1000\nCHECK: 600+1000 = 1600 ✓\n\nAnswer: A = Rs 600, B = Rs 1000 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
