      "type": "text",
      "x": 535,
      "y": 1206,
      "width": 816,
      "height": 49,
      "text": "A starts with Rs 10000. After 6 months, A adds Rs 5000\nmore. B invests Rs 15000 for the whole year. Profit is Rs\n3500. Find shares.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
