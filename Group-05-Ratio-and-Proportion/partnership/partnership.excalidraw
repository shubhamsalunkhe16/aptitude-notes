    {
      "id": "el_58",
      "type": "text",
      "x": 1005,
      "y": 1206,
      "width": 830,
      "height": 49,
      "text": "A invests Rs 6000. B's profit share from a total profit of\nRs 1500 is Rs 900. How much did B invest if both invested\nfor the same period?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5800,
      "version": 1,
      "versionNonce": 58,
      "isDeleted": false,
      "boundElements": null,
