    {
      "id": "el_60",
      "type": "text",
      "x": 1005,
      "y": 1287,
      "width": 245,
      "height": 173,
      "text": "LOGIC:\nStep 1: A profit=600, B profit=900\nStep 2: Ratio = 600:900 = 2:3\nStep 3: Same time → capital = 2:3\n  6000/B = 2/3 → B = 9000\n\nTRICK:\nB/A profit = 900/600 = 3/2\nB capital = A capital x 3/2\n= 6000 x 3/2 = Rs 9000\n\nAnswer: B invested Rs 9000 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6000,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
