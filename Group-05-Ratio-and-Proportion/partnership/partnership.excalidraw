    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 273,
      "height": 78,
      "text": "Invest for DIFFERENT durations\nProfit ratio = Capital × Time ratio\n\nA:B = Cₐ×Tₐ : Cᵦ×Tᵦ\nA's share = Profit × (Cₐ×Tₐ)/Σ(C×T)",
      "fontSize": 13,
      "fontFamily": 3,
