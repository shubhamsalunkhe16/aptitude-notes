    {
      "id": "el_60",
      "type": "text",
      "x": 1005,
      "y": 1635,
      "width": 252,
      "height": 260,
      "text": "LOGIC:\nStep 1: All DIR (more→more shirts)\nStep 2: Man-hrs-days:\n  Old=10x8x4=320, New=15x10x6=900\nStep 3: Shirts=20x900/320=56.25→56\n\n  Variable   Change     Type\n  Men        10→15      DIR → 15/10\n  Hours      8→10       DIR → 10/8\n  Days       4→6        DIR →  6/4\n  ? = 20 × 3/2 × 5/4 × 3/2 = 56\n\nTRICK:\n? = 20 x (15/10) x (10/8) x (6/4)\n= 20 x 3/2 x 5/4 x 3/2\n= 20 x 45/16 = 56 shirts\n\nAnswer: 56 shirts ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6000,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: All DIR (more→more shirts)\nStep 2: Man-hrs-days:\n  Old=10x8x4=320, New=15x10x6=900\nStep 3: Shirts=20x900/320=56.25→56\n\n  Variable   Change     Type\n  Men        10→15      DIR → 15/10\n  Hours      8→10       DIR → 10/8\n  Days       4→6        DIR →  6/4\n  ? = 20 × 3/2 × 5/4 × 3/2 = 56\n\nTRICK:\n? = 20 x (15/10) x (10/8) x (6/4)\n= 20 x 3/2 x 5/4 x 3/2\n= 20 x 45/16 = 56 shirts\n\nAnswer: 56 shirts ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
