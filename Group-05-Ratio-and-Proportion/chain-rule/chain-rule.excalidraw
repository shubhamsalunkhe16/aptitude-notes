    {
      "id": "el_25",
      "type": "text",
      "x": 535,
      "y": 782,
      "width": 274,
      "height": 216,
      "text": "LOGIC:\nStep 1: More men → Less days (Inverse)\nStep 2: Total work = 12 x 20 = 240\nStep 3: Days = 240/15 = 16\n\n  12 men × 20 days = 240 man-days\n  15 men × ?  days = 240 man-days\n  ? = 240/15 = 16\n\nTRICK:\nInverse: flip and multiply\n? = 20 x (12/15) = 16 days\nA1xB1 = A2xB2 (constant product)\n\nAnswer: 16 days ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2500,
      "version": 1,
      "versionNonce": 25,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: More men → Less days (Inverse)\nStep 2: Total work = 12 x 20 = 240\nStep 3: Days = 240/15 = 16\n\n  12 men × 20 days = 240 man-days\n  15 men × ?  days = 240 man-days\n  ? = 240/15 = 16\n\nTRICK:\nInverse: flip and multiply\n? = 20 x (12/15) = 16 days\nA1xB1 = A2xB2 (constant product)\n\nAnswer: 16 days ✓",
      "autoResize": true,
