    {
      "id": "el_48",
      "type": "text",
      "x": 65,
      "y": 1554,
      "width": 816,
      "height": 49,
      "text": "A garrison of 500 men has provisions for 27 days. After 3\ndays, 200 men leave. How many more days will the food\nlast?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4800,
      "version": 1,
      "versionNonce": 48,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "A garrison of 500 men has provisions for 27 days. After 3\ndays, 200 men leave. How many more days will the food\nlast?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_49",
      "type": "text",
      "x": 65,
      "y": 1613,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#862e9c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4900,
      "version": 1,
      "versionNonce": 49,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_50",
      "type": "text",
      "x": 65,
      "y": 1635,
      "width": 281,
      "height": 245,
      "text": "LOGIC:\nStep 1: After 3 days: food for 24 days\n        Men left = 500-200 = 300\nStep 2: Food units = 500x24 = 12000\nStep 3: Days = 12000/300 = 40\n\n  Day 0──3──────────27\n  500 men eat for 3 days → 24 days left\n  200 leave → 300 men\n  300 × ? = 500 × 24 → ? = 40 days\n\nTRICK:\nInverse: ? = 24 x 500/300\n= 24 x 5/3 = 40 days\nMore men leave → food lasts longer\n\nAnswer: 40 more days ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5000,
      "version": 1,
      "versionNonce": 50,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: After 3 days: food for 24 days\n        Men left = 500-200 = 300\nStep 2: Food units = 500x24 = 12000\nStep 3: Days = 12000/300 = 40\n\n  Day 0──3──────────27\n  500 men eat for 3 days → 24 days left\n  200 leave → 300 men\n  300 × ? = 500 × 24 → ? = 40 days\n\nTRICK:\nInverse: ? = 24 x 500/300\n= 24 x 5/3 = 40 days\nMore men leave → food lasts longer\n\nAnswer: 40 more days ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
