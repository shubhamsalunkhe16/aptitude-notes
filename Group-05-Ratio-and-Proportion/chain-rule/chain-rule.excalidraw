    {
      "id": "el_33",
      "type": "text",
      "x": 65,
      "y": 1128,
      "width": 801,
      "height": 33,
      "text": "If 20 men can build a wall 56 m long in 6 days, how many\nmen are needed to build a 72 m wall in 8 days?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
