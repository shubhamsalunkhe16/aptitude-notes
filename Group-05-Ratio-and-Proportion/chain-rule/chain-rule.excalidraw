      "roundness": null
    },
    {
      "id": "el_45",
      "type": "text",
      "x": 1005,
      "y": 1193,
      "width": 303,
      "height": 260,
      "text": "LOGIC:\nStep 1: Units:500→800(DIR)\n        Hours:10→8(INV)\nStep 2: Total capacity = 5x500/10 = 250/hr\n  Need 800/8=100/hr per machine\n  Machines = 800/(8x250/5x10)... = 10\n\n  Variable   Change      Type\n  Units      500→800     DIR → 800/500\n  Hours      10→8        INV →  10/8\n  ? = 5 × (800/500) × (10/8) = 10\n\nTRICK:\n? = 5 x (800/500) x (10/8)\n= 5 x 8/5 x 5/4 = 10 machines\nDIR: same order, INV: flip\n\nAnswer: 10 machines ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4500,
      "version": 1,
      "versionNonce": 45,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Units:500→800(DIR)\n        Hours:10→8(INV)\nStep 2: Total capacity = 5x500/10 = 250/hr\n  Need 800/8=100/hr per machine\n  Machines = 800/(8x250/5x10)... = 10\n\n  Variable   Change      Type\n  Units      500→800     DIR → 800/500\n  Hours      10→8        INV →  10/8\n  ? = 5 × (800/500) × (10/8) = 10\n\nTRICK:\n? = 5 x (800/500) x (10/8)\n= 5 x 8/5 x 5/4 = 10 machines\nDIR: same order, INV: flip\n\nAnswer: 10 machines ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
