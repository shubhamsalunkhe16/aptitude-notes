    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 782,
      "width": 245,
      "height": 245,
      "text": "LOGIC:\nStep 1: Men:8→6(INV), Hrs:6→8(INV)\nStep 2: M1xD1xH1 = M2xD2xH2\n  8x12x6 = 6xD2x8\n  576 = 48xD2 → D2 = 12\n\n  Variable   Change     Type\n  Men        8→6        INV → 8/6\n  Hours      6→8        INV → 6/8\n  ? = 12 × (8/6) × (6/8) = 12\n\nTRICK:\n? = 12 x (8/6) x (6/8) = 12\nINV ratios cancel out here!\nSame total man-hours = same days\n\nAnswer: 12 days ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Men:8→6(INV), Hrs:6→8(INV)\nStep 2: M1xD1xH1 = M2xD2xH2\n  8x12x6 = 6xD2x8\n  576 = 48xD2 → D2 = 12\n\n  Variable   Change     Type\n  Men        8→6        INV → 8/6\n  Hours      6→8        INV → 6/8\n  ? = 12 × (8/6) × (6/8) = 12\n\nTRICK:\n? = 12 x (8/6) x (6/8) = 12\nINV ratios cancel out here!\nSame total man-hours = same days\n\nAnswer: 12 days ✓",
      "autoResize": true,
