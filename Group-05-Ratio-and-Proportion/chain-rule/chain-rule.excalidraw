    {
      "id": "el_13",
      "type": "text",
      "x": 65,
      "y": 378,
      "width": 412,
      "height": 22,
      "text": "Man-Days-Hours Formula",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 17,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1300,
      "version": 1,
      "versionNonce": 13,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f3"
      ],
      "containerId": null,
      "originalText": "Man-Days-Hours Formula",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 403,
      "width": 336,
      "height": 219,
      "text": "M₁ × D₁ × H₁ = M₂ × D₂ × H₂\n(when work is same)\n\nM₁×D₁×H₁/W₁ = M₂×D₂×H₂/W₂\n(when work differs)\n\nTotal work = Men × Days × Hours\n\nWHY: Work is the product of all effort\nvariables. Equal work means equal products.\n\nEx: 10 men × 8 hrs × 5 days = 400\n  ? men × 10 hrs × 4 days = 400\n  ? = 400/40 = 10 men",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1400,
      "version": 1,
      "versionNonce": 14,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f3"
      ],
      "containerId": null,
      "originalText": "M₁ × D₁ × H₁ = M₂ × D₂ × H₂\n(when work is same)\n\nM₁×D₁×H₁/W₁ = M₂×D₂×H₂/W₂\n(when work differs)\n\nTotal work = Men × Days × Hours\n\nWHY: Work is the product of all effort\nvariables. Equal work means equal products.\n\nEx: 10 men × 8 hrs × 5 days = 400\n  ? men × 10 hrs × 4 days = 400\n  ? = 400/40 = 10 men",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
