    {
      "id": "el_18",
      "type": "text",
      "x": 65,
      "y": 717,
      "width": 773,
      "height": 17,
      "text": "If 15 books cost Rs 750, what is the cost of 25 books?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1800,
      "version": 1,
      "versionNonce": 18,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "If 15 books cost Rs 750, what is the cost of 25 books?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_19",
      "type": "text",
      "x": 65,
      "y": 744,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1900,
      "version": 1,
      "versionNonce": 19,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 766,
      "width": 281,
      "height": 216,
      "text": "LOGIC:\nStep 1: More books → More cost (Direct)\nStep 2: 15/25 = 750/x\nStep 3: x = 750 x 25/15 = 1250\n\n  15 books ──→ Rs.750\n  25 books ──→ Rs.???\n  More books → More cost (DIR)\n  ? = 750 × 25/15 = 1250\n\nTRICK:\nUnit price = 750/15 = Rs 50/book\n25 books = 25 x 50 = Rs 1250\n\nAnswer: Cost = Rs 1250 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: More books → More cost (Direct)\nStep 2: 15/25 = 750/x\nStep 3: x = 750 x 25/15 = 1250\n\n  15 books ──→ Rs.750\n  25 books ──→ Rs.???\n  More books → More cost (DIR)\n  ? = 750 × 25/15 = 1250\n\nTRICK:\nUnit price = 750/15 = Rs 50/book\n25 books = 25 x 50 = Rs 1250\n\nAnswer: Cost = Rs 1250 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
