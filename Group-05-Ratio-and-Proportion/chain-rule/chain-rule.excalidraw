    },
    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1619,
      "width": 260,
      "height": 245,
      "text": "LOGIC:\nStep 1: Workers:18→12(DIR for wages)\n        Days:6→9(DIR for wages)\nStep 2: Man-days: 18x6=108, 12x9=108\n  Same man-days → same wages!\n\n  Variable   Change     Type\n  Workers    18→12      DIR → 12/18\n  Days       6→9        DIR →  9/6\n  ? = 5400 × (12/18) × (9/6) = 5400\n\nTRICK:\n? = 5400 x (12/18) x (9/6)\n= 5400 x 2/3 x 3/2 = 5400\nRatios cancel → equal wages\n\nAnswer: Rs 5400 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Workers:18→12(DIR for wages)\n        Days:6→9(DIR for wages)\nStep 2: Man-days: 18x6=108, 12x9=108\n  Same man-days → same wages!\n\n  Variable   Change     Type\n  Workers    18→12      DIR → 12/18\n  Days       6→9        DIR →  9/6\n  ? = 5400 × (12/18) × (9/6) = 5400\n\nTRICK:\n? = 5400 x (12/18) x (9/6)\n= 5400 x 2/3 x 3/2 = 5400\nRatios cancel → equal wages\n\nAnswer: Rs 5400 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
