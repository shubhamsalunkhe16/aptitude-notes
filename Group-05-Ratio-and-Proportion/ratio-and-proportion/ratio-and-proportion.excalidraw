    {
      "id": "el_16",
      "type": "text",
      "x": 535,
      "y": 425,
      "width": 300,
      "height": 22,
      "text": "Direct & Inverse",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 17,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
