    {
      "id": "el_73",
      "type": "text",
      "x": 535,
      "y": 1975,
      "width": 303,
      "height": 216,
      "text": "LOGIC:\nStep 1: More workers → Less days (INVERSE)\nStep 2: 12 x 10 = 15 x ?\n        ? = 120/15 = 8 days\n\n  12 workers × 10 days = 120\n  15 workers × ?  days = 120\n  ? = 120/15 = 8 days\n\nTRICK:\nInverse: multiply and divide\n? = old_days x old_workers/new_workers\n= 10 x 12/15 = 8 days\n\nAnswer: 8 days ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7300,
      "version": 1,
      "versionNonce": 73,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: More workers → Less days (INVERSE)\nStep 2: 12 x 10 = 15 x ?\n        ? = 120/15 = 8 days\n\n  12 workers × 10 days = 120\n  15 workers × ?  days = 120\n  ? = 120/15 = 8 days\n\nTRICK:\nInverse: multiply and divide\n? = old_days x old_workers/new_workers\n= 10 x 12/15 = 8 days\n\nAnswer: 8 days ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
