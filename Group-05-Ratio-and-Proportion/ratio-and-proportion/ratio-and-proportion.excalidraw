    },
    {
      "id": "el_17",
      "type": "text",
      "x": 535,
      "y": 450,
      "width": 320,
      "height": 203,
      "text": "Direct: A↑ then B↑ (same dir)\n  A1/B1 = A2/B2\n  More items → More cost\n\nInverse: A↑ then B↓ (opposite)\n  A1 × B1 = A2 × B2\n  More workers → Less time\n\nWHY: Direct means constant ratio (k=A/B).\nInverse means constant product (k=A×B).\n\nEx: 5 pens cost Rs.60 (direct)\n  8 pens cost 60×8/5 = Rs.96",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1700,
      "version": 1,
      "versionNonce": 17,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f4"
      ],
      "containerId": null,
      "originalText": "Direct: A↑ then B↑ (same dir)\n  A1/B1 = A2/B2\n  More items → More cost\n\nInverse: A↑ then B↓ (opposite)\n  A1 × B1 = A2 × B2\n  More workers → Less time\n\nWHY: Direct means constant ratio (k=A/B).\nInverse means constant product (k=A×B).\n\nEx: 5 pens cost Rs.60 (direct)\n  8 pens cost 60×8/5 = Rs.96",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
