    },
    {
      "id": "el_59",
      "type": "text",
      "x": 535,
      "y": 1501,
      "width": 816,
      "height": 49,
      "text": "A student gets 40% and fails by 30 marks. Another student\ngets 60% and exceeds the pass marks by 20. Find the total\nmarks.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5900,
      "version": 1,
      "versionNonce": 59,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "A student gets 40% and fails by 30 marks. Another student\ngets 60% and exceeds the pass marks by 20. Find the total\nmarks.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_60",
      "type": "text",
      "x": 535,
      "y": 1560,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6000,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_61",
      "type": "text",
      "x": 535,
      "y": 1582,
      "width": 267,
      "height": 216,
      "text": "LOGIC:\nStep 1: 40% of T = Pass - 30 ...(i)\n        60% of T = Pass + 20 ...(ii)\nStep 2: (ii)-(i): 20% of T = 50\n        T = 250 marks\n\nTRICK:\nDifference in marks / Difference in %\n= (30+20) / (60%-40%) = 50/20% = 250\n\n  0%   40%  Pass  60%   100%\n  |─────|─30─|─────|──────|\n  0    100  130   150    250\n\nAnswer: Total = 250 marks ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6100,
      "version": 1,
      "versionNonce": 61,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 40% of T = Pass - 30 ...(i)\n        60% of T = Pass + 20 ...(ii)\nStep 2: (ii)-(i): 20% of T = 50\n        T = 250 marks\n\nTRICK:\nDifference in marks / Difference in %\n= (30+20) / (60%-40%) = 50/20% = 250\n\n  0%   40%  Pass  60%   100%\n  |─────|─30─|─────|──────|\n  0    100  130   150    250\n\nAnswer: Total = 250 marks ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
