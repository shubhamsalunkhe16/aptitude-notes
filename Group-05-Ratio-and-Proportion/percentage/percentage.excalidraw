    {
      "id": "el_39",
      "type": "text",
      "x": 65,
      "y": 1103,
      "width": 830,
      "height": 33,
      "text": "The price of an item rises by 10% and then by another 20%.\nFind the net percentage increase.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3900,
      "version": 1,
      "versionNonce": 39,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "The price of an item rises by 10% and then by another 20%.\nFind the net percentage increase.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_40",
      "type": "text",
      "x": 65,
      "y": 1146,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4000,
      "version": 1,
      "versionNonce": 40,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_41",
      "type": "text",
      "x": 65,
      "y": 1168,
      "width": 252,
      "height": 173,
      "text": "LOGIC:\nStep 1: 100 →+10%→ 110 →+20%→ 132\nStep 2: Net change = 32/100 = 32%\n\n  100 ──+10%──→ 110 ──+20%──→ 132\n\nTRICK:\nFormula: a + b + (a x b)/100\n= 10 + 20 + (10x20)/100 = 32%\nSPECIAL: +x% then -x% = -(x^2/100)%\n\nAnswer: 32% increase ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4100,
      "version": 1,
      "versionNonce": 41,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 100 →+10%→ 110 →+20%→ 132\nStep 2: Net change = 32/100 = 32%\n\n  100 ──+10%──→ 110 ──+20%──→ 132\n\nTRICK:\nFormula: a + b + (a x b)/100\n= 10 + 20 + (10x20)/100 = 32%\nSPECIAL: +x% then -x% = -(x^2/100)%\n\nAnswer: 32% increase ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
