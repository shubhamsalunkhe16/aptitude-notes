    {
      "id": "el_11",
      "type": "text",
      "x": 1005,
      "y": 125,
      "width": 344,
      "height": 219,
      "text": "A is x% more than B:\n  B less than A by x/(100+x)×100%\n\nA is x% less than B:\n  B more than A by x/(100-x)×100%\n\nPrice ↑x%, keep spending same:\n  ↓ consumption by x/(100+x)×100%\n\nWHY: Base changes! A=120 is +20% over B=100,\nbut B=100 is only 100/120 below A → 16.67%.\n\nEx: A is 25% more than B:\n  B less than A by 25/125×100 = 20%",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1100,
      "version": 1,
      "versionNonce": 11,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f2"
      ],
      "containerId": null,
      "originalText": "A is x% more than B:\n  B less than A by x/(100+x)×100%\n\nA is x% less than B:\n  B more than A by x/(100-x)×100%\n\nPrice ↑x%, keep spending same:\n  ↓ consumption by x/(100+x)×100%\n\nWHY: Base changes! A=120 is +20% over B=100,\nbut B=100 is only 100/120 below A → 16.67%.\n\nEx: A is 25% more than B:\n  B less than A by 25/125×100 = 20%",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
