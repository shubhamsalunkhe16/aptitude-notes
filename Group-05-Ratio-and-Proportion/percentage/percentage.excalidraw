    {
      "id": "el_89",
      "type": "text",
      "x": 535,
      "y": 2325,
      "width": 830,
      "height": 33,
      "text": "In an election, candidate A gets 60% of the votes and wins\nby 8000 votes. Find the total number of votes.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
