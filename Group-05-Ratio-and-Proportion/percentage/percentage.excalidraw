    {
      "id": "el_71",
      "type": "text",
      "x": 65,
      "y": 1964,
      "width": 245,
      "height": 260,
      "text": "LOGIC:\nStep 1: Spent = 30+20+10 = 60%\nStep 2: Savings = 100%-60% = 40%\nStep 3: 40% of Salary = 4800\n        Salary = 4800/0.40 = 12000\n\nTRICK:\nSalary = Savings x 100/Savings%\n= 4800 x 100/40 = Rs.12000\n\n  ┌──────────────────────┐\n  │ Rent 30%=3600        │\n  │ Food 20%=2400        │\n  │ Save 40%=4800        │\n  │ Total 100%=12000     │\n  └──────────────────────┘\n\nAnswer: Salary = Rs.12000 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7100,
      "version": 1,
      "versionNonce": 71,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Spent = 30+20+10 = 60%\nStep 2: Savings = 100%-60% = 40%\nStep 3: 40% of Salary = 4800\n        Salary = 4800/0.40 = 12000\n\nTRICK:\nSalary = Savings x 100/Savings%\n= 4800 x 100/40 = Rs.12000\n\n  ┌──────────────────────┐\n  │ Rent 30%=3600        │\n  │ Food 20%=2400        │\n  │ Save 40%=4800        │\n  │ Total 100%=12000     │\n  └──────────────────────┘\n\nAnswer: Salary = Rs.12000 ✓",
      "autoResize": true,
