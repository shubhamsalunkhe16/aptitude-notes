    {
      "id": "el_20",
      "type": "text",
      "x": 1005,
      "y": 450,
      "width": 266,
      "height": 188,
      "text": "1/2=50%  1/3=33.33%  1/4=25%\n1/5=20%  1/6=16.67%  1/7=14.28%\n1/8=12.5% 1/9=11.11% 1/10=10%\n1/11=9.09% 1/12=8.33% 1/15=6.67%\n\nx% of y = y% of x (commutative!)\n8% of 50 = 50% of 8 = 4\n\nWHY: 1/n as % = (1/n)×100 = 100/n.\nMemorize these to avoid division.\n\nEx: 37.5% of 480 → 3/8 × 480 = 180",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f5"
      ],
      "containerId": null,
      "originalText": "1/2=50%  1/3=33.33%  1/4=25%\n1/5=20%  1/6=16.67%  1/7=14.28%\n1/8=12.5% 1/9=11.11% 1/10=10%\n1/11=9.09% 1/12=8.33% 1/15=6.67%\n\nx% of y = y% of x (commutative!)\n8% of 50 = 50% of 8 = 4\n\nWHY: 1/n as % = (1/n)×100 = 100/n.\nMemorize these to avoid division.\n\nEx: 37.5% of 480 → 3/8 × 480 = 180",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_21",
      "type": "line",
      "x": 50,
      "y": 714,
      "width": 1385,
      "height": 0,
      "strokeColor": "#adb5bd",
