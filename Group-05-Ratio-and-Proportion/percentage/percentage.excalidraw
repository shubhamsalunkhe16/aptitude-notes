    {
      "id": "el_69",
      "type": "text",
      "x": 65,
      "y": 1899,
      "width": 744,
      "height": 33,
      "text": "A person spends 30% on rent, 20% on food, and 10% on\ntransport, saving Rs.4800. Find the salary.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
