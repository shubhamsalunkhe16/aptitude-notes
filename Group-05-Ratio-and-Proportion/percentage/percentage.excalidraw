    {
      "id": "el_26",
      "type": "text",
      "x": 65,
      "y": 813,
      "width": 252,
      "height": 173,
      "text": "LOGIC:\nStep 1: 15% of 840 = (15/100) x 840\nStep 2: = 15 x 8.4 = 126\n\n  840 ──×15/100──→ 126\n\nTRICK:\nSplit: 10% of 840 = 84\n       5% of 840 = 42 (half of 10%)\n       15% = 84 + 42 = 126\n\nAnswer: 126 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
