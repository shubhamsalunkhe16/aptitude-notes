      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_17",
      "type": "text",
      "x": 535,
      "y": 450,
      "width": 344,
      "height": 219,
      "text": "Election (2 candidates):\n  Margin% = 2×Winner% - 100\n  Margin = Margin% × Total/100\n  Check for invalid votes!\n\nExam pass marks:\n  Pass = obtained + shortfall\n  Pass = Total × pass%/100\n\nWHY: If winner gets W%, loser gets (100-W)%,\nmargin = W-(100-W) = 2W-100.\n\nEx: Winner=60%: Margin% = 2×60-100 = 20%\n  If 40000 votes: margin = 20%×40000 = 8000",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1700,
      "version": 1,
      "versionNonce": 17,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f4"
      ],
      "containerId": null,
      "originalText": "Election (2 candidates):\n  Margin% = 2×Winner% - 100\n  Margin = Margin% × Total/100\n  Check for invalid votes!\n\nExam pass marks:\n  Pass = obtained + shortfall\n  Pass = Total × pass%/100\n\nWHY: If winner gets W%, loser gets (100-W)%,\nmargin = W-(100-W) = 2W-100.\n\nEx: Winner=60%: Margin% = 2×60-100 = 20%\n  If 40000 votes: margin = 20%×40000 = 8000",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
