    {
      "id": "el_49",
      "type": "text",
      "x": 1005,
      "y": 1103,
      "width": 816,
      "height": 49,
      "text": "If the price of sugar rises by 25%, by what percentage\nmust consumption be reduced to keep the total expenditure\nthe same?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4900,
      "version": 1,
      "versionNonce": 49,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "If the price of sugar rises by 25%, by what percentage\nmust consumption be reduced to keep the total expenditure\nthe same?",
      "autoResize": true,
