      "type": "text",
      "x": 65,
      "y": 1501,
      "width": 830,
      "height": 49,
      "text": "If the length of a rectangle increases by 20% and the\nbreadth decreases by 10%, what is the percentage change in\nits area?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
