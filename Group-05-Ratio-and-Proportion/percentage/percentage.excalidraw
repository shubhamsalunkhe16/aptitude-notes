    {
      "id": "el_76",
      "type": "text",
      "x": 535,
      "y": 1948,
      "width": 288,
      "height": 202,
      "text": "LOGIC:\nStep 1: 5/8 = (5/8) x 100 = 62.5%\nStep 2: 62.5% = 625/1000 = 5/8\n\n  |█████░░░| = 5/8 = 62.5%\n  |████████| = 8/8 = 100%\n\nTRICK:\nMemorize: 1/8=12.5%, so 5/8=5x12.5=62.5%\n  1/2=50%   1/3=33.33%  1/4=25%\n  1/5=20%   1/8=12.5%   3/8=37.5%\n  5/8=62.5% 3/4=75%     7/8=87.5%\n\nAnswer: 5/8 = 62.5% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7600,
      "version": 1,
      "versionNonce": 76,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 5/8 = (5/8) x 100 = 62.5%\nStep 2: 62.5% = 625/1000 = 5/8\n\n  |█████░░░| = 5/8 = 62.5%\n  |████████| = 8/8 = 100%\n\nTRICK:\nMemorize: 1/8=12.5%, so 5/8=5x12.5=62.5%\n  1/2=50%   1/3=33.33%  1/4=25%\n  1/5=20%   1/8=12.5%   3/8=37.5%\n  5/8=62.5% 3/4=75%     7/8=87.5%\n\nAnswer: 5/8 = 62.5% ✓",
