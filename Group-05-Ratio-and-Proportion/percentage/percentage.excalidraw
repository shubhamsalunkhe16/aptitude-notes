    },
    {
      "id": "el_86",
      "type": "text",
      "x": 65,
      "y": 2374,
      "width": 274,
      "height": 216,
      "text": "LOGIC:\nStep 1: Let B=100, A=125 (25% more)\nStep 2: B < A by 25, base = A = 125\nStep 3: (25/125) x 100 = 20%\n\n  B |████████████████| 100\n  A |████████████████████| 125\n      base shifts → 25/125 = 20%\n\nTRICK:\nFormula: x/(100+x) x 100%\n= 25/125 x 100 = 20%\nREVERSE: -20% → +20/(100-20)x100 = 25%\n\nAnswer: B is 20% less than A ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8600,
      "version": 1,
