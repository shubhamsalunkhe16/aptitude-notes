    {
      "id": "el_7",
      "type": "text",
      "x": 535,
      "y": 100,
      "width": 401,
      "height": 17,
      "text": "Successive & Compound Change",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 700,
      "version": 1,
      "versionNonce": 7,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "Successive & Compound Change",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 351,
      "height": 250,
      "text": "Successive a% and b%:\n  Net = a + b + (a×b)/100 %\n\nPopulation growth (n yrs):\n  P × (1 + r/100)^n\n\nDepreciation (n yrs):\n  P × (1 - r/100)^n\n\n+x% then -x% = -(x²/100)% LOSS\n\nWHY: Second change applies on already-changed\nvalue, so cross-term (a×b)/100 appears.\n\nEx: +10% then +20%:\n  Net = 10+20+(10×20)/100 = 32%",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "Successive a% and b%:\n  Net = a + b + (a×b)/100 %\n\nPopulation growth (n yrs):\n  P × (1 + r/100)^n\n\nDepreciation (n yrs):\n  P × (1 - r/100)^n\n\n+x% then -x% = -(x²/100)% LOSS\n\nWHY: Second change applies on already-changed\nvalue, so cross-term (a×b)/100 appears.\n\nEx: +10% then +20%:\n  Net = 10+20+(10×20)/100 = 32%",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
