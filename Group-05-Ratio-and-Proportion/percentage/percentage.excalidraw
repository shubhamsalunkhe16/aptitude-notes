    {
      "id": "el_81",
      "type": "text",
      "x": 1005,
      "y": 1948,
      "width": 238,
      "height": 202,
      "text": "LOGIC:\nStep 1: 37.5% of 480\nStep 2: = (37.5/100) x 480\n        = 0.375 x 480 = 180\n\n  37.5% = 3/8\n  480 ──×3/8──→ 180\n\nTRICK:\n37.5% = 3/8, so (3/8) x 480 = 180\nCOMMUTATIVE: x% of y = y% of x\n8% of 25 = 25% of 8 = 2\n\nAnswer: 180 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8100,
      "version": 1,
      "versionNonce": 81,
      "isDeleted": false,
      "boundElements": null,
