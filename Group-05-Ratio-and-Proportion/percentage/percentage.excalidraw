    },
    {
      "id": "el_56",
      "type": "text",
      "x": 65,
      "y": 1582,
      "width": 310,
      "height": 216,
      "text": "LOGIC:\nStep 1: L=100→120, B=100→90\nStep 2: Old area=10000, New=10800\nStep 3: Change = 800/10000 x 100 = +8%\n\n  L: |████████████| +20% → |██████████████|\n  B: |██████████|  -10% → |█████████|\n  Area = L x B → net +8%\n\nTRICK:\nFormula: a + b + (a x b)/100\n= 20 + (-10) + (20 x -10)/100\n= 20 - 10 - 2 = +8%\n\nAnswer: Area increases 8% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5600,
      "version": 1,
      "versionNonce": 56,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: L=100→120, B=100→90\nStep 2: Old area=10000, New=10800\nStep 3: Change = 800/10000 x 100 = +8%\n\n  L: |████████████| +20% → |██████████████|\n  B: |██████████|  -10% → |█████████|\n  Area = L x B → net +8%\n\nTRICK:\nFormula: a + b + (a x b)/100\n= 20 + (-10) + (20 x -10)/100\n= 20 - 10 - 2 = +8%\n\nAnswer: Area increases 8% ✓",
      "autoResize": true,
