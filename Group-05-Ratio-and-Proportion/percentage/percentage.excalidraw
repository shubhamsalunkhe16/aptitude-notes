    },
    {
      "id": "el_91",
      "type": "text",
      "x": 535,
      "y": 2390,
      "width": 317,
      "height": 231,
      "text": "LOGIC:\nStep 1: A=60%, B=40%, Margin=20%\nStep 2: 20% of Total = 8000\nStep 3: Total = 8000/0.20 = 40000\n  A=24000, B=16000, diff=8000 ✓\n\n  |████████████████████████░░░░░░░░░░░░░░░░|\n  |◄───── A=60% ─────────►|◄─── B=40% ───►|\n  |◄──────── margin=20% = 8000 ──────────►|\n\nTRICK:\nFormula: Total = Margin/(Winner%-50%)x50\nMargin% = 2xWinner% - 100 = 20%\nTotal = 8000 x 100/20 = 40000\n\nAnswer: 40000 votes ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 9100,
      "version": 1,
      "versionNonce": 91,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_14"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A=60%, B=40%, Margin=20%\nStep 2: 20% of Total = 8000\nStep 3: Total = 8000/0.20 = 40000\n  A=24000, B=16000, diff=8000 ✓\n\n  |████████████████████████░░░░░░░░░░░░░░░░|\n  |◄───── A=60% ─────────►|◄─── B=40% ───►|\n  |◄──────── margin=20% = 8000 ──────────►|\n\nTRICK:\nFormula: Total = Margin/(Winner%-50%)x50\nMargin% = 2xWinner% - 100 = 20%\nTotal = 8000 x 100/20 = 40000\n\nAnswer: 40000 votes ✓",
