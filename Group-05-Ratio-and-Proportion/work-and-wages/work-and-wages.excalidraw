    {
      "id": "el_18",
      "type": "text",
      "x": 65,
      "y": 733,
      "width": 816,
      "height": 49,
      "text": "A can do a work in 10 days and B can do it in 15 days.\nThey work together and earn Rs.5000. What is the share of\neach?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
