      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3900,
      "version": 1,
      "versionNonce": 39,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_40",
      "type": "text",
      "x": 535,
      "y": 1257,
      "width": 274,
      "height": 245,
      "text": "LOGIC:\nStep 1: G1=10x500=5000/day\n        G2=8x400=3200/day\nStep 2: Daily total = 5000+3200 = 8200\nStep 3: 6 days = 8200x6 = Rs.49,200\n\n  G1: 10 workers × Rs.500 = 5000/day\n  G2:  8 workers × Rs.400 = 3200/day\n  Daily total = 8200\n  8200 ──×6 days──→ Rs.49,200\n\nTRICK:\nTotal = (w1xr1 + w2xr2) x days\n= (10x500 + 8x400) x 6\n= 8200 x 6 = Rs.49,200\n\nAnswer: Rs.49,200 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4000,
      "version": 1,
      "versionNonce": 40,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: G1=10x500=5000/day\n        G2=8x400=3200/day\nStep 2: Daily total = 5000+3200 = 8200\nStep 3: 6 days = 8200x6 = Rs.49,200\n\n  G1: 10 workers × Rs.500 = 5000/day\n  G2:  8 workers × Rs.400 = 3200/day\n  Daily total = 8200\n  8200 ──×6 days──→ Rs.49,200\n\nTRICK:\nTotal = (w1xr1 + w2xr2) x days\n= (10x500 + 8x400) x 6\n= 8200 x 6 = Rs.49,200\n\nAnswer: Rs.49,200 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
