    {
      "id": "el_53",
      "type": "text",
      "x": 535,
      "y": 1313,
      "width": 816,
      "height": 49,
      "text": "A worker earns Rs.480 for an 8-hour day. Overtime is paid\nat 1.5 times the normal hourly rate. If he works 11 hours\nin a day, what is his total earning for that day?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5300,
      "version": 1,
      "versionNonce": 53,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "A worker earns Rs.480 for an 8-hour day. Overtime is paid\nat 1.5 times the normal hourly rate. If he works 11 hours\nin a day, what is his total earning for that day?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
