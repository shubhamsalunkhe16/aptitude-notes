    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 642,
      "width": 245,
      "height": 188,
      "text": "LOGIC:\nStep 1: A does 8/20 work in 8 days\nStep 2: B does remaining 12/20\nStep 3: Ratio = 8:12 = 2:3\n  B = 4000x3/5 = Rs.2400\n\nTRICK:\nWages by work done (not time!)\nA:B = 8:12 = 2:3\n1 part = 4000/5 = 800\nA=1600, B=2400\n\nAnswer: B gets Rs.2400 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
