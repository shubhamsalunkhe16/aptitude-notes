    },
    {
      "id": "el_50",
      "type": "text",
      "x": 65,
      "y": 1410,
      "width": 332,
      "height": 173,
      "text": "LOGIC:\nStep 1: Accepted = 50-8 = 42\nStep 2: Earned = 42x15 = Rs.630\n        Deducted = 8x5 = Rs.40\nStep 3: Net = 630-40 = Rs.590\n\nTRICK:\nNet = (Accepted x rate) - (Rejected x penalty)\n= 42x15 - 8x5 = 630-40 = Rs.590\nEach rejected costs 15+5=20 vs accepted\n\nAnswer: Rs.590 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5000,
      "version": 1,
      "versionNonce": 50,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Accepted = 50-8 = 42\nStep 2: Earned = 42x15 = Rs.630\n        Deducted = 8x5 = Rs.40\nStep 3: Net = 630-40 = Rs.590\n\nTRICK:\nNet = (Accepted x rate) - (Rejected x penalty)\n= 42x15 - 8x5 = 630-40 = Rs.590\nEach rejected costs 15+5=20 vs accepted\n\nAnswer: Rs.590 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
