    {
      "id": "el_18",
      "type": "text",
      "x": 65,
      "y": 545,
      "width": 816,
      "height": 49,
      "text": "A can do a work in 10 days and B can do it in 15 days.\nThey work together and earn Rs.5000. What is the share of\neach?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1800,
      "version": 1,
      "versionNonce": 18,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "A can do a work in 10 days and B can do it in 15 days.\nThey work together and earn Rs.5000. What is the share of\neach?",
