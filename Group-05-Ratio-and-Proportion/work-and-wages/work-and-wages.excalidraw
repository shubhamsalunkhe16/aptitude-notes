      "link": null,
      "locked": false,
      "groupIds": [
        "f2"
      ],
      "containerId": null,
      "originalText": "Daily Wage & Piece Rate",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
