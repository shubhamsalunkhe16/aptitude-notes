    {
      "id": "el_53",
      "type": "text",
      "x": 535,
      "y": 1603,
      "width": 816,
      "height": 49,
      "text": "A worker earns Rs.480 for an 8-hour day. Overtime is paid\nat 1.5 times the normal hourly rate. If he works 11 hours\nin a day, what is his total earning for that day?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5300,
      "version": 1,
      "versionNonce": 53,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "A worker earns Rs.480 for an 8-hour day. Overtime is paid\nat 1.5 times the normal hourly rate. If he works 11 hours\nin a day, what is his total earning for that day?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_54",
      "type": "text",
      "x": 535,
      "y": 1662,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5400,
      "version": 1,
      "versionNonce": 54,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1684,
      "width": 296,
      "height": 231,
      "text": "LOGIC:\nStep 1: Normal rate = 480/8 = Rs.60/hr\n  OT rate = 1.5x60 = Rs.90/hr\nStep 2: OT hours = 11-8 = 3\nStep 3: Total = 480 + 3x90 = Rs.750\n\n  |──── 8 hrs normal ────|── 3 hrs OT ──|\n  |  8 × Rs.60 = 480     | 3 × Rs.90=270|\n  Total = 480 + 270 = Rs.750\n\nTRICK:\nTotal = Base + OT_hrs x OT_rate\n= 480 + 3x(1.5x60)\n= 480 + 270 = Rs.750\n\nAnswer: Rs.750 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Normal rate = 480/8 = Rs.60/hr\n  OT rate = 1.5x60 = Rs.90/hr\nStep 2: OT hours = 11-8 = 3\nStep 3: Total = 480 + 3x90 = Rs.750\n\n  |──── 8 hrs normal ────|── 3 hrs OT ──|\n  |  8 × Rs.60 = 480     | 3 × Rs.90=270|\n  Total = 480 + 270 = Rs.750\n\nTRICK:\nTotal = Base + OT_hrs x OT_rate\n= 480 + 3x(1.5x60)\n= 480 + 270 = Rs.750\n\nAnswer: Rs.750 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
