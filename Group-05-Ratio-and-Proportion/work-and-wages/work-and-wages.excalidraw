    {
      "id": "el_43",
      "type": "text",
      "x": 1005,
      "y": 1176,
      "width": 816,
      "height": 49,
      "text": "5 men and 4 women can complete a work in 8 days. Daily\nwage of a man is Rs.600 and a woman is Rs.400. If 2 men =\n3 women in efficiency, what is the total labor cost?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4300,
      "version": 1,
      "versionNonce": 43,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "5 men and 4 women can complete a work in 8 days. Daily\nwage of a man is Rs.600 and a woman is Rs.400. If 2 men =\n3 women in efficiency, what is the total labor cost?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_44",
      "type": "text",
      "x": 1005,
      "y": 1235,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#862e9c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4400,
      "version": 1,
      "versionNonce": 44,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_45",
      "type": "text",
      "x": 1005,
      "y": 1257,
      "width": 288,
      "height": 231,
      "text": "LOGIC:\nStep 1: Men: 5x600x8 = Rs.24,000\nStep 2: Women: 4x400x8 = Rs.12,800\nStep 3: Total = 24000+12800 = Rs.36,800\n\n  Men:   5 × Rs.600 × 8 days = Rs.24,000\n  Women: 4 × Rs.400 × 8 days = Rs.12,800\n  Total labor cost = Rs.36,800\n\nTRICK:\nTotal = sum(workers x rate x days)\nEfficiency info is irrelevant here!\nWages = actual persons x their rate\n= (5x600 + 4x400) x 8 = Rs.36,800\n\nAnswer: Rs.36,800 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4500,
      "version": 1,
      "versionNonce": 45,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Men: 5x600x8 = Rs.24,000\nStep 2: Women: 4x400x8 = Rs.12,800\nStep 3: Total = 24000+12800 = Rs.36,800\n\n  Men:   5 × Rs.600 × 8 days = Rs.24,000\n  Women: 4 × Rs.400 × 8 days = Rs.12,800\n  Total labor cost = Rs.36,800\n\nTRICK:\nTotal = sum(workers x rate x days)\nEfficiency info is irrelevant here!\nWages = actual persons x their rate\n= (5x600 + 4x400) x 8 = Rs.36,800\n\nAnswer: Rs.36,800 ✓",
