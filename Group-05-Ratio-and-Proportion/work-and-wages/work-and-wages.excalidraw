    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 336,
      "height": 94,
      "text": "Wages ∝ Work Done (Efficiency)\nWages are ALWAYS split by EFFICIENCY ratio\nNOT by number of days worked!\n\nMore work done = More pay\nShare = (Your eff / Total eff) × Total Wage",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
