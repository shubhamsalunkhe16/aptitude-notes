      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: G1=10x500=5000/day\n        G2=8x400=3200/day\nStep 2: Daily total = 5000+3200 = 8200\nStep 3: 6 days = 8200x6 = Rs.49,200\n\nTRICK:\nTotal = (w1xr1 + w2xr2) x days\n= (10x500 + 8x400) x 6\n= 8200 x 6 = Rs.49,200\n\nAnswer: Rs.49,200 ✓",
      "autoResize": true,
