    },
    {
      "id": "el_25",
      "type": "text",
      "x": 535,
      "y": 814,
      "width": 281,
      "height": 245,
      "text": "LOGIC:\nStep 1: LCM(10,15)=30, A eff=3, B eff=2\nStep 2: A work=4x3=12, B work=9x2=18\nStep 3: Wage ratio = 12:18 = 2:3\n  A=3000x2/5=1200, B=1800\n\n  A: eff=3 × 4 days = 12 units\n  B: eff=2 × 9 days = 18 units\n  Work ratio = 12:18 = 2:3\n\nTRICK:\nWages split by WORK DONE, not days!\nWork = efficiency x days worked\nA:B = 12:18 = 2:3\n1 part = 3000/5 = 600\n\nAnswer: A = Rs.1200, B = Rs.1800 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2500,
      "version": 1,
      "versionNonce": 25,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: LCM(10,15)=30, A eff=3, B eff=2\nStep 2: A work=4x3=12, B work=9x2=18\nStep 3: Wage ratio = 12:18 = 2:3\n  A=3000x2/5=1200, B=1800\n\n  A: eff=3 × 4 days = 12 units\n  B: eff=2 × 9 days = 18 units\n  Work ratio = 12:18 = 2:3\n\nTRICK:\nWages split by WORK DONE, not days!\nWork = efficiency x days worked\nA:B = 12:18 = 2:3\n1 part = 3000/5 = 600\n\nAnswer: A = Rs.1200, B = Rs.1800 ✓",
      "autoResize": true,
