      "roundness": null
    },
    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1394,
      "width": 274,
      "height": 173,
      "text": "LOGIC:\nStep 1: Normal rate = 480/8 = Rs.60/hr\n  OT rate = 1.5x60 = Rs.90/hr\nStep 2: OT hours = 11-8 = 3\nStep 3: Total = 480 + 3x90 = Rs.750\n\nTRICK:\nTotal = Base + OT_hrs x OT_rate\n= 480 + 3x(1.5x60)\n= 480 + 270 = Rs.750\n\nAnswer: Rs.750 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Normal rate = 480/8 = Rs.60/hr\n  OT rate = 1.5x60 = Rs.90/hr\nStep 2: OT hours = 11-8 = 3\nStep 3: Total = 480 + 3x90 = Rs.750\n\nTRICK:\nTotal = Base + OT_hrs x OT_rate\n= 480 + 3x(1.5x60)\n= 480 + 270 = Rs.750\n\nAnswer: Rs.750 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
