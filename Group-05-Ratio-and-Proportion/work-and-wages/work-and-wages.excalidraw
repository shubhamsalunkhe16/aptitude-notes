    {
      "id": "el_48",
      "type": "text",
      "x": 65,
      "y": 1313,
      "width": 816,
      "height": 65,
      "text": "A worker is paid Rs.15 for each finished item and Rs.5 is\ndeducted for each rejected item. In a day he produces 50\nitems, out of which 8 are rejected. What is his daily\nearning?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4800,
