      "roundness": null
    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 626,
      "width": 245,
      "height": 188,
      "text": "LOGIC:\nStep 1: LCM(10,15)=30 (Total Work)\n  A eff=30/10=3, B eff=30/15=2\nStep 2: Wages split by efficiency\n  A = (3/5)x5000=3000\n  B = (2/5)x5000=2000\n\nTRICK:\nEff ratio = 1/10 : 1/15 = 3:2\n1 part = 5000/5 = 1000\nA=3000, B=2000\n\nAnswer: A = Rs.3000, B = Rs.2000 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: LCM(10,15)=30 (Total Work)\n  A eff=30/10=3, B eff=30/15=2\nStep 2: Wages split by efficiency\n  A = (3/5)x5000=3000\n  B = (2/5)x5000=2000\n\nTRICK:\nEff ratio = 1/10 : 1/15 = 3:2\n1 part = 5000/5 = 1000\nA=3000, B=2000\n\nAnswer: A = Rs.3000, B = Rs.2000 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
