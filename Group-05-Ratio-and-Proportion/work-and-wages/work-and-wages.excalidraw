      "type": "text",
      "x": 535,
      "y": 1176,
      "width": 830,
      "height": 49,
      "text": "A contractor hires 10 workers at Rs.500/day and 8 workers\nat Rs.400/day. If the work takes 6 days, what is the total\nlabor cost?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3800,
      "version": 1,
      "versionNonce": 38,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "A contractor hires 10 workers at Rs.500/day and 8 workers\nat Rs.400/day. If the work takes 6 days, what is the total\nlabor cost?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_39",
      "type": "text",
      "x": 535,
      "y": 1235,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
