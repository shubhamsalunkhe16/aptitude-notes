    {
      "id": "el_18",
      "type": "text",
      "x": 65,
      "y": 732,
      "width": 816,
      "height": 33,
      "text": "In what ratio must rice at Rs 30/kg be mixed with rice at\nRs 40/kg to get a mixture worth Rs 34/kg?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1800,
      "version": 1,
      "versionNonce": 18,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "In what ratio must rice at Rs 30/kg be mixed with rice at\nRs 40/kg to get a mixture worth Rs 34/kg?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_19",
      "type": "text",
      "x": 65,
      "y": 775,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1900,
      "version": 1,
      "versionNonce": 19,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 797,
      "width": 209,
      "height": 231,
      "text": "LOGIC:\nStep 1: C=30, D=40, M=34\nStep 2: Let ratio be x:y\n  (30x+40y)/(x+y) = 34\n  30x+40y = 34x+34y → 6y=4x\n  x:y = 6:4 = 3:2\n\nTRICK:\nAlligation cross:\n  30       40\n    \\     /\n      34\n    /     \\\n  (40-34):(34-30) = 6:4 = 3:2\n\nAnswer: Ratio = 3:2 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: C=30, D=40, M=34\nStep 2: Let ratio be x:y\n  (30x+40y)/(x+y) = 34\n  30x+40y = 34x+34y → 6y=4x\n  x:y = 6:4 = 3:2\n\nTRICK:\nAlligation cross:\n  30       40\n    \\     /\n      34\n    /     \\\n  (40-34):(34-30) = 6:4 = 3:2\n\nAnswer: Ratio = 3:2 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
