    {
      "id": "el_53",
      "type": "text",
      "x": 535,
      "y": 1601,
      "width": 830,
      "height": 49,
      "text": "A shopkeeper mixes 2 varieties of tea, one at Rs 60/kg and\nanother at Rs 90/kg in ratio 2:1, and sells at Rs 80/kg.\nFind profit percent.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5300,
      "version": 1,
      "versionNonce": 53,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "A shopkeeper mixes 2 varieties of tea, one at Rs 60/kg and\nanother at Rs 90/kg in ratio 2:1, and sells at Rs 80/kg.\nFind profit percent.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
