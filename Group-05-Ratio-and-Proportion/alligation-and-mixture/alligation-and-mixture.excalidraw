    {
      "id": "el_33",
      "type": "text",
      "x": 65,
      "y": 1188,
      "width": 830,
      "height": 33,
      "text": "How many litres of a 30% acid solution must be added to 40\nlitres of a 10% acid solution to get a 20% acid solution?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3300,
      "version": 1,
      "versionNonce": 33,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "How many litres of a 30% acid solution must be added to 40\nlitres of a 10% acid solution to get a 20% acid solution?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_34",
      "type": "text",
      "x": 65,
      "y": 1231,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3400,
      "version": 1,
      "versionNonce": 34,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_35",
      "type": "text",
      "x": 65,
      "y": 1253,
      "width": 252,
      "height": 231,
      "text": "LOGIC:\nStep 1: C=10%, D=30%, M=20%\nStep 2: Acid balance: 40x0.1+xx0.3\n  = (40+x)x0.2\n  4+0.3x = 8+0.2x → 0.1x=4 → x=40\n\n  [40L @10%] + [?L @30%] = [? @20%]\n  Alligation: (30-20):(20-10) = 1:1\n  Need 40L of 30% solution\n\nTRICK:\nAlligation: (D-M):(M-C)\n= (30-20):(20-10) = 10:10 = 1:1\n40L of 10% → need 40L of 30%\n\nAnswer: 40 litres ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3500,
      "version": 1,
      "versionNonce": 35,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: C=10%, D=30%, M=20%\nStep 2: Acid balance: 40x0.1+xx0.3\n  = (40+x)x0.2\n  4+0.3x = 8+0.2x → 0.1x=4 → x=40\n\n  [40L @10%] + [?L @30%] = [? @20%]\n  Alligation: (30-20):(20-10) = 1:1\n  Need 40L of 30% solution\n\nTRICK:\nAlligation: (D-M):(M-C)\n= (30-20):(20-10) = 10:10 = 1:1\n40L of 10% → need 40L of 30%\n\nAnswer: 40 litres ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
