    {
      "id": "el_48",
      "type": "text",
      "x": 65,
      "y": 1601,
      "width": 787,
      "height": 33,
      "text": "A mixture of 40 litres has milk and water in ratio 3:1.\nHow much water must be added to make the ratio 3:2?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4800,
      "version": 1,
      "versionNonce": 48,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "A mixture of 40 litres has milk and water in ratio 3:1.\nHow much water must be added to make the ratio 3:2?",
      "autoResize": true,
