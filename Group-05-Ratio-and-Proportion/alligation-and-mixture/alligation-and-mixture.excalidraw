    {
      "id": "el_73",
      "type": "text",
      "x": 1005,
      "y": 2028,
      "width": 830,
      "height": 49,
      "text": "Alloy A has copper and zinc in ratio 5:3. Alloy B has them\nin ratio 1:2. If 8 kg of A and 12 kg of B are melted, find\ncopper percentage in new alloy.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7300,
      "version": 1,
      "versionNonce": 73,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "Alloy A has copper and zinc in ratio 5:3. Alloy B has them\nin ratio 1:2. If 8 kg of A and 12 kg of B are melted, find\ncopper percentage in new alloy.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_74",
      "type": "text",
      "x": 1005,
      "y": 2087,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7400,
      "version": 1,
      "versionNonce": 74,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_75",
      "type": "text",
      "x": 1005,
      "y": 2109,
      "width": 260,
      "height": 231,
      "text": "LOGIC:\nStep 1: Cu in A = 8x5/8 = 5 kg\n        Cu in B = 12x1/3 = 4 kg\nStep 2: Total Cu = 9, Total = 20 kg\nStep 3: Cu% = (9/20)x100 = 45%\n\n  Alloy A: [Cu=5 Zn=3] 8kg → Cu=5kg\n  Alloy B: [Cu=1 Zn=2] 12kg → Cu=4kg\n  Mixed:   [Cu=9 Zn=11] 20kg → 45%\n\nTRICK:\nCu fractions: A=5/8, B=1/3\nWeighted: (5/8x8 + 1/3x12)/20\n= (5+4)/20 = 9/20 = 45%\n\nAnswer: Copper = 45% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7500,
      "version": 1,
      "versionNonce": 75,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Cu in A = 8x5/8 = 5 kg\n        Cu in B = 12x1/3 = 4 kg\nStep 2: Total Cu = 9, Total = 20 kg\nStep 3: Cu% = (9/20)x100 = 45%\n\n  Alloy A: [Cu=5 Zn=3] 8kg → Cu=5kg\n  Alloy B: [Cu=1 Zn=2] 12kg → Cu=4kg\n  Mixed:   [Cu=9 Zn=11] 20kg → 45%\n\nTRICK:\nCu fractions: A=5/8, B=1/3\nWeighted: (5/8x8 + 1/3x12)/20\n= (5+4)/20 = 9/20 = 45%\n\nAnswer: Copper = 45% ✓",
