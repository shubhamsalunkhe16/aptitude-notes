    },
    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 813,
      "width": 224,
      "height": 274,
      "text": "LOGIC:\nStep 1: Let ratio be x:y\n  (126x+135y)/(x+y) = 130\n  126x+135y = 130x+130y\n  5y = 4x → x:y = 5:4\n\nTRICK:\nAlligation: (D-M):(M-C)\n= (135-130):(130-126) = 5:4\n\n  126       135\n    \\       /\n      130\n    /       \\\n  (135-130):(130-126) = 5:4\n\nVerify: (126x5+135x4)/9 = 130 ✓\n\nAnswer: Ratio = 5:4 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Let ratio be x:y\n  (126x+135y)/(x+y) = 130\n  126x+135y = 130x+130y\n  5y = 4x → x:y = 5:4\n\nTRICK:\nAlligation: (D-M):(M-C)\n= (135-130):(130-126) = 5:4\n\n  126       135\n    \\       /\n      130\n    /       \\\n  (135-130):(130-126) = 5:4\n\nVerify: (126x5+135x4)/9 = 130 ✓\n\nAnswer: Ratio = 5:4 ✓",
      "autoResize": true,
