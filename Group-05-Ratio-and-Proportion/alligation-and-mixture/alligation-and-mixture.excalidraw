    {
      "id": "el_68",
      "type": "text",
      "x": 535,
      "y": 2028,
      "width": 787,
      "height": 49,
      "text": "Milk at Rs 15/litre is mixed with water (free) to get a\nmixture worth Rs 10/litre. Find the ratio of milk to\nwater.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6800,
      "version": 1,
