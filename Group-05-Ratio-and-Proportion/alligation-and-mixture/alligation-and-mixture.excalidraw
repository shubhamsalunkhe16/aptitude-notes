    },
    {
      "id": "el_65",
      "type": "text",
      "x": 65,
      "y": 2093,
      "width": 209,
      "height": 274,
      "text": "LOGIC:\nStep 1: Milk fractions:\n  C1=3/5, C2=5/8, Target=7/11\nStep 2: Let ratio = x:y\n  (3x/5+5y/8)/(x+y) = 7/11\n  Cross multiply and solve:\n  x:y = 16:5\n\nTRICK:\nAlligation on milk fractions:\n  3/5       5/8\n    \\       /\n     7/11\n    /       \\\n  (D-M)   (M-C)\n= (5/8-7/11):(7/11-3/5)\n= 16:5\n\nAnswer: Ratio = 16:5 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6500,
      "version": 1,
      "versionNonce": 65,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
