    {
      "id": "el_23",
      "type": "text",
      "x": 535,
      "y": 732,
      "width": 801,
      "height": 33,
      "text": "5 kg of wheat at Rs 20/kg is mixed with 3 kg of wheat at\nRs 30/kg. Find the price per kg of the mixture.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
