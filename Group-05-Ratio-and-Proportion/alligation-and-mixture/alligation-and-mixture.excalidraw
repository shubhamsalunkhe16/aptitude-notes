      "roundness": null
    },
    {
      "id": "el_70",
      "type": "text",
      "x": 535,
      "y": 2109,
      "width": 274,
      "height": 245,
      "text": "LOGIC:\nStep 1: Milk=15/L, Water=0/L, Mix=10/L\nStep 2: Let milk=x, water=y\n  15x/(x+y) = 10 → 15x=10x+10y\n  5x = 10y → x:y = 2:1\n\nTRICK:\nAlligation: water=0(cheaper), milk=15\n  0(Water)    15(Milk)\n    \\          /\n       10\n    /          \\\n  (15-10)  :(10-0)\n  W:M = 5:10 = 1:2\n  Milk:Water = 2:1\n\nAnswer: Milk:Water = 2:1 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7000,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Milk=15/L, Water=0/L, Mix=10/L\nStep 2: Let milk=x, water=y\n  15x/(x+y) = 10 → 15x=10x+10y\n  5x = 10y → x:y = 2:1\n\nTRICK:\nAlligation: water=0(cheaper), milk=15\n  0(Water)    15(Milk)\n    \\          /\n       10\n    /          \\\n  (15-10)  :(10-0)\n  W:M = 5:10 = 1:2\n  Milk:Water = 2:1\n\nAnswer: Milk:Water = 2:1 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
