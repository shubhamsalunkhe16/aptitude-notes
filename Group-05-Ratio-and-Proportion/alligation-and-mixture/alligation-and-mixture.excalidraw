    {
      "id": "el_38",
      "type": "text",
      "x": 535,
      "y": 1188,
      "width": 830,
      "height": 49,
      "text": "A container has 80 litres of milk. 8 litres is taken out\nand replaced with water. This is done twice. Find the milk\nremaining.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3800,
      "version": 1,
      "versionNonce": 38,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "A container has 80 litres of milk. 8 litres is taken out\nand replaced with water. This is done twice. Find the milk\nremaining.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_39",
      "type": "text",
      "x": 535,
      "y": 1247,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3900,
      "version": 1,
      "versionNonce": 39,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_40",
      "type": "text",
      "x": 535,
      "y": 1269,
      "width": 288,
      "height": 231,
      "text": "LOGIC:\nStep 1: Start: 80L milk\nStep 2: Op 1: remove 8L, add water\n  Milk = 80-8 = 72L\nStep 3: Op 2: remove 8L (has 72/80 milk)\n  Milk = 72 - 8x(72/80) = 64.8L\n\n  80L ─-8L+W─→ 72L ─-8L+W─→ 64.8L\n  Each op keeps (1-8/80)=90% of milk\n\nTRICK:\nFormula: V x (1-x/V)^n\n= 80 x (1-8/80)^2 = 80 x (9/10)^2\n= 80 x 81/100 = 64.8L\n\nAnswer: 64.8 litres of milk ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4000,
      "version": 1,
      "versionNonce": 40,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Start: 80L milk\nStep 2: Op 1: remove 8L, add water\n  Milk = 80-8 = 72L\nStep 3: Op 2: remove 8L (has 72/80 milk)\n  Milk = 72 - 8x(72/80) = 64.8L\n\n  80L ─-8L+W─→ 72L ─-8L+W─→ 64.8L\n  Each op keeps (1-8/80)=90% of milk\n\nTRICK:\nFormula: V x (1-x/V)^n\n= 80 x (1-8/80)^2 = 80 x (9/10)^2\n= 80 x 81/100 = 64.8L\n\nAnswer: 64.8 litres of milk ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
