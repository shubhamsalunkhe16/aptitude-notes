    },
    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1682,
      "width": 245,
      "height": 245,
      "text": "LOGIC:\nStep 1: CP = (60x2+90x1)/3 = 210/3\n        = Rs 70/kg\nStep 2: SP = Rs 80, Profit = 10\nStep 3: P% = (10/70)x100 = 14.29%\n\n  CP |████████████████| 70\n  SP |████████████████████| 80\n  Profit = 10/70 = 14.29%\n\nTRICK:\nWeighted avg for CP, then P%\nCP = (120+90)/3 = 70\nP% = (SP-CP)/CP x 100\n= 10/70 x 100 = 14.29%\n\nAnswer: Profit = 14.29% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: CP = (60x2+90x1)/3 = 210/3\n        = Rs 70/kg\nStep 2: SP = Rs 80, Profit = 10\nStep 3: P% = (10/70)x100 = 14.29%\n\n  CP |████████████████| 70\n  SP |████████████████████| 80\n  Profit = 10/70 = 14.29%\n\nTRICK:\nWeighted avg for CP, then P%\nCP = (120+90)/3 = 70\nP% = (SP-CP)/CP x 100\n= 10/70 x 100 = 14.29%\n\nAnswer: Profit = 14.29% ✓",
      "autoResize": true,
