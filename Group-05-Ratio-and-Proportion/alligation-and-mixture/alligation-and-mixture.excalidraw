      "roundness": null
    },
    {
      "id": "el_25",
      "type": "text",
      "x": 535,
      "y": 797,
      "width": 332,
      "height": 245,
      "text": "LOGIC:\nStep 1: Total cost = 20x5 + 30x3\n        = 100 + 90 = 190\nStep 2: Total qty = 5+3 = 8 kg\nStep 3: Mean = 190/8 = Rs 23.75/kg\n\n  [5kg @ Rs.20] + [3kg @ Rs.30] = [8kg @ Rs.?]\n  Total cost = 100 + 90 = 190\n  Mean = 190/8 = 23.75\n\nTRICK:\nWeighted avg = (CxQc + DxQd)/(Qc+Qd)\n= (100+90)/8 = 23.75\nAlways between C and D,\ncloser to larger qty price ✓\n\nAnswer: Rs 23.75/kg ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2500,
      "version": 1,
      "versionNonce": 25,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Total cost = 20x5 + 30x3\n        = 100 + 90 = 190\nStep 2: Total qty = 5+3 = 8 kg\nStep 3: Mean = 190/8 = Rs 23.75/kg\n\n  [5kg @ Rs.20] + [3kg @ Rs.30] = [8kg @ Rs.?]\n  Total cost = 100 + 90 = 190\n  Mean = 190/8 = 23.75\n\nTRICK:\nWeighted avg = (CxQc + DxQd)/(Qc+Qd)\n= (100+90)/8 = 23.75\nAlways between C and D,\ncloser to larger qty price ✓\n\nAnswer: Rs 23.75/kg ✓",
      "autoResize": true,
