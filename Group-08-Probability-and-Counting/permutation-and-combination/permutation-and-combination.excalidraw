      "roundness": null
    },
    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 328,
      "height": 172,
      "text": "nPr = n! / (n-r)!\nnPn = n!  (all items)\nWith repetition: n^r\nRepeated items: n! / (p1!×p2!×...)\nCircular: (n-1)!\nNecklace: (n-1)!/2\n\nWHY: First slot has n choices, second n-1,\n  ...r-th has n-r+1. Product = n!/(n-r)!\n\nEx: 5P3 = 5!/2! = 120/2 = 60",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "nPr = n! / (n-r)!\nnPn = n!  (all items)\nWith repetition: n^r\nRepeated items: n! / (p1!×p2!×...)\nCircular: (n-1)!\nNecklace: (n-1)!/2\n\nWHY: First slot has n choices, second n-1,\n  ...r-th has n-r+1. Product = n!/(n-r)!\n\nEx: 5P3 = 5!/2! = 120/2 = 60",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
