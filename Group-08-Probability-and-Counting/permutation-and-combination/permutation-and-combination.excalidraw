      "type": "text",
      "x": 1005,
      "y": 1829,
      "width": 787,
      "height": 49,
      "text": "In how many ways can the letters of the word ORANGE be\narranged so that the vowels are always together? And in\nhow many ways so that the vowels are never together?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7300,
