    {
      "id": "el_60",
      "type": "text",
      "x": 1005,
      "y": 1468,
      "width": 267,
      "height": 260,
      "text": "LOGIC:\nStep 1: Total 10C4 = 210\n  No women = 6C4 = 15\nStep 2: At least 1W = 210-15 = 195\n\nTRICK:\nAt least 1 = Total - None\n(complement is always faster)\nDirect: 1W+2W+3W+4W = 195 (slower)\n\n  Total(210)─No women(15)=At least 1W\n  ┌──────────────────────┐\n  │ All combos = 210     │\n  │ Remove 0W cases = 15 │\n  │ Result = 195         │\n  └──────────────────────┘\n\nAnswer: 195 ways ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6000,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Total 10C4 = 210\n  No women = 6C4 = 15\nStep 2: At least 1W = 210-15 = 195\n\nTRICK:\nAt least 1 = Total - None\n(complement is always faster)\nDirect: 1W+2W+3W+4W = 195 (slower)\n\n  Total(210)─No women(15)=At least 1W\n  ┌──────────────────────┐\n  │ All combos = 210     │\n  │ Remove 0W cases = 15 │\n  │ Result = 195         │\n  └──────────────────────┘\n\nAnswer: 195 ways ✓",
      "autoResize": true,
