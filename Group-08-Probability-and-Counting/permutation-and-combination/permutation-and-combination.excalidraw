    },
    {
      "id": "el_70",
      "type": "text",
      "x": 535,
      "y": 1894,
      "width": 274,
      "height": 260,
      "text": "LOGIC:\nStep 1: 12 books → 3 children (4 each)\nStep 2: 12C4 × 8C4 × 4C4\n  = 495 × 70 × 1 = 34650\n\nTRICK:\nNamed groups: n!/(r!)^k\nUnnamed piles: n!/[(r!)^k × k!]\n→ 34650/3! = 5775 (unnamed)\nChildren are named → 34650\n\n  12 books\n  ├─Child A: pick 4 → 12C4=495\n  ├─Child B: pick 4 → 8C4=70\n  └─Child C: rest 4 → 4C4=1\n  Total = 495×70×1 = 34650\n\nAnswer: 34650 ways ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7000,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 12 books → 3 children (4 each)\nStep 2: 12C4 × 8C4 × 4C4\n  = 495 × 70 × 1 = 34650\n\nTRICK:\nNamed groups: n!/(r!)^k\nUnnamed piles: n!/[(r!)^k × k!]\n→ 34650/3! = 5775 (unnamed)\nChildren are named → 34650\n\n  12 books\n  ├─Child A: pick 4 → 12C4=495\n  ├─Child B: pick 4 → 8C4=70\n  └─Child C: rest 4 → 4C4=1\n  Total = 495×70×1 = 34650\n\nAnswer: 34650 ways ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
