    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1468,
      "width": 260,
      "height": 216,
      "text": "LOGIC:\nStep 1: Pick 3 from 8M AND 2 from 5W\nStep 2: 8C3 × 5C2 = 56 × 10 = 560\n\nTRICK:\nAND = MULTIPLY, OR = ADD\n8C3 = (8×7×6)/6 = 56\n5C2 = (5×4)/2 = 10\nTotal = 56 × 10 = 560\n\n  8 Men──pick 3──>8C3=56\n           AND (×)        = 560\n  5 Women─pick 2──>5C2=10\n\nAnswer: 560 ways ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Pick 3 from 8M AND 2 from 5W\nStep 2: 8C3 × 5C2 = 56 × 10 = 560\n\nTRICK:\nAND = MULTIPLY, OR = ADD\n8C3 = (8×7×6)/6 = 56\n5C2 = (5×4)/2 = 10\nTotal = 56 × 10 = 560\n\n  8 Men──pick 3──>8C3=56\n           AND (×)        = 560\n  5 Women─pick 2──>5C2=10\n\nAnswer: 560 ways ✓",
      "autoResize": true,
      "lineHeight": 1.2,
