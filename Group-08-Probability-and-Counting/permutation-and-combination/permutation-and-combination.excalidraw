    {
      "id": "el_25",
      "type": "text",
      "x": 535,
      "y": 704,
      "width": 267,
      "height": 173,
      "text": "LOGIC:\nStep 1: 5 letters, pick & arrange 3\nStep 2: 5P3 = 5!/(5-3)! = 120/2 = 60\n\nTRICK:\nSlot method: fill slots left to right\n  ┌───┐┌───┐┌───┐\n  │ 5 ││ 4 ││ 3 │ = 60\n  └───┘└───┘└───┘\n  1st  2nd  3rd\n\nAnswer: 60 ways ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2500,
      "version": 1,
      "versionNonce": 25,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
