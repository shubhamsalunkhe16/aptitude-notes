    {
      "id": "el_50",
      "type": "text",
      "x": 65,
      "y": 1468,
      "width": 245,
      "height": 231,
      "text": "LOGIC:\nStep 1: Fix 1 person, arrange rest\nStep 2: (n-1)! = 5! = 120\n\nTRICK:\nCircular = (n-1)! always\nWHY: rotations are same\nABCDEF = BCDEFA = CDEFAB...\nLine: n! | Circle: (n-1)!\n\n     A\n   F   B\n   E   C\n     D\n\nAnswer: 120 ways ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5000,
      "version": 1,
      "versionNonce": 50,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Fix 1 person, arrange rest\nStep 2: (n-1)! = 5! = 120\n\nTRICK:\nCircular = (n-1)! always\nWHY: rotations are same\nABCDEF = BCDEFA = CDEFAB...\nLine: n! | Circle: (n-1)!\n\n     A\n   F   B\n   E   C\n     D\n\nAnswer: 120 ways ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
