    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 688,
      "width": 245,
      "height": 216,
      "text": "LOGIC:\nStep 1: 8!/6! = (8×7×6!)/6!\nStep 2: Cancel 6! → 8×7 = 56\n\nTRICK:\nn!/k! = product of top (n-k) terms\n8!/6! → top 2 terms = 8×7 = 56\n10!/8! = 10×9 = 90\n\n  8! = 8×7×[6!]\n        ──── cancel\n  6! =     [6!]\n  Result = 8×7 = 56\n\nAnswer: 56 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 8!/6! = (8×7×6!)/6!\nStep 2: Cancel 6! → 8×7 = 56\n\nTRICK:\nn!/k! = product of top (n-k) terms\n8!/6! → top 2 terms = 8×7 = 56\n10!/8! = 10×9 = 90\n\n  8! = 8×7×[6!]\n        ──── cancel\n  6! =     [6!]\n  Result = 8×7 = 56\n\nAnswer: 56 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
