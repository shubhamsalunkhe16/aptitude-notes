    },
    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 704,
      "width": 296,
      "height": 216,
      "text": "LOGIC:\nStep 1: Select 3 from 7, order irrelevant\nStep 2: 7C3 = 7!/(3!×4!)\n  = (7×6×5)/(3×2×1) = 35\n\nTRICK:\nnCr = multiply top r terms / r!\n7C3 = (7×6×5)/6 = 35\nOR: 7C3 = 7C4 (complement)\n\n  7 people: A B C D E F G\n  Pick 3 → {A,B,C} = {C,A,B}\n  Order irrelevant → divide by 3!=6\n\nAnswer: 35 ways ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Select 3 from 7, order irrelevant\nStep 2: 7C3 = 7!/(3!×4!)\n  = (7×6×5)/(3×2×1) = 35\n\nTRICK:\nnCr = multiply top r terms / r!\n7C3 = (7×6×5)/6 = 35\nOR: 7C3 = 7C4 (complement)\n\n  7 people: A B C D E F G\n  Pick 3 → {A,B,C} = {C,A,B}\n  Order irrelevant → divide by 3!=6\n\nAnswer: 35 ways ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
