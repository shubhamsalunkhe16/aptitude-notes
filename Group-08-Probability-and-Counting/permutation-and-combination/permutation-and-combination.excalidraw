    {
      "id": "el_68",
      "type": "text",
      "x": 535,
      "y": 1829,
      "width": 801,
      "height": 33,
      "text": "In how many ways can 12 books be divided equally among 3\nchildren?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6800,
      "version": 1,
      "versionNonce": 68,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "In how many ways can 12 books be divided equally among 3\nchildren?",
      "autoResize": true,
