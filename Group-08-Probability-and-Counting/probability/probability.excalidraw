    {
      "id": "el_24",
      "type": "text",
      "x": 65,
      "y": 467,
      "width": 801,
      "height": 49,
      "text": "A bag contains 4 red, 3 blue, and 5 green balls. If one\nball is drawn at random, what is the probability that it\nis blue?",
      "fontSize": 13,
      "fontFamily": 1,
