    {
      "id": "el_96",
      "type": "text",
      "x": 1005,
      "y": 2028,
      "width": 245,
      "height": 216,
      "text": "LOGIC:\nStep 1: Circle area = 9pi\n  Square area = 100\nStep 2: P = 9pi/100 = 0.2827\n\nTRICK:\nP = favorable area / total area\nInscribed circle (r=s/2): P = pi/4\n\n  ┌──────────────┐\n  │  (  . . .  ) │ Circle r=3\n  │              │\n  └──────────────┘ Square = 100\n\nAnswer: P = 9pi/100 ~ 0.283 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 9600,
      "version": 1,
      "versionNonce": 96,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_15"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Circle area = 9pi\n  Square area = 100\nStep 2: P = 9pi/100 = 0.2827\n\nTRICK:\nP = favorable area / total area\nInscribed circle (r=s/2): P = pi/4\n\n  ┌──────────────┐\n  │  (  . . .  ) │ Circle r=3\n  │              │\n  └──────────────┘ Square = 100\n\nAnswer: P = 9pi/100 ~ 0.283 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
