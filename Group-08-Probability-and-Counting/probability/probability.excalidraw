      "type": "text",
      "x": 535,
      "y": 1207,
      "width": 830,
      "height": 49,
      "text": "Two dice are thrown. Given that the sum is greater than 7,\nwhat is the probability that both dice show a number\ngreater than or equal to 5?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
