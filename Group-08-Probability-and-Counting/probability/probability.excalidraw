    {
      "id": "el_89",
      "type": "text",
      "x": 535,
      "y": 1931,
      "width": 801,
      "height": 33,
      "text": "In a group of 23 people, what is the probability that at\nleast 2 people share the same birthday?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
