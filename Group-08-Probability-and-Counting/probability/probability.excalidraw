    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 281,
      "height": 78,
      "text": "P(A or B) = P(A) + P(B) - P(A and B)\nP(A ∪ B)  = P(A) + P(B) - P(A ∩ B)\n\nMutually Exclusive: P(A ∩ B) = 0\n  -> P(A ∪ B) = P(A) + P(B)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "P(A or B) = P(A) + P(B) - P(A and B)\nP(A ∪ B)  = P(A) + P(B) - P(A ∩ B)\n\nMutually Exclusive: P(A ∩ B) = 0\n  -> P(A ∪ B) = P(A) + P(B)",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
