    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 351,
      "height": 78,
      "text": "P(E) = Favorable outcomes / Total outcomes\n\n0 <= P(E) <= 1\nP(certain) = 1, P(impossible) = 0\nSample space S = set of all possible outcomes",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
