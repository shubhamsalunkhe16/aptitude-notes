    },
    {
      "id": "el_61",
      "type": "text",
      "x": 535,
      "y": 1288,
      "width": 252,
      "height": 188,
      "text": "LOGIC:\nStep 1: B=sum>7 → 15 outcomes of 36\n  A∩B = both>=5 AND sum>7\n  = (5,5)(5,6)(6,5)(6,6) = 4\nStep 2: P(A|B) = 4/15\n\nTRICK:\nP(A|B) = P(A∩B)/P(B)\nNew sample space = given condition\nJust count within reduced space\n= 4/15\n\nAnswer: P(both>=5 | sum>7) = 4/15 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6100,
      "version": 1,
      "versionNonce": 61,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: B=sum>7 → 15 outcomes of 36\n  A∩B = both>=5 AND sum>7\n  = (5,5)(5,6)(6,5)(6,6) = 4\nStep 2: P(A|B) = 4/15\n\nTRICK:\nP(A|B) = P(A∩B)/P(B)\nNew sample space = given condition\nJust count within reduced space\n= 4/15\n\nAnswer: P(both>=5 | sum>7) = 4/15 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
