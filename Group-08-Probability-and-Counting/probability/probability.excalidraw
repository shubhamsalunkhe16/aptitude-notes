    {
      "id": "el_91",
      "type": "text",
      "x": 535,
      "y": 1996,
      "width": 267,
      "height": 173,
      "text": "LOGIC:\nStep 1: P(all diff) for 23 people\n  = 365/365 × 364/365 × ... × 343/365\n  = 0.493\nStep 2: P(shared) = 1-0.493 = 0.507\n\nTRICK:\nBirthday Paradox: only 23 for >50%!\nn:  23→50.7%  30→70.6%  50→97%\nP(all diff) = 365!/(365^n × (365-n)!)\n\nAnswer: P(shared bday) = 50.7% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 9100,
      "version": 1,
      "versionNonce": 91,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_14"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: P(all diff) for 23 people\n  = 365/365 × 364/365 × ... × 343/365\n  = 0.493\nStep 2: P(shared) = 1-0.493 = 0.507\n\nTRICK:\nBirthday Paradox: only 23 for >50%!\nn:  23→50.7%  30→70.6%  50→97%\nP(all diff) = 365!/(365^n × (365-n)!)\n\nAnswer: P(shared bday) = 50.7% ✓",
      "autoResize": true,
