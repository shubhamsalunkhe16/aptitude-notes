      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f3"
      ],
      "containerId": null,
      "originalText": "P(not A) = 1 - P(A)\nP(at least 1) = 1 - P(none)\n\nConditional: P(A|B) = P(A ∩ B) / P(B)\nBayes: P(A|B) = P(B|A).P(A) / P(B)",
      "autoResize": true,
