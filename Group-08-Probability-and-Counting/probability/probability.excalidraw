    },
    {
      "id": "el_56",
      "type": "text",
      "x": 65,
      "y": 1272,
      "width": 267,
      "height": 159,
      "text": "LOGIC:\nStep 1: P(all tails) = (1/2)³ = 1/8\nStep 2: P(at least 1H) = 1-1/8 = 7/8\n\nTRICK:\nAt least 1 = 1 - P(none)\nP(none) = (1/2)^n for coins\n= 1 - (1/2)³ = 7/8\n(never calculate all cases directly!)\n\nAnswer: P(at least 1H) = 7/8 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5600,
      "version": 1,
      "versionNonce": 56,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: P(all tails) = (1/2)³ = 1/8\nStep 2: P(at least 1H) = 1-1/8 = 7/8\n\nTRICK:\nAt least 1 = 1 - P(none)\nP(none) = (1/2)^n for coins\n= 1 - (1/2)³ = 7/8\n(never calculate all cases directly!)\n\nAnswer: P(at least 1H) = 7/8 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
