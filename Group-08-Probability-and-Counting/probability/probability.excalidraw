    {
      "id": "el_20",
      "type": "text",
      "x": 1005,
      "y": 278,
      "width": 305,
      "height": 78,
      "text": "Odds in favor  = P(E) : P(E') = a : b\nOdds against   = P(E') : P(E) = b : a\nIf odds = a:b -> P(E) = a/(a+b)\n\nExpected Value E(X) = Sum[x_i . P(x_i)]",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
