    {
      "id": "el_49",
      "type": "text",
      "x": 1005,
      "y": 837,
      "width": 816,
      "height": 49,
      "text": "A coin is tossed and a die is rolled simultaneously. What\nis the probability of getting a Head on the coin and a 6\non the die?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4900,
      "version": 1,
      "versionNonce": 49,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "A coin is tossed and a die is rolled simultaneously. What\nis the probability of getting a Head on the coin and a 6\non the die?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
