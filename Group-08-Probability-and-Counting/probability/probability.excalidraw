        "type_1"
      ],
      "containerId": null,
      "originalText": "A bag contains 4 red, 3 blue, and 5 green balls. If one\nball is drawn at random, what is the probability that it\nis blue?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_25",
      "type": "text",
      "x": 65,
      "y": 526,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
