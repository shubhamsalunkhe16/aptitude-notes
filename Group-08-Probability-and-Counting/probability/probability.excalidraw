    {
      "id": "el_76",
      "type": "text",
      "x": 535,
      "y": 1642,
      "width": 252,
      "height": 159,
      "text": "LOGIC:\nStep 1: All H = (1/2)^5 = 1/32\n  All T = (1/2)^5 = 1/32\nStep 2: P = 1/32+1/32 = 2/32 = 1/16\n\nTRICK:\nP(all same) = 2/2^n = 1/2^(n-1)\n= 1/2^4 = 1/16\nFor dice: 6/6^k = 1/6^(k-1)\n\nAnswer: P(all same) = 1/16 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7600,
      "version": 1,
      "versionNonce": 76,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: All H = (1/2)^5 = 1/32\n  All T = (1/2)^5 = 1/32\nStep 2: P = 1/32+1/32 = 2/32 = 1/16\n\nTRICK:\nP(all same) = 2/2^n = 1/2^(n-1)\n= 1/2^4 = 1/16\nFor dice: 6/6^k = 1/6^(k-1)\n\nAnswer: P(all same) = 1/16 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
