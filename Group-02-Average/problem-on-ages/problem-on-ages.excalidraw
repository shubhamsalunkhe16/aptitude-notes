    {
      "id": "el_35",
      "type": "text",
      "x": 65,
      "y": 1211,
      "width": 267,
      "height": 231,
      "text": "LOGIC:\nStep 1: F=4S, F+6=3(S+6)\nStep 2: 4S+6=3S+18 → S=12\nStep 3: F=4x12=48\n\n  |←── NOW ──|── +6 yrs ──→|\n  F:  48 (4x) →  54 (3x)\n  S:  12      →  18\n  Ratio shrinks: 4:1 → 3:1\n\nTRICK:\nDiff = F-S = 3S (constant)\nAfter 6: F-S still=36\nF+6=3(S+6) → S=12, F=48\n\nAnswer: Father = 48, Son = 12 years ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3500,
      "version": 1,
      "versionNonce": 35,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: F=4S, F+6=3(S+6)\nStep 2: 4S+6=3S+18 → S=12\nStep 3: F=4x12=48\n\n  |←── NOW ──|── +6 yrs ──→|\n  F:  48 (4x) →  54 (3x)\n  S:  12      →  18\n  Ratio shrinks: 4:1 → 3:1\n\nTRICK:\nDiff = F-S = 3S (constant)\nAfter 6: F-S still=36\nF+6=3(S+6) → S=12, F=48\n\nAnswer: Father = 48, Son = 12 years ✓",
      "autoResize": true,
