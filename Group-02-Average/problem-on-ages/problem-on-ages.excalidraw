    {
      "id": "el_70",
      "type": "text",
      "x": 535,
      "y": 2052,
      "width": 238,
      "height": 260,
      "text": "LOGIC:\nStep 1: M=D+24\nStep 2: M+6=2(D+6) → D+30=2D+12\nStep 3: D=18, M=42\n\n  |← D born →| NOW    |── +6 ──→|\n  M: 24        42       48 (2x)\n  D:  0        18       24\n  Diff = 24 always (= M at birth)\n\nTRICK:\nDiff=24 (constant)\nAfter 6: M+6=2(D+6)\nD+24+6=2D+12 → D=18\nMother was 24 at daughter's birth\nCheck: 48=2x24 ✓\n\nAnswer: Daughter = 18 years ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7000,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: M=D+24\nStep 2: M+6=2(D+6) → D+30=2D+12\nStep 3: D=18, M=42\n\n  |← D born →| NOW    |── +6 ──→|\n  M: 24        42       48 (2x)\n  D:  0        18       24\n  Diff = 24 always (= M at birth)\n\nTRICK:\nDiff=24 (constant)\nAfter 6: M+6=2(D+6)\nD+24+6=2D+12 → D=18\nMother was 24 at daughter's birth\nCheck: 48=2x24 ✓\n\nAnswer: Daughter = 18 years ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
