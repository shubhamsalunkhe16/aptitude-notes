    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 814,
      "width": 267,
      "height": 216,
      "text": "LOGIC:\nStep 1: F+S=56, F+4=3(S+4)\nStep 2: F=3S+8, substitute: 3S+8+S=56\nStep 3: 4S=48 → S=12, F=44\n\n  NOW: F=44, S=12 (sum=56)\n  |── +4 yrs ──→| F=48, S=16\n  48 = 3 x 16 ✓ (3 times)\n\nTRICK:\nFrom F+4=3(S+4): F=3S+8\nF+S=56 → 4S+8=56 → S=12\nCheck: 48=3x16 ✓\n\nAnswer: Father = 44, Son = 12 years ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: F+S=56, F+4=3(S+4)\nStep 2: F=3S+8, substitute: 3S+8+S=56\nStep 3: 4S=48 → S=12, F=44\n\n  NOW: F=44, S=12 (sum=56)\n  |── +4 yrs ──→| F=48, S=16\n  48 = 3 x 16 ✓ (3 times)\n\nTRICK:\nFrom F+4=3(S+4): F=3S+8\nF+S=56 → 4S+8=56 → S=12\nCheck: 48=3x16 ✓\n\nAnswer: Father = 44, Son = 12 years ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
