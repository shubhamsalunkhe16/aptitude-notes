    {
      "id": "el_60",
      "type": "text",
      "x": 1005,
      "y": 1625,
      "width": 260,
      "height": 245,
      "text": "LOGIC:\nStep 1: E-Y=20, E-5=3(Y-5)\nStep 2: E=3Y-10, substitute:\n  3Y-10-Y=20 → Y=15, E=35\n\n  |←── 5 ago ──| NOW |\n  E:  30 (3x)    35\n  Y:  10          15\n  Diff: 20         20 (constant!)\n\nTRICK:\nDiff always=20 (constant)\nE=Y+20, substitute in 2nd eqn:\nY+20-5=3(Y-5) → Y=15, E=35\nCheck: 30=3x10 ✓\n\nAnswer: Elder=35, Younger=15 years ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6000,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: E-Y=20, E-5=3(Y-5)\nStep 2: E=3Y-10, substitute:\n  3Y-10-Y=20 → Y=15, E=35\n\n  |←── 5 ago ──| NOW |\n  E:  30 (3x)    35\n  Y:  10          15\n  Diff: 20         20 (constant!)\n\nTRICK:\nDiff always=20 (constant)\nE=Y+20, substitute in 2nd eqn:\nY+20-5=3(Y-5) → Y=15, E=35\nCheck: 30=3x10 ✓\n\nAnswer: Elder=35, Younger=15 years ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
