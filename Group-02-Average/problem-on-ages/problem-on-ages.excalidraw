      "type": "text",
      "x": 535,
      "y": 1146,
      "width": 830,
      "height": 49,
      "text": "The average age of a family of 4 members is 25 years. A\nbaby is born and the average age drops to 21. Find the age\nof the baby.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
