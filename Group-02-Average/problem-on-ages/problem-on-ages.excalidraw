    {
      "id": "el_65",
      "type": "text",
      "x": 65,
      "y": 2036,
      "width": 281,
      "height": 245,
      "text": "LOGIC:\nStep 1: A=3k, B=5k, C=7k\nStep 2: 15k=60 → k=4\nStep 3: A=12, B=20, C=28\n\n  A: |████████ 12       (3 parts)\n  B: |██████████████ 20  (5 parts)\n  C: |████████████████████ 28 (7 parts)\n     Sum = 60, k = 60/15 = 4\n\nTRICK:\nk = Sum / (ratio sum)\n= 60/15 = 4\nA=3x4=12, B=5x4=20, C=7x4=28\nCHECK: 12+20+28=60 ✓\n\nAnswer: A=12, B=20, C=28 years ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6500,
      "version": 1,
      "versionNonce": 65,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A=3k, B=5k, C=7k\nStep 2: 15k=60 → k=4\nStep 3: A=12, B=20, C=28\n\n  A: |████████ 12       (3 parts)\n  B: |██████████████ 20  (5 parts)\n  C: |████████████████████ 28 (7 parts)\n     Sum = 60, k = 60/15 = 4\n\nTRICK:\nk = Sum / (ratio sum)\n= 60/15 = 4\nA=3x4=12, B=5x4=20, C=7x4=28\nCHECK: 12+20+28=60 ✓\n\nAnswer: A=12, B=20, C=28 years ✓",
      "autoResize": true,
