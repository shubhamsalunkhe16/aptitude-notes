      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "The average age of a family of 4 members is 25 years. A\nbaby is born and the average age drops to 21. Find the age\nof the baby.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_39",
      "type": "text",
      "x": 535,
      "y": 1205,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
