      "type": "text",
      "x": 1005,
      "y": 1971,
      "width": 830,
      "height": 49,
      "text": "The age of a man is 1/3 more than his wife's age. The wife\nis 8 years older than her son aged 16. What is the man's\nage?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
