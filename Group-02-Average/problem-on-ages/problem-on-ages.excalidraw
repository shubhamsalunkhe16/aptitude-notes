    {
      "id": "el_75",
      "type": "text",
      "x": 1005,
      "y": 2052,
      "width": 281,
      "height": 202,
      "text": "LOGIC:\nStep 1: Son=16, Wife=16+8=24\nStep 2: Man = 24 + 24/3 = 24+8 = 32\n\n  Son=16 → Wife=16+8=24 → Man=24×4/3=32\n  |──16──|──+8──|──24──|──+8──|──32──|\n\nTRICK:\n1/3 MORE means x(4/3)\nMan = 24 x 4/3 = 32\nTRAP: 1/3 more ≠ 1/3 of!\n1/3 more = multiply by 4/3\n\nAnswer: Man = 32 years ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7500,
      "version": 1,
      "versionNonce": 75,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Son=16, Wife=16+8=24\nStep 2: Man = 24 + 24/3 = 24+8 = 32\n\n  Son=16 → Wife=16+8=24 → Man=24×4/3=32\n  |──16──|──+8──|──24──|──+8──|──32──|\n\nTRICK:\n1/3 MORE means x(4/3)\nMan = 24 x 4/3 = 32\nTRAP: 1/3 more ≠ 1/3 of!\n1/3 more = multiply by 4/3\n\nAnswer: Man = 32 years ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
