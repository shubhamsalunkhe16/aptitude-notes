      "roundness": null
    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 814,
      "width": 296,
      "height": 231,
      "text": "LOGIC:\nStep 1: A=5k, B=3k, Diff=2k\nStep 2: 2k=12 → k=6\nStep 3: A=30, B=18\n\n  A: |████████████████████████████████ 30\n  B: |███████████████████ 18\n     |←─── diff = 12 ───→|\n\nTRICK:\nk = Diff/(ratio diff)\n= 12/(5-3) = 6\nA=5x6=30, B=3x6=18\nCHECK: 30:18=5:3, 30-18=12 ✓\n\nAnswer: A = 30, B = 18 years ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A=5k, B=3k, Diff=2k\nStep 2: 2k=12 → k=6\nStep 3: A=30, B=18\n\n  A: |████████████████████████████████ 30\n  B: |███████████████████ 18\n     |←─── diff = 12 ───→|\n\nTRICK:\nk = Diff/(ratio diff)\n= 12/(5-3) = 6\nA=5x6=30, B=3x6=18\nCHECK: 30:18=5:3, 30-18=12 ✓\n\nAnswer: A = 30, B = 18 years ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
