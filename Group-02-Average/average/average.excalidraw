    {
      "id": "el_56",
      "type": "text",
      "x": 65,
      "y": 1552,
      "width": 238,
      "height": 173,
      "text": "LOGIC:\nStep 1: Old sum = 11x36 = 396\nStep 2: New sum = 396-45+27 = 378\nStep 3: New avg = 378/11 = 34.36\n\nTRICK:\nChange in avg = (New-Old)/n\n= (27-45)/11 = -18/11 = -1.64\nNew avg = 36-1.64 = 34.36\nNo need to find total sum!\n\nAnswer: New Avg = 34.36 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5600,
      "version": 1,
      "versionNonce": 56,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Old sum = 11x36 = 396\nStep 2: New sum = 396-45+27 = 378\nStep 3: New avg = 378/11 = 34.36\n\nTRICK:\nChange in avg = (New-Old)/n\n= (27-45)/11 = -18/11 = -1.64\nNew avg = 36-1.64 = 34.36\nNo need to find total sum!\n\nAnswer: New Avg = 34.36 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
