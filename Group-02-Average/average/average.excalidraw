    {
      "id": "el_36",
      "type": "text",
      "x": 1005,
      "y": 797,
      "width": 260,
      "height": 159,
      "text": "LOGIC:\nStep 1: Count = 50-11+1 = 40 numbers\nStep 2: Sum = (11+50)x40/2 = 1220\nStep 3: Avg = 1220/40 = 30.5\n\nTRICK:\nAny AP: Avg = (First+Last)/2\n= (11+50)/2 = 30.5\nWorks for any consecutive/AP series!\n\nAnswer: Avg = 30.5 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
