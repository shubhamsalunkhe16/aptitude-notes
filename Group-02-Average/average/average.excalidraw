    {
      "id": "el_74",
      "type": "text",
      "x": 535,
      "y": 1885,
      "width": 415,
      "height": 33,
      "text": "The average of 5 numbers is 27. Four of the numbers are\n24, 26, 30, and 32. Find the fifth number.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7400,
      "version": 1,
      "versionNonce": 74,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "The average of 5 numbers is 27. Four of the numbers are\n24, 26, 30, and 32. Find the fifth number.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
