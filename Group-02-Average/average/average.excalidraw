    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 383,
      "height": 234,
      "text": "Average = Sum / n\nSum = Average × n\n\nIf each value +x → New Avg = Old Avg + x\nIf each value -x → New Avg = Old Avg - x\nIf each value ×k → New Avg = Old Avg × k\nIf each value /k → New Avg = Old Avg / k\n\nWHY: Average distributes total equally among all.\nIf you level out unequal items, average is that\nlevel.\n\nEx: 10,20,30 → Sum=60, Count=3\n  Avg = 60/3 = 20\n  Each +5 → New Avg = 20+5 = 25",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 500,
      "version": 1,
      "versionNonce": 5,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f0"
      ],
      "containerId": null,
      "originalText": "Average = Sum / n\nSum = Average × n\n\nIf each value +x → New Avg = Old Avg + x\nIf each value -x → New Avg = Old Avg - x\nIf each value ×k → New Avg = Old Avg × k\nIf each value /k → New Avg = Old Avg / k\n\nWHY: Average distributes total equally among all.\nIf you level out unequal items, average is that\nlevel.\n\nEx: 10,20,30 → Sum=60, Count=3\n  Avg = 60/3 = 20\n  Each +5 → New Avg = 20+5 = 25",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
