    {
      "id": "el_59",
      "type": "text",
      "x": 535,
      "y": 1487,
      "width": 415,
      "height": 49,
      "text": "A family of 5 members has an average age of 30 years. Two\nyears later a baby is born, and the new average age of the\n6-member family becomes 27 years. What is the baby's age?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5900,
      "version": 1,
      "versionNonce": 59,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "A family of 5 members has an average age of 30 years. Two\nyears later a baby is born, and the new average age of the\n6-member family becomes 27 years. What is the baby's age?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_60",
      "type": "text",
      "x": 535,
      "y": 1546,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#862e9c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6000,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_61",
      "type": "text",
      "x": 535,
      "y": 1568,
      "width": 281,
      "height": 173,
      "text": "LOGIC:\nStep 1: Sum then = 5x30 = 150\nStep 2: Sum now (no baby) = 150+5x2=160\nStep 3: Sum now (with baby) = 6x27=162\n  Baby = 162-160 = 2 years\n\nTRICK:\nAfter t yrs, avg increases by t\nOld avg now = 30+2 = 32\nBaby = 6x27 - 5x32 = 162-160 = 2\n\nAnswer: Baby = 2 years old ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6100,
      "version": 1,
      "versionNonce": 61,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Sum then = 5x30 = 150\nStep 2: Sum now (no baby) = 150+5x2=160\nStep 3: Sum now (with baby) = 6x27=162\n  Baby = 162-160 = 2 years\n\nTRICK:\nAfter t yrs, avg increases by t\nOld avg now = 30+2 = 32\nBaby = 6x27 - 5x32 = 162-160 = 2\n\nAnswer: Baby = 2 years old ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
