    {
      "id": "el_51",
      "type": "text",
      "x": 1005,
      "y": 1211,
      "width": 245,
      "height": 159,
      "text": "LOGIC:\nStep 1: Old sum = 8x65 = 520\nStep 2: New sum = 520-80 = 440\nStep 3: New avg = 440/7 = 62.86 kg\n\nTRICK:\nDrop from avg = (80-65)/7 = 15/7\nNew avg = 65 - 15/7 = 62.86\n(removed person was above avg)\n\nAnswer: New Avg = 62.86 kg ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5100,
      "version": 1,
      "versionNonce": 51,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
