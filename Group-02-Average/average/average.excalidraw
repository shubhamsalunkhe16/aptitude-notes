      "roundness": null
    },
    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 434,
      "width": 383,
      "height": 219,
      "text": "ADDED: New = NewAvg + n×(NewAvg-OldAvg)\n  (n = original count)\n\nREMOVED: Removed = OldAvg - n×(NewAvg-OldAvg)\n  (n = new count after removal)\n\nREPLACED: New-Old = n×(NewAvg-OldAvg)\n  (n = total count, unchanged)\n\nWHY: New member must cover its own share\nPLUS compensate the avg rise for all old members.\n\nEx: 4 people avg 25, new joins, avg→27\n  New = 27 + 4×(27-25) = 27+8 = 35",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1400,
      "version": 1,
      "versionNonce": 14,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f3"
      ],
      "containerId": null,
      "originalText": "ADDED: New = NewAvg + n×(NewAvg-OldAvg)\n  (n = original count)\n\nREMOVED: Removed = OldAvg - n×(NewAvg-OldAvg)\n  (n = new count after removal)\n\nREPLACED: New-Old = n×(NewAvg-OldAvg)\n  (n = total count, unchanged)\n\nWHY: New member must cover its own share\nPLUS compensate the avg rise for all old members.\n\nEx: 4 people avg 25, new joins, avg→27\n  New = 27 + 4×(27-25) = 27+8 = 35",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
