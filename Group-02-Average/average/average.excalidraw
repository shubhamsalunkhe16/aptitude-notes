    {
      "id": "el_31",
      "type": "text",
      "x": 535,
      "y": 829,
      "width": 267,
      "height": 216,
      "text": "LOGIC:\nStep 1: Sum = 30x60+20x70 = 3200\nStep 2: Avg = 3200/50 = 64\n\n    (30)         (20)\n     |             |\n    60            70\n     \\           /\n    Avg = 64\n\nTRICK:\nAlligation: 30/20 = (70-Avg)/(Avg-60)\n3/2 = (70-Avg)/(Avg-60) → Avg=64\n\nAnswer: Overall Avg = 64 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3100,
      "version": 1,
      "versionNonce": 31,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Sum = 30x60+20x70 = 3200\nStep 2: Avg = 3200/50 = 64\n\n    (30)         (20)\n     |             |\n    60            70\n     \\           /\n    Avg = 64\n\nTRICK:\nAlligation: 30/20 = (70-Avg)/(Avg-60)\n3/2 = (70-Avg)/(Avg-60) → Avg=64\n\nAnswer: Overall Avg = 64 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
