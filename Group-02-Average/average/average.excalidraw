    {
      "id": "el_29",
      "type": "text",
      "x": 535,
      "y": 748,
      "width": 415,
      "height": 49,
      "text": "In a class, 30 boys have an average score of 60 marks and\n20 girls have an average score of 70 marks. What is the\noverall average of the class?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
