    {
      "id": "el_81",
      "type": "text",
      "x": 1005,
      "y": 1966,
      "width": 252,
      "height": 159,
      "text": "LOGIC:\nStep 1: Old sum = 10x40 = 400\nStep 2: New sum = 11x45 = 495\nStep 3: Runs = 495-400 = 95\n\nTRICK:\nRuns = NewAvg + n x (NewAvg-OldAvg)\n= 45 + 10x(45-40) = 45+50 = 95\nNeeds 45 for self + 5x10 extra\n\nAnswer: Runs needed = 95 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8100,
      "version": 1,
      "versionNonce": 81,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Old sum = 10x40 = 400\nStep 2: New sum = 11x45 = 495\nStep 3: Runs = 495-400 = 95\n\nTRICK:\nRuns = NewAvg + n x (NewAvg-OldAvg)\n= 45 + 10x(45-40) = 45+50 = 95\nNeeds 45 for self + 5x10 extra\n\nAnswer: Runs needed = 95 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
