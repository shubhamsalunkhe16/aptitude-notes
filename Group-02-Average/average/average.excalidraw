    {
      "id": "el_69",
      "type": "text",
      "x": 65,
      "y": 1885,
      "width": 415,
      "height": 49,
      "text": "The average of 20 numbers is 35 and the average of another\n30 numbers is 45. What is the combined average of all 50\nnumbers?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6900,
      "version": 1,
      "versionNonce": 69,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "The average of 20 numbers is 35 and the average of another\n30 numbers is 45. What is the combined average of all 50\nnumbers?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_70",
      "type": "text",
      "x": 65,
      "y": 1944,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7000,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_71",
      "type": "text",
      "x": 65,
      "y": 1966,
      "width": 267,
      "height": 202,
      "text": "LOGIC:\nStep 1: Sum = 20x35+30x45 = 2050\nStep 2: Combined = 2050/50 = 41\n\n  Grp1(20,35)    Grp2(30,45)\n       \\            /\n     Combined: Avg=41\n\nTRICK:\nAlligation: n1/n2 = (A2-Avg)/(Avg-A1)\n20/30 = (45-41)/(41-35) = 4/6 ✓\nCloser to larger group's avg\n\nAnswer: Combined Avg = 41 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7100,
      "version": 1,
      "versionNonce": 71,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Sum = 20x35+30x45 = 2050\nStep 2: Combined = 2050/50 = 41\n\n  Grp1(20,35)    Grp2(30,45)\n       \\            /\n     Combined: Avg=41\n\nTRICK:\nAlligation: n1/n2 = (A2-Avg)/(Avg-A1)\n20/30 = (45-41)/(41-35) = 4/6 ✓\nCloser to larger group's avg\n\nAnswer: Combined Avg = 41 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
