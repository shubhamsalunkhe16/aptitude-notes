    {
      "id": "el_44",
      "type": "text",
      "x": 535,
      "y": 1146,
      "width": 415,
      "height": 49,
      "text": "The average age of 10 students is 15 years. A new student\njoins and the average becomes 16 years. What is the age of\nthe new student?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
