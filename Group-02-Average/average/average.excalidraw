    },
    {
      "id": "el_76",
      "type": "text",
      "x": 535,
      "y": 1950,
      "width": 267,
      "height": 159,
      "text": "LOGIC:\nStep 1: Sum needed = 27x5 = 135\nStep 2: Known sum = 24+26+30+32 = 112\nStep 3: Missing = 135-112 = 23\n\nTRICK:\nMissing = Total sum - Known sum\n= (Avg x n) - sum of known values\n= 135-112 = 23\n\nAnswer: Missing number = 23 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7600,
      "version": 1,
      "versionNonce": 76,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Sum needed = 27x5 = 135\nStep 2: Known sum = 24+26+30+32 = 112\nStep 3: Missing = 135-112 = 23\n\nTRICK:\nMissing = Total sum - Known sum\n= (Avg x n) - sum of known values\n= 135-112 = 23\n\nAnswer: Missing number = 23 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
