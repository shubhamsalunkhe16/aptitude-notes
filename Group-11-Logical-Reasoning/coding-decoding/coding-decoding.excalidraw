    {
      "id": "el_48",
      "type": "text",
      "x": 1005,
      "y": 1055,
      "width": 310,
      "height": 216,
      "text": "LOGIC:\nStep 1: H+S=27, E+V=27, L+O=27\nStep 2: L+O=27, O+L=27 -> all sum to 27\nStep 3: Mirror coding confirmed\n\n  H(8)<->S(19)  E(5)<->V(22)  L(12)<->O(15)\n  All pairs sum to 27 = Mirror!\n\n  W(23)->D(4) O(15)->L(12) R(18)->I(9)\n  L(12)->O(15) D(4)->W(23) = DLIOW\n\nTRICK:\nMirror is SELF-INVERSE: encode = decode!\n\nAnswer: DLIOW ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4800,
      "version": 1,
      "versionNonce": 48,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: H+S=27, E+V=27, L+O=27\nStep 2: L+O=27, O+L=27 -> all sum to 27\nStep 3: Mirror coding confirmed\n\n  H(8)<->S(19)  E(5)<->V(22)  L(12)<->O(15)\n  All pairs sum to 27 = Mirror!\n\n  W(23)->D(4) O(15)->L(12) R(18)->I(9)\n  L(12)->O(15) D(4)->W(23) = DLIOW\n\nTRICK:\nMirror is SELF-INVERSE: encode = decode!\n\nAnswer: DLIOW ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
