    {
      "id": "el_13",
      "type": "text",
      "x": 65,
      "y": 316,
      "width": 393,
      "height": 22,
      "text": "Common Shift Patterns",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 17,
      "strokeColor": "#7048e8",
