    {
      "id": "el_66",
      "type": "text",
      "x": 65,
      "y": 1815,
      "width": 830,
      "height": 33,
      "text": "In a certain coding system, if DARK is coded as D1R11, how\nwill the word LAMP be coded using the same rule?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
