    {
      "id": "el_41",
      "type": "text",
      "x": 535,
      "y": 990,
      "width": 816,
      "height": 49,
      "text": "In a coding system, each vowel is replaced by the next\nletter in the alphabet, and each consonant is replaced by\nthe previous letter. What is the code for BOARD?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
