    {
      "id": "el_78",
      "type": "text",
      "x": 1005,
      "y": 1896,
      "width": 339,
      "height": 188,
      "text": "LOGIC:\nStep 1: Reverse HELP -> PLEH\nStep 2: Shift +1 each: P->Q L->M E->F H->I\n\n  HELP  ──reverse──>  PLEH\n  P(+1)L(+1)E(+1)H(+1)\n  Q    M    F    I     = QMFI\n\nTRICK:\nFor uniform shift, order doesn't matter.\nYou can shift first then reverse (same result).\n\nAnswer: QMFI ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7800,
      "version": 1,
      "versionNonce": 78,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Reverse HELP -> PLEH\nStep 2: Shift +1 each: P->Q L->M E->F H->I\n\n  HELP  ──reverse──>  PLEH\n  P(+1)L(+1)E(+1)H(+1)\n  Q    M    F    I     = QMFI\n\nTRICK:\nFor uniform shift, order doesn't matter.\nYou can shift first then reverse (same result).\n\nAnswer: QMFI ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    }
