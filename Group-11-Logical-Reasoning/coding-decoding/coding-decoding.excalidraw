      "type": "text",
      "x": 1005,
      "y": 608,
      "width": 816,
      "height": 33,
      "text": "In a certain coding system, if CAT is coded as 24 and DOG\nis coded as 26, what is the code for PIG?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
