    {
      "id": "el_68",
      "type": "text",
      "x": 65,
      "y": 1880,
      "width": 360,
      "height": 274,
      "text": "LOGIC:\nStep 1: D->D(stay) A->1(pos) R->R(stay) K->11(pos)\nStep 2: Consonants stay as letters\nStep 3: Vowels replaced by position number\n\n  D    A    R    K\n  C    V    C    C     <- type\n  D    1    R    11    = D1R11\n  (V->pos number, C->stays)\n\n  L    A    M    P\n  C    V    C    C\n  L    1    M    P     = L1MP\n\nTRICK:\nSplit into vowels vs consonants.\nVowels -> position number, Consonants -> same\n\nAnswer: L1MP ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6800,
      "version": 1,
      "versionNonce": 68,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: D->D(stay) A->1(pos) R->R(stay) K->11(pos)\nStep 2: Consonants stay as letters\nStep 3: Vowels replaced by position number\n\n  D    A    R    K\n  C    V    C    C     <- type\n  D    1    R    11    = D1R11\n  (V->pos number, C->stays)\n\n  L    A    M    P\n  C    V    C    C\n  L    1    M    P     = L1MP\n\nTRICK:\nSplit into vowels vs consonants.\nVowels -> position number, Consonants -> same\n\nAnswer: L1MP ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
