    },
    {
      "id": "el_38",
      "type": "text",
      "x": 65,
      "y": 1055,
      "width": 281,
      "height": 231,
      "text": "LOGIC:\nStep 1: A->B(+1) P->Q(+1) P->Q(+1)\nStep 2: L->M(+1) E->F(+1)\nStep 3: All +1 uniform shift\n\n  A(+1)P(+1)P(+1)L(+1)E(+1)\n  B    Q    Q    M    F     = BQQMF ✓\n\n  M(+1)A(+1)N(+1)G(+1)O(+1)\n  N    B    O    H    P     = NBOHP\n\nTRICK:\nDecode the given pair FIRST, find rule.\nApply SAME rule to new word.\n\nAnswer: NBOHP ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3800,
      "version": 1,
      "versionNonce": 38,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A->B(+1) P->Q(+1) P->Q(+1)\nStep 2: L->M(+1) E->F(+1)\nStep 3: All +1 uniform shift\n\n  A(+1)P(+1)P(+1)L(+1)E(+1)\n  B    Q    Q    M    F     = BQQMF ✓\n\n  M(+1)A(+1)N(+1)G(+1)O(+1)\n  N    B    O    H    P     = NBOHP\n\nTRICK:\nDecode the given pair FIRST, find rule.\nApply SAME rule to new word.\n\nAnswer: NBOHP ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
