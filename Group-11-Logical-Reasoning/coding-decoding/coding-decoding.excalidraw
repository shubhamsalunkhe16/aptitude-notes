      "y": 1388,
      "width": 830,
      "height": 49,
      "text": "If '+' means multiplication, '-' means division, 'x' means\nsubtraction, and '/' means addition, what is the value of\n8+6-3x2/1?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
