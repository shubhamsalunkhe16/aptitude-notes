      "type": "text",
      "x": 65,
      "y": 990,
      "width": 787,
      "height": 33,
      "text": "In a certain coding system, if APPLE is coded as BQQMF,\nhow will the word MANGO be coded using the same rule?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
