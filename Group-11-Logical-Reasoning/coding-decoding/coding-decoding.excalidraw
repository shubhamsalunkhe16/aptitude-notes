    {
      "id": "el_73",
      "type": "text",
      "x": 535,
      "y": 1896,
      "width": 324,
      "height": 202,
      "text": "LOGIC:\nStep 1: B(2)+1=C, E(5)+2=G\nStep 2: S(19)+3=V, T(20)+4=X\n\n  B    E    S    T\n  +1   +2   +3   +4   <- position-based shift\n  C    G    V    X    = CGVX\n\nTRICK:\nDiffs increasing? Position-based shift!\n1st letter +1, 2nd +2, 3rd +3, ...\n(Variants: +1,+2,+3 or -1,-2,-3)\n\nAnswer: CGVX ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7300,
      "version": 1,
      "versionNonce": 73,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: B(2)+1=C, E(5)+2=G\nStep 2: S(19)+3=V, T(20)+4=X\n\n  B    E    S    T\n  +1   +2   +3   +4   <- position-based shift\n  C    G    V    X    = CGVX\n\nTRICK:\nDiffs increasing? Position-based shift!\n1st letter +1, 2nd +2, 3rd +3, ...\n(Variants: +1,+2,+3 or -1,-2,-3)\n\nAnswer: CGVX ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
