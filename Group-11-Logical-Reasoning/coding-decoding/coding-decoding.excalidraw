    {
      "id": "el_33",
      "type": "text",
      "x": 1005,
      "y": 673,
      "width": 310,
      "height": 202,
      "text": "LOGIC:\nStep 1: CAT: C(3)+A(1)+T(20) = 24 ✓\nStep 2: DOG: D(4)+O(15)+G(7) = 26 ✓\nStep 3: Rule = sum of positions\n\n  C(3) + A(1) + T(20) = 24\n  D(4) + O(15)+ G(7)  = 26\n  P(16)+ I(9) + G(7)  = [32]\n\nTRICK:\nWord -> Number? Try SUM of positions first!\n(Also check: product, sum+/-len, sum x2)\n\nAnswer: 32 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3300,
      "version": 1,
      "versionNonce": 33,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: CAT: C(3)+A(1)+T(20) = 24 ✓\nStep 2: DOG: D(4)+O(15)+G(7) = 26 ✓\nStep 3: Rule = sum of positions\n\n  C(3) + A(1) + T(20) = 24\n  D(4) + O(15)+ G(7)  = 26\n  P(16)+ I(9) + G(7)  = [32]\n\nTRICK:\nWord -> Number? Try SUM of positions first!\n(Also check: product, sum+/-len, sum x2)\n\nAnswer: 32 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
