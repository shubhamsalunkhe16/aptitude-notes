      "type": "text",
      "x": 1005,
      "y": 1815,
      "width": 816,
      "height": 49,
      "text": "In a coding system, the word is first reversed and then\neach letter is shifted forward by 1. What is the code for\nHELP?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7600,
