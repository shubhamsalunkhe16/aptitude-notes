    {
      "id": "el_63",
      "type": "text",
      "x": 1005,
      "y": 1779,
      "width": 353,
      "height": 260,
      "text": "LOGIC:\nStep 1: A+B=50, A=B+10\nStep 2: (B+10)+B=50 -> 2B=40 -> B=20, A=30\nStep 3: 5 yrs ago: A=25, B=15\nStep 4: Ratio = 25:15 = 5:3\n\n  Timeline:\n  5 yrs ago    Now\n  A: 25 ──────→ 30    diff=10\n  B: 15 ──────→ 20    (constant)\n  Ratio: 5:3\n\nTRICK:\nAge DIFFERENCE never changes!\nSum=50, Diff=10 -> A=(50+10)/2=30, B=(50-10)/2=20\nFormula: (S+D)/2 and (S-D)/2\n\nAnswer: Ratio = 5:3 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6300,
      "version": 1,
      "versionNonce": 63,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A+B=50, A=B+10\nStep 2: (B+10)+B=50 -> 2B=40 -> B=20, A=30\nStep 3: 5 yrs ago: A=25, B=15\nStep 4: Ratio = 25:15 = 5:3\n\n  Timeline:\n  5 yrs ago    Now\n  A: 25 ──────→ 30    diff=10\n  B: 15 ──────→ 20    (constant)\n  Ratio: 5:3\n\nTRICK:\nAge DIFFERENCE never changes!\nSum=50, Diff=10 -> A=(50+10)/2=30, B=(50-10)/2=20\nFormula: (S+D)/2 and (S-D)/2\n\nAnswer: Ratio = 5:3 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
