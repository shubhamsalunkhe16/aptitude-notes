    {
      "id": "el_56",
      "type": "text",
      "x": 535,
      "y": 1698,
      "width": 415,
      "height": 65,
      "text": "A team of 3 must be selected from P, Q, R, S, T, U. Rules:\nif P is selected then Q must be selected, R and S cannot\nboth be selected, and at least one of T or U must be\nincluded. How many valid teams are possible?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5600,
      "version": 1,
      "versionNonce": 56,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "A team of 3 must be selected from P, Q, R, S, T, U. Rules:\nif P is selected then Q must be selected, R and S cannot\nboth be selected, and at least one of T or U must be\nincluded. How many valid teams are possible?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_57",
      "type": "text",
      "x": 535,
      "y": 1773,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#862e9c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5700,
      "version": 1,
      "versionNonce": 57,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_58",
      "type": "text",
      "x": 535,
      "y": 1795,
      "width": 288,
      "height": 245,
      "text": "LOGIC:\nStep 1: Rules: P->Q, NOT(R+S), T or U\nStep 2: If P in -> Q in, 3rd from {T,U}\n  -> {P,Q,T} {P,Q,U}\nStep 3: P out -> pick 3 with T or U,\n  no R+S together\n\n  P ──→ Q (must follow)\n  R ──✗── S (cannot both)\n  T ──or── U (at least one)\n\nTRICK:\nConvert all rules to IF-THEN.\nCase-split on most constrained variable.\nP in: 2 teams. P out: 7 teams.\n\nAnswer: Total valid teams = 9 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5800,
      "version": 1,
      "versionNonce": 58,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Rules: P->Q, NOT(R+S), T or U\nStep 2: If P in -> Q in, 3rd from {T,U}\n  -> {P,Q,T} {P,Q,U}\nStep 3: P out -> pick 3 with T or U,\n  no R+S together\n\n  P ──→ Q (must follow)\n  R ──✗── S (cannot both)\n  T ──or── U (at least one)\n\nTRICK:\nConvert all rules to IF-THEN.\nCase-split on most constrained variable.\nP in: 2 teams. P out: 7 teams.\n\nAnswer: Total valid teams = 9 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
