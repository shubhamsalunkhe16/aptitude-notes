    {
      "id": "el_51",
      "type": "text",
      "x": 65,
      "y": 1698,
      "width": 415,
      "height": 49,
      "text": "If it rains, the ground gets wet. If the ground is wet,\nthe match gets cancelled. The match was not cancelled.\nWhat can you conclude?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5100,
      "version": 1,
      "versionNonce": 51,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "If it rains, the ground gets wet. If the ground is wet,\nthe match gets cancelled. The match was not cancelled.\nWhat can you conclude?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_52",
      "type": "text",
      "x": 65,
      "y": 1757,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5200,
      "version": 1,
      "versionNonce": 52,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_53",
      "type": "text",
      "x": 65,
      "y": 1779,
      "width": 317,
      "height": 202,
      "text": "LOGIC:\nStep 1: Rain->Wet->Cancelled (chain)\nStep 2: NOT Cancelled (given)\nStep 3: Contrapositive: ~Cancel->~Wet->~Rain\n\n  Rain ──→ Wet ──→ Cancelled\n  ~Rain ←─ ~Wet ←─ ~Cancelled (given)\n\nTRICK:\nContrapositive: reverse chain + negate ALL.\nA->B, ~B => ~A (Modus Tollens)\nINVALID: ~A->~B or B->A\n\nAnswer: It did NOT rain ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5300,
      "version": 1,
      "versionNonce": 53,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_7"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Rain->Wet->Cancelled (chain)\nStep 2: NOT Cancelled (given)\nStep 3: Contrapositive: ~Cancel->~Wet->~Rain\n\n  Rain ──→ Wet ──→ Cancelled\n  ~Rain ←─ ~Wet ←─ ~Cancelled (given)\n\nTRICK:\nContrapositive: reverse chain + negate ALL.\nA->B, ~B => ~A (Modus Tollens)\nINVALID: ~A->~B or B->A\n\nAnswer: It did NOT rain ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
