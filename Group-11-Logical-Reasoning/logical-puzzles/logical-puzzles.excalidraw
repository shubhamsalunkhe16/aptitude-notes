    {
      "id": "el_13",
      "type": "text",
      "x": 65,
      "y": 456,
      "width": 415,
      "height": 17,
      "text": "Argument & Cause-Effect Rules",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#7048e8",
