    },
    {
      "id": "el_33",
      "type": "text",
      "x": 1005,
      "y": 923,
      "width": 317,
      "height": 188,
      "text": "LOGIC:\nStep 1: P>Q and Q>T -> P>Q>T\nStep 2: T>R>S (given)\nStep 3: Merge: P>Q>T>R>S\n\n  P--→Q--→T--→R--→S\n  1st 2nd 3rd 4th 5th\n\nTRICK:\nFind the linking element (Q,T appear twice).\nChain through links to build full order.\n\nAnswer: P, Q, T, R, S ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3300,
      "version": 1,
      "versionNonce": 33,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: P>Q and Q>T -> P>Q>T\nStep 2: T>R>S (given)\nStep 3: Merge: P>Q>T>R>S\n\n  P--→Q--→T--→R--→S\n  1st 2nd 3rd 4th 5th\n\nTRICK:\nFind the linking element (Q,T appear twice).\nChain through links to build full order.\n\nAnswer: P, Q, T, R, S ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
