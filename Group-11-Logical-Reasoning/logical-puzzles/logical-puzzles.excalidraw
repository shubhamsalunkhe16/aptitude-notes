    {
      "id": "el_76",
      "type": "text",
      "x": 1005,
      "y": 2141,
      "width": 415,
      "height": 65,
      "text": "Statement A: \"The city banned plastic bags.\" Statement B:\n\"Shopkeepers started using cloth bags.\" What is the\ncause-and-effect relationship between these two\nstatements?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7600,
      "version": 1,
      "versionNonce": 76,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "Statement A: \"The city banned plastic bags.\" Statement B:\n\"Shopkeepers started using cloth bags.\" What is the\ncause-and-effect relationship between these two\nstatements?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_77",
      "type": "text",
      "x": 1005,
      "y": 2216,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7700,
      "version": 1,
      "versionNonce": 77,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_78",
      "type": "text",
      "x": 1005,
      "y": 2238,
      "width": 360,
      "height": 231,
      "text": "LOGIC:\nStep 1: A->B? Ban plastic -> cloth bags? YES ✓\nStep 2: B->A? Cloth bags -> ban? Not necessarily ✗\nStep 3: Time order: ban first, then alternative\n\n  A (Ban plastic) ──→ B (Use cloth bags)\n       cause              effect\n  [time: A happens first, B follows]\n\nTRICK:\nTest: Does A logically FORCE B to happen?\nCheck time order: cause always BEFORE effect.\n5 types: A->B, B->A, independent, common cause,\nboth effects of 3rd factor.\n\nAnswer: A is cause, B is effect ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7800,
      "version": 1,
      "versionNonce": 78,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A->B? Ban plastic -> cloth bags? YES ✓\nStep 2: B->A? Cloth bags -> ban? Not necessarily ✗\nStep 3: Time order: ban first, then alternative\n\n  A (Ban plastic) ──→ B (Use cloth bags)\n       cause              effect\n  [time: A happens first, B follows]\n\nTRICK:\nTest: Does A logically FORCE B to happen?\nCheck time order: cause always BEFORE effect.\n5 types: A->B, B->A, independent, common cause,\nboth effects of 3rd factor.\n\nAnswer: A is cause, B is effect ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    }
