    },
    {
      "id": "el_43",
      "type": "text",
      "x": 535,
      "y": 1352,
      "width": 317,
      "height": 245,
      "text": "LOGIC:\nStep 1: B=Tea -> B!=Coffee -> B!=Dog\nStep 2: Coffee->dog (linked pair)\nStep 3: A!=Cat, try A=Dog -> A=Coffee\nStep 4: C=Cat+Milk, B=Fish+Tea\n\n       Cat  Dog  Fish | Tea Cof Milk\n  A  |  x    ✓    x  |  x   ✓   x\n  B  |  x    x    ✓  |  ✓   x   x\n  C  |  ✓    x    x  |  x   x   ✓\n\nTRICK:\nUse elimination grid (cross off impossible).\nLinked pairs (coffee->dog) reduce 2 at once.\nSudoku rule: one per row, one per column.\n\nAnswer: Fish owner = B ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4300,
      "version": 1,
      "versionNonce": 43,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: B=Tea -> B!=Coffee -> B!=Dog\nStep 2: Coffee->dog (linked pair)\nStep 3: A!=Cat, try A=Dog -> A=Coffee\nStep 4: C=Cat+Milk, B=Fish+Tea\n\n       Cat  Dog  Fish | Tea Cof Milk\n  A  |  x    ✓    x  |  x   ✓   x\n  B  |  x    x    ✓  |  ✓   x   x\n  C  |  ✓    x    x  |  x   x   ✓\n\nTRICK:\nUse elimination grid (cross off impossible).\nLinked pairs (coffee->dog) reduce 2 at once.\nSudoku rule: one per row, one per column.\n\nAnswer: Fish owner = B ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
