    {
      "id": "el_36",
      "type": "text",
      "x": 65,
      "y": 1255,
      "width": 415,
      "height": 49,
      "text": "Among six people, B is taller than A who is taller than C,\nD is the tallest, and C is taller than E who is taller\nthan F. Who is the 3rd tallest?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3600,
