    {
      "id": "el_61",
      "type": "text",
      "x": 1005,
      "y": 1698,
      "width": 415,
      "height": 49,
      "text": "The sum of the ages of A and B is 50 years, and A is 10\nyears older than B. What was the ratio of their ages 5\nyears ago?",
