    {
      "id": "el_71",
      "type": "text",
      "x": 535,
      "y": 2141,
      "width": 415,
      "height": 65,
      "text": "Statement: \"Should schools go online-only?\" Three\narguments are given: (1) It saves travel time, (2) Not all\nstudents have internet access, (3) My friend prefers it.\nWhich arguments are strong and which are weak?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7100,
      "version": 1,
      "versionNonce": 71,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "Statement: \"Should schools go online-only?\" Three\narguments are given: (1) It saves travel time, (2) Not all\nstudents have internet access, (3) My friend prefers it.\nWhich arguments are strong and which are weak?",
      "autoResize": true,
      "lineHeight": 1.25,
