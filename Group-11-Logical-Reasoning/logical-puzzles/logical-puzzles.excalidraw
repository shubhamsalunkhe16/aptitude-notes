    {
      "id": "el_31",
      "type": "text",
      "x": 1005,
      "y": 826,
      "width": 415,
      "height": 65,
      "text": "Five students P, Q, R, S, T have different heights. P is\ntaller than Q, T is taller than R who is taller than S,\nand Q is taller than T. Arrange them from tallest to\nshortest.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3100,
      "version": 1,
      "versionNonce": 31,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
