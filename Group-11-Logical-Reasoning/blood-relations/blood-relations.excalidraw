    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 782,
      "width": 310,
      "height": 216,
      "text": "LOGIC:\nStep 1: Brother's wife = sister-in-law\nStep 2: Sister-in-law's son = brother's son\nStep 3: Brother's son = nephew\n\n  [-Reema] [+Brother] ═══ [-Wife]\n                │\n             [+Boy]\n\nTRICK:\nSimplify chain right-to-left:\nwife of brother = brother (same family)\nson of brother = Nephew\n\nAnswer: The boy is Reema's Nephew ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Brother's wife = sister-in-law\nStep 2: Sister-in-law's son = brother's son\nStep 3: Brother's son = nephew\n\n  [-Reema] [+Brother] ═══ [-Wife]\n                │\n             [+Boy]\n\nTRICK:\nSimplify chain right-to-left:\nwife of brother = brother (same family)\nson of brother = Nephew\n\nAnswer: The boy is Reema's Nephew ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
