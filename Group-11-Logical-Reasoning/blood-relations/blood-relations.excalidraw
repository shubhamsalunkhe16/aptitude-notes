    {
      "id": "el_73",
      "type": "text",
      "x": 1005,
      "y": 1909,
      "width": 816,
      "height": 49,
      "text": "In a family, P and Q are married. R is their son, S is\ntheir daughter, and T is R's brother. U is the wife of R.\nHow is U related to S?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7300,
      "version": 1,
      "versionNonce": 73,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "In a family, P and Q are married. R is their son, S is\ntheir daughter, and T is R's brother. U is the wife of R.\nHow is U related to S?",
