    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 312,
      "height": 203,
      "text": "Mother's husband = Father\nFather's wife = Mother\nBrother's/Sister's son = Nephew\nBrother's/Sister's daughter = Niece\nSon's wife = Daughter-in-law\nDaughter's husband = Son-in-law\nWife's brother = Brother-in-law\n\nWHY: Chains collapse to a single word.\n  Always simplify right-to-left.\n\nEx: \"Mother's brother's son\" = Cousin\n  Mother's brother = Uncle → Uncle's son",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "Mother's husband = Father\nFather's wife = Mother\nBrother's/Sister's son = Nephew\nBrother's/Sister's daughter = Niece\nSon's wife = Daughter-in-law\nDaughter's husband = Son-in-law\nWife's brother = Brother-in-law\n\nWHY: Chains collapse to a single word.\n  Always simplify right-to-left.\n\nEx: \"Mother's brother's son\" = Cousin\n  Mother's brother = Uncle → Uncle's son",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
