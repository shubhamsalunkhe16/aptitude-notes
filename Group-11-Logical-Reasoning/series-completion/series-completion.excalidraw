    {
      "id": "el_41",
      "type": "text",
      "x": 65,
      "y": 1070,
      "width": 303,
      "height": 245,
      "text": "LOGIC:\nStep 1: D1: 2, 6, 12, 20\nStep 2: D2: 4, 6, 8 -> AP with d=2\nStep 3: Next D2=10, D1=20+10=30\nStep 4: Next = 42+30 = 72\n\n  Row 0:  2    4   10   22   42   [72]\n  D1:       2    6   12   20   [30]\n  D2:         4    6    8   [10]\n  D3:           2    2   [2]  <- constant!\n\nTRICK:\nD3 constant = cubic series.\nKeep taking diffs until constant row.\nThen work back up to find next term.\n\nAnswer: 72 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4100,
      "version": 1,
      "versionNonce": 41,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: D1: 2, 6, 12, 20\nStep 2: D2: 4, 6, 8 -> AP with d=2\nStep 3: Next D2=10, D1=20+10=30\nStep 4: Next = 42+30 = 72\n\n  Row 0:  2    4   10   22   42   [72]\n  D1:       2    6   12   20   [30]\n  D2:         4    6    8   [10]\n  D3:           2    2   [2]  <- constant!\n\nTRICK:\nD3 constant = cubic series.\nKeep taking diffs until constant row.\nThen work back up to find next term.\n\nAnswer: 72 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
