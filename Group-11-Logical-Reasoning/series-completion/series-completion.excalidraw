    {
      "id": "el_61",
      "type": "text",
      "x": 535,
      "y": 1467,
      "width": 281,
      "height": 260,
      "text": "LOGIC:\nStep 1: 2+3=5, 3+5=8, 5+8=13, 8+13=21\nStep 2: Each term = sum of previous two\nStep 3: Next = 21+13 = 34\n\n  2   3   5   8   13   21   [34]\n  └─+─┘   |   |    |    |\n      └─+─┘   |    |    |\n          └─+─┘    |    |\n              └──+─┘    |\n                  └──+──┘ = 34\n\nTRICK:\nEach = prev + prev-prev? Fibonacci!\nWorks with ANY starting pair.\nF(n) = F(n-1) + F(n-2)\n\nAnswer: 34 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6100,
      "version": 1,
      "versionNonce": 61,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 2+3=5, 3+5=8, 5+8=13, 8+13=21\nStep 2: Each term = sum of previous two\nStep 3: Next = 21+13 = 34\n\n  2   3   5   8   13   21   [34]\n  └─+─┘   |   |    |    |\n      └─+─┘   |    |    |\n          └─+─┘    |    |\n              └──+─┘    |\n                  └──+──┘ = 34\n\nTRICK:\nEach = prev + prev-prev? Fibonacci!\nWorks with ANY starting pair.\nF(n) = F(n-1) + F(n-2)\n\nAnswer: 34 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
