    {
      "id": "el_63",
      "type": "text",
      "x": 65,
      "y": 2030,
      "width": 816,
      "height": 33,
      "text": "In a 200 metre race, A beats B by 4 seconds. If A runs at\n10 m/s, find B's speed.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
