    {
      "id": "el_68",
      "type": "text",
      "x": 535,
      "y": 2030,
      "width": 801,
      "height": 65,
      "text": "A and B start running from the same point on a 400 metre\ncircular track. A runs at 5 m/s and B at 3 m/s. When do\nthey first meet in (a) same direction and (b) opposite\ndirections?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6800,
      "version": 1,
      "versionNonce": 68,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "A and B start running from the same point on a 400 metre\ncircular track. A runs at 5 m/s and B at 3 m/s. When do\nthey first meet in (a) same direction and (b) opposite\ndirections?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_69",
      "type": "text",
      "x": 535,
      "y": 2105,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#2f9e44",
