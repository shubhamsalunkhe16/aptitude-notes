    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 844,
      "width": 303,
      "height": 202,
      "text": "LOGIC:\nStep 1: When A finishes 200m, B is at 170m\nStep 2: Same time → Speed ∝ Distance\n  Sa/Sb = 200/170 = 20/17\n\nTRICK:\nSa : Sb = D : (D-Lead) = 200:170 = 20:17\n\n  Start              Finish\n  |====================| A (200m)\n  |=================   | B (170m)\n                    30m behind\n\nAnswer: Speed ratio = 20:17 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: When A finishes 200m, B is at 170m\nStep 2: Same time → Speed ∝ Distance\n  Sa/Sb = 200/170 = 20/17\n\nTRICK:\nSa : Sb = D : (D-Lead) = 200:170 = 20:17\n\n  Start              Finish\n  |====================| A (200m)\n  |=================   | B (170m)\n                    30m behind\n\nAnswer: Speed ratio = 20:17 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
