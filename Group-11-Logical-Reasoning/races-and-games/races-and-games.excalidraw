    },
    {
      "id": "el_25",
      "type": "text",
      "x": 535,
      "y": 844,
      "width": 281,
      "height": 216,
      "text": "LOGIC:\nStep 1: B's time = A's time + 20 = 120s\nStep 2: B's speed = 1000/120 = 25/3 m/s\n\n  Time: |--100s--|---20s---|\n     A: |========| finish\n     B: |========|=========| finish\n        A done    B still running\n\nTRICK:\nBeaten by T sec → Tb = Ta + T\nSb = D / (Ta + T)\n= 1000/120 = 8.33 m/s\n\nAnswer: B's speed = 8.33 m/s ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2500,
      "version": 1,
      "versionNonce": 25,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: B's time = A's time + 20 = 120s\nStep 2: B's speed = 1000/120 = 25/3 m/s\n\n  Time: |--100s--|---20s---|\n     A: |========| finish\n     B: |========|=========| finish\n        A done    B still running\n\nTRICK:\nBeaten by T sec → Tb = Ta + T\nSb = D / (Ta + T)\n= 1000/120 = 8.33 m/s\n\nAnswer: B's speed = 8.33 m/s ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
