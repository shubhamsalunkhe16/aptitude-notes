    {
      "id": "el_73",
      "type": "text",
      "x": 1005,
      "y": 2030,
      "width": 801,
      "height": 65,
      "text": "A man, his wife and daughter worked in a garden. The man\nworked for 3 days, wife for 2 days and daughter for 4\ndays. Ratio of daily wages is Man:Wife:Daughter = 5:4:3.\nTotal earning is Rs.105. Find the daughter's daily wage.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7300,
      "version": 1,
      "versionNonce": 73,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "A man, his wife and daughter worked in a garden. The man\nworked for 3 days, wife for 2 days and daughter for 4\ndays. Ratio of daily wages is Man:Wife:Daughter = 5:4:3.\nTotal earning is Rs.105. Find the daughter's daily wage.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_74",
      "type": "text",
      "x": 1005,
      "y": 2105,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7400,
      "version": 1,
      "versionNonce": 74,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_75",
      "type": "text",
      "x": 1005,
      "y": 2127,
      "width": 274,
      "height": 274,
      "text": "LOGIC:\nStep 1: Total earning by each:\n  Man: 3×5x = 15x\n  Wife: 2×4x = 8x\n  Daughter: 4×3x = 12x\nStep 2: 15x+8x+12x = 105\n  35x = 105 → x = 3\nStep 3: Daughter = 3×3 = Rs.9/day\n\n  Person   Days  Rate  Units\n  Man       3  x  5  =  15x\n  Wife      2  x  4  =   8x\n  Daughter  4  x  3  =  12x\n  Total = 35x = 105 → x=3\n\nTRICK:\nDaily wage = rate × x = 3×3 = Rs.9\n\nAnswer: Daughter's daily wage = Rs.9 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7500,
      "version": 1,
      "versionNonce": 75,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Total earning by each:\n  Man: 3×5x = 15x\n  Wife: 2×4x = 8x\n  Daughter: 4×3x = 12x\nStep 2: 15x+8x+12x = 105\n  35x = 105 → x = 3\nStep 3: Daughter = 3×3 = Rs.9/day\n\n  Person   Days  Rate  Units\n  Man       3  x  5  =  15x\n  Wife      2  x  4  =   8x\n  Daughter  4  x  3  =  12x\n  Total = 35x = 105 → x=3\n\nTRICK:\nDaily wage = rate × x = 3×3 = Rs.9\n\nAnswer: Daughter's daily wage = Rs.9 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    }
