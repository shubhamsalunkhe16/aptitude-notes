    },
    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 844,
      "width": 353,
      "height": 245,
      "text": "LOGIC:\nStep 1: B was 35m behind when A finished\n  B covers 35m in 7 sec → Sb = 35/7 = 5 m/s\nStep 2: B's time = 200/5 = 40 sec\nStep 3: A's time = 40 - 7 = 33 sec\n\n  Start                  Finish\n  |========================| A (200m in 33s)\n  |====================    | B (165m when A done)\n                       35m |\n                       in 7s → Sb=5m/s\n\nTRICK:\nSb = Lead(m)/Lead(s) = 35/7 = 5 m/s\nTa = Tb - T = 40 - 7 = 33s\n\nAnswer: A's time = 33 seconds ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: B was 35m behind when A finished\n  B covers 35m in 7 sec → Sb = 35/7 = 5 m/s\nStep 2: B's time = 200/5 = 40 sec\nStep 3: A's time = 40 - 7 = 33 sec\n\n  Start                  Finish\n  |========================| A (200m in 33s)\n  |====================    | B (165m when A done)\n                       35m |\n                       in 7s → Sb=5m/s\n\nTRICK:\nSb = Lead(m)/Lead(s) = 35/7 = 5 m/s\nTa = Tb - T = 40 - 7 = 33s\n\nAnswer: A's time = 33 seconds ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
