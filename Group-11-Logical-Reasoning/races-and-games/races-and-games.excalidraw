    {
      "id": "el_23",
      "type": "text",
      "x": 535,
      "y": 779,
      "width": 801,
      "height": 33,
      "text": "In a 1 km race, A beats B by 20 seconds. If A's time for\nthe race is 100 seconds, what is B's speed?",
      "fontSize": 13,
