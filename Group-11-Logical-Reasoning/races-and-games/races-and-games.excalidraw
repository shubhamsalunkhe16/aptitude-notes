    {
      "id": "el_28",
      "type": "text",
      "x": 1005,
      "y": 779,
      "width": 816,
      "height": 33,
      "text": "In a 200 metre race, A beats B by 35 metres or 7 seconds.\nFind A's time over the course.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2800,
