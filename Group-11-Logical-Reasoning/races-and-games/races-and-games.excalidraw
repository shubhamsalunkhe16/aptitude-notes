    {
      "id": "el_33",
      "type": "text",
      "x": 65,
      "y": 1190,
      "width": 816,
      "height": 49,
      "text": "A runs 5/3 times as fast as B. If A gives B a start of 80\nmetres, how far must the winning post be so that A and B\nreach it at the same time?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
