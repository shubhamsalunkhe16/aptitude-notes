    },
    {
      "id": "el_65",
      "type": "text",
      "x": 65,
      "y": 1879,
      "width": 303,
      "height": 144,
      "text": "LOGIC:\nStep 1: 3 CW from N: N->E->S->W\nStep 2: 1 CCW from W: W->S\n\nTRICK:\nNet turns = CW - CCW = 3-1 = 2 right turns\nN + 2 right = N->E->S\nEach 4 net turns = full circle (cancel)\n\nAnswer: Facing SOUTH ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
