    {
      "id": "el_35",
      "type": "text",
      "x": 65,
      "y": 1039,
      "width": 238,
      "height": 231,
      "text": "LOGIC:\nStep 1: 5km N -> turn R(East) 3km\nStep 2: Turn R(South) 5km\nStep 3: y=+5-5=0, x=+3\n\n  A---3km E---B\n  |           |\n  5km N     5km S\n  |           |\n  START      FINAL\n\nTRICK:\nN and S cancel: 5-5=0 (y=0)\nOnly E remains: x=3km East\n\nAnswer: 3 km EAST of start ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3500,
      "version": 1,
      "versionNonce": 35,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 5km N -> turn R(East) 3km\nStep 2: Turn R(South) 5km\nStep 3: y=+5-5=0, x=+3\n\n  A---3km E---B\n  |           |\n  5km N     5km S\n  |           |\n  START      FINAL\n\nTRICK:\nN and S cancel: 5-5=0 (y=0)\nOnly E remains: x=3km East\n\nAnswer: 3 km EAST of start ✓",
      "autoResize": true,
