      "groupIds": [
        "f0"
      ],
      "containerId": null,
      "originalText": "8 Directions:\n  NW   N   NE        Cardinal: N, S, E, W (90° apart)\n    \\  |  /         Ordinal:  NE, NW, SE, SW (45°)\n  W --+-- E\n    /  |  \\         N=0°  E=90°  S=180°  W=270°\n  SW   S   SE       NE=45° SE=135° SW=225° NW=315°",
      "autoResize": true,
