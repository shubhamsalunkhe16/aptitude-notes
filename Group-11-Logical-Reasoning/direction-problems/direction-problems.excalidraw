    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 325,
      "width": 258,
      "height": 141,
      "text": "Distance = sqrt(x² + y²)\n  x = net East(+)/West(-)\n  y = net North(+)/South(-)\n\nTriplets: 3,4,5  5,12,13  8,15,17\n\nFinal direction from signs:\n  x>0,y>0=NE  x<0,y>0=NW\n  x>0,y<0=SE  x<0,y<0=SW",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1400,
      "version": 1,
      "versionNonce": 14,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f3"
      ],
      "containerId": null,
      "originalText": "Distance = sqrt(x² + y²)\n  x = net East(+)/West(-)\n  y = net North(+)/South(-)\n\nTriplets: 3,4,5  5,12,13  8,15,17\n\nFinal direction from signs:\n  x>0,y>0=NE  x<0,y>0=NW\n  x>0,y<0=SE  x<0,y<0=SW",
