    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1452,
      "width": 252,
      "height": 245,
      "text": "LOGIC:\nStep 1: dx = 8-4 = 4, dy = 1-3 = -2\nStep 2: d = sqrt(4^2 + 2^2)\n     = sqrt(16+4) = sqrt(20)\n\n  A(4,3)\n    |\\\n  2 | \\ d\n    |  \\\n    +--- B(8,1)\n     4\n\nTRICK:\nDistance formula: sqrt(dx^2 + dy^2)\n= sqrt(16+4) = 2*sqrt(5) ~ 4.47 km\n\nAnswer: 2sqrt(5) ~ 4.47 km apart ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: dx = 8-4 = 4, dy = 1-3 = -2\nStep 2: d = sqrt(4^2 + 2^2)\n     = sqrt(16+4) = sqrt(20)\n\n  A(4,3)\n    |\\\n  2 | \\ d\n    |  \\\n    +--- B(8,1)\n     4\n\nTRICK:\nDistance formula: sqrt(dx^2 + dy^2)\n= sqrt(16+4) = 2*sqrt(5) ~ 4.47 km\n\nAnswer: 2sqrt(5) ~ 4.47 km apart ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
