    {
      "id": "el_60",
      "type": "text",
      "x": 1005,
      "y": 1436,
      "width": 260,
      "height": 245,
      "text": "LOGIC:\nStep 1: A at (0,5), B at (5,0)\nStep 2: A relative to B:\n  dx=0-5=-5(West), dy=5-0=+5(North)\nStep 3: x<0,y>0 -> North-West\n\n     A(0,5)\n     |\n  5N |\n     |\n  START---5E---B(5,0)\n\nTRICK:\nSubtract B's coords from A's coords.\nSign tells quadrant: (-,+) = NW\n\nAnswer: A is NORTH-WEST of B ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6000,
      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A at (0,5), B at (5,0)\nStep 2: A relative to B:\n  dx=0-5=-5(West), dy=5-0=+5(North)\nStep 3: x<0,y>0 -> North-West\n\n     A(0,5)\n     |\n  5N |\n     |\n  START---5E---B(5,0)\n\nTRICK:\nSubtract B's coords from A's coords.\nSign tells quadrant: (-,+) = NW\n\nAnswer: A is NORTH-WEST of B ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
