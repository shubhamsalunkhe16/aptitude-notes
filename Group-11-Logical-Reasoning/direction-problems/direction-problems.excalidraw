    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 390,
      "height": 125,
      "text": "RIGHT = Clockwise 90°    LEFT = Anti-clockwise 90°\n\nRight cycle: N → E → S → W → N\nLeft  cycle: N → W → S → E → N\n\n180° turn = Opposite direction\n360° turn = Same direction\nFace N + Right = E    Face N + Left = W",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "RIGHT = Clockwise 90°    LEFT = Anti-clockwise 90°\n\nRight cycle: N → E → S → W → N\nLeft  cycle: N → W → S → E → N\n\n180° turn = Opposite direction\n360° turn = Same direction\nFace N + Right = E    Face N + Left = W",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
