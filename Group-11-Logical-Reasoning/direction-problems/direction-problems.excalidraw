    {
      "id": "el_25",
      "type": "text",
      "x": 535,
      "y": 626,
      "width": 245,
      "height": 231,
      "text": "LOGIC:\nStep 1: Facing East\nStep 2: Right = Clockwise 90°\nStep 3: E -> S (CW: N->E->S->W->N)\n\n       N\n  W ---+---> E (facing)\n       |   ↓ (right=CW)\n       S\n\nTRICK:\nRight cycle: N->E->S->W->N\nLeft cycle:  N->W->S->E->N\nJust move one step in the cycle.\n\nAnswer: Now facing SOUTH ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2500,
      "version": 1,
      "versionNonce": 25,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Facing East\nStep 2: Right = Clockwise 90°\nStep 3: E -> S (CW: N->E->S->W->N)\n\n       N\n  W ---+---> E (facing)\n       |   ↓ (right=CW)\n       S\n\nTRICK:\nRight cycle: N->E->S->W->N\nLeft cycle:  N->W->S->E->N\nJust move one step in the cycle.\n\nAnswer: Now facing SOUTH ✓",
      "autoResize": true,
