    {
      "id": "el_18",
      "type": "text",
      "x": 65,
      "y": 515,
      "width": 816,
      "height": 49,
      "text": "6 persons in a row facing North. B is 3rd from left. A is\nimmediately right of B. C is at extreme left. Who is 3rd\nfrom right?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1800,
      "version": 1,
      "versionNonce": 18,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "6 persons in a row facing North. B is 3rd from left. A is\nimmediately right of B. C is at extreme left. Who is 3rd\nfrom right?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
