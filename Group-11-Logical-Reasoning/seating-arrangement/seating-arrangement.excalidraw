    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 328,
      "height": 94,
      "text": "N persons in a line = N! arrangements\nPositions: LEFT to RIGHT = 1, 2, 3 ... N\n\nNth from right = position (Total - N + 1)\n\"Immediately left of B\" = position (B - 1)\n\"2nd to the left of B\" = position (B - 2)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 500,
      "version": 1,
      "versionNonce": 5,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f0"
      ],
      "containerId": null,
