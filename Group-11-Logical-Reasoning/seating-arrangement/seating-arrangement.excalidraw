    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 596,
      "width": 296,
      "height": 188,
      "text": "LOGIC:\nStep 1: B at pos 3, A right of B at pos 4\nStep 2: C at extreme left = pos 1\nStep 3: 3rd from right = (6-3+1) = pos 4\n\n  C  _  B  A  _  _\n  1  2  3  4  5  6\n\nTRICK:\nNth from right = (Total - N + 1)\n3rd from right = 6-3+1 = pos 4 = A\n\nAnswer: A is 3rd from the right ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: B at pos 3, A right of B at pos 4\nStep 2: C at extreme left = pos 1\nStep 3: 3rd from right = (6-3+1) = pos 4\n\n  C  _  B  A  _  _\n  1  2  3  4  5  6\n\nTRICK:\nNth from right = (Total - N + 1)\n3rd from right = 6-3+1 = pos 4 = A\n\nAnswer: A is 3rd from the right ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
