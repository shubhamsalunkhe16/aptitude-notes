    {
      "id": "el_70",
      "type": "text",
      "x": 535,
      "y": 1832,
      "width": 303,
      "height": 245,
      "text": "LOGIC:\nStep 1: A 4th CW from B -> pos 5\nStep 2: C 2nd Anti-CW from B -> pos 7\nStep 3: CW from A(5): 6, 7(=C)\nStep 4: 1 person between them\n\n     B(1)\n  (8)    (2)\n C(7)  o  (3)\n  (6)    (4)\n     A(5)\n\nTRICK:\nCount seats between (exclusive both ends).\nCW from A to C: 5->6->7, between=1\n\nAnswer: 1 person between A and C ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7000,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A 4th CW from B -> pos 5\nStep 2: C 2nd Anti-CW from B -> pos 7\nStep 3: CW from A(5): 6, 7(=C)\nStep 4: 1 person between them\n\n     B(1)\n  (8)    (2)\n C(7)  o  (3)\n  (6)    (4)\n     A(5)\n\nTRICK:\nCount seats between (exclusive both ends).\nCW from A to C: 5->6->7, between=1\n\nAnswer: 1 person between A and C ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
