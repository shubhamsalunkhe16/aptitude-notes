    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1405,
      "width": 281,
      "height": 231,
      "text": "LOGIC:\nStep 1: C opposite A -> pos 4 (A at 1)\nStep 2: D left(CW) of C -> pos 5\nStep 3: B NOT adjacent to A -> not 2,6\nStep 4: B not at 4(C) or 5(D) -> B at 3\n\n     A(1)\n  (6)    (2)\n  D(5)   B(3)\n     C(4)\n\nTRICK:\nEliminate: adjacent(2,6), occupied(4,5)\nOnly pos 3 left for B.\n\nAnswer: B is at Pos 3 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: C opposite A -> pos 4 (A at 1)\nStep 2: D left(CW) of C -> pos 5\nStep 3: B NOT adjacent to A -> not 2,6\nStep 4: B not at 4(C) or 5(D) -> B at 3\n\n     A(1)\n  (6)    (2)\n  D(5)   B(3)\n     C(4)\n\nTRICK:\nEliminate: adjacent(2,6), occupied(4,5)\nOnly pos 3 left for B.\n\nAnswer: B is at Pos 3 ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
