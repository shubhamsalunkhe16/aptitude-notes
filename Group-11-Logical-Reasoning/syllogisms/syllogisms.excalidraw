      "version": 1,
      "versionNonce": 60,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_61",
      "type": "text",
      "x": 535,
      "y": 1725,
      "width": 296,
      "height": 260,
      "text": "LOGIC:\nStep 1: A inside B, C overlaps B\nStep 2: C may or may not touch A\nStep 3: Neither I nor E is definite alone\n\n  ┌────────┐  ┌────┐\n  │B       │  │ C  │\n  │ ┌──┐   ├──┤    │\n  │ │A │   │XX│    │\n  │ └──┘   ├──┤    │\n  └────────┘  └────┘\n\nTRICK:\nWhen neither I nor E follows alone,\ncheck if they form complementary pair.\nI+E or A+O -> Either/Or.\n\nAnswer: Either/Or applies here ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6100,
      "version": 1,
      "versionNonce": 61,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A inside B, C overlaps B\nStep 2: C may or may not touch A\nStep 3: Neither I nor E is definite alone\n\n  ┌────────┐  ┌────┐\n  │B       │  │ C  │\n  │ ┌──┐   ├──┤    │\n  │ │A │   │XX│    │\n  │ └──┘   ├──┤    │\n  └────────┘  └────┘\n\nTRICK:\nWhen neither I nor E follows alone,\ncheck if they form complementary pair.\nI+E or A+O -> Either/Or.\n\nAnswer: Either/Or applies here ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
