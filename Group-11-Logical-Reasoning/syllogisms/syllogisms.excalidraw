    {
      "id": "el_64",
      "type": "text",
      "x": 1005,
      "y": 1644,
      "width": 415,
      "height": 33,
      "text": "Given the statement \"Some cats are dogs,\" is the\nconclusion \"All cats are dogs\" possible or definite?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6400,
      "version": 1,
      "versionNonce": 64,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "Given the statement \"Some cats are dogs,\" is the\nconclusion \"All cats are dogs\" possible or definite?",
      "autoResize": true,
