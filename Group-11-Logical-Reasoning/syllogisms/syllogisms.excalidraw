    {
      "id": "el_49",
      "type": "text",
      "x": 1005,
      "y": 1174,
      "width": 415,
      "height": 49,
      "text": "Given: All birds are animals, and no animals are stones.\nDoes the conclusion \"No birds are stones\" logically\nfollow?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
