    {
      "id": "el_39",
      "type": "text",
      "x": 65,
      "y": 1174,
      "width": 415,
      "height": 49,
      "text": "Given: All roses are flowers, and all flowers are plants.\nDoes the conclusion \"All roses are plants\" logically\nfollow?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
