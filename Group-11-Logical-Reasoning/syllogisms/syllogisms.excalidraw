    {
      "id": "el_59",
      "type": "text",
      "x": 535,
      "y": 1644,
      "width": 415,
      "height": 49,
      "text": "Given: All A are B, and some C are B. Does \"Some A are C\"\nfollow, or does \"No A are C\" follow, or do we apply the\nEither-Or rule?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5900,
      "version": 1,
      "versionNonce": 59,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "Given: All A are B, and some C are B. Does \"Some A are C\"\nfollow, or does \"No A are C\" follow, or do we apply the\nEither-Or rule?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
