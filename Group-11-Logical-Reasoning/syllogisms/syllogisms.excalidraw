      "versionNonce": 65,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_66",
      "type": "text",
      "x": 1005,
      "y": 1709,
      "width": 360,
      "height": 260,
      "text": "LOGIC:\nStep 1: \"Some\" allows partial or full overlap\nStep 2: Case 1: partial overlap (Some but not All)\nStep 3: Case 2: cats fully inside dogs (All)\n\n  Case 1:          Case 2:\n  ┌──┐  ┌──┐     ┌────────┐\n  │C ├──┤D │     │D ┌──┐ │\n  │  │XX│  │     │  │C │ │\n  └──┘  └──┘     │  └──┘ │\n                  └────────┘\n\nTRICK:\nPossible = exists in AT LEAST 1 valid case.\nDefinite = true in ALL valid cases.\nSome allows All -> so All is POSSIBLE.\n\nAnswer: All cats are dogs: possible ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6600,
      "version": 1,
      "versionNonce": 66,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_9"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: \"Some\" allows partial or full overlap\nStep 2: Case 1: partial overlap (Some but not All)\nStep 3: Case 2: cats fully inside dogs (All)\n\n  Case 1:          Case 2:\n  ┌──┐  ┌──┐     ┌────────┐\n  │C ├──┤D │     │D ┌──┐ │\n  │  │XX│  │     │  │C │ │\n  └──┘  └──┘     │  └──┘ │\n                  └────────┘\n\nTRICK:\nPossible = exists in AT LEAST 1 valid case.\nDefinite = true in ALL valid cases.\nSome allows All -> so All is POSSIBLE.\n\nAnswer: All cats are dogs: possible ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
