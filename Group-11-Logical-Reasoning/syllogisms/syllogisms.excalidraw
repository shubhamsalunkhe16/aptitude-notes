      "groupIds": [
        "traps"
      ],
      "containerId": null,
      "originalText": "COMMON TRAPS TO AVOID",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_84",
      "type": "text",
      "x": 65,
      "y": 2562,
      "width": 740,
      "height": 135,
      "text": "TRAP 1: \"All A are B\" does NOT mean \"All B are A\" — only \"Some B are A\" follows\nTRAP 2: \"Some A are not B\" (O-type) CANNOT be converted — no valid converse exists\nTRAP 3: Two particular premises (Some+Some) → NO definite conclusion ever\nTRAP 4: \"Only A are B\" means \"All B are A\" (REVERSE!) — not \"All A are B\"\nTRAP 5: Confusing POSSIBLE with DEFINITE — possible=CAN be true, definite=MUST be true\nTRAP 6: Forgetting Either-Or rule — if neither I nor E follows, check complementary pair\nTRAP 7: \"All A are B\" makes \"Some A are B\" DEFINITE, not just possible\nTRAP 8: Middle term not distributed (Some+Some, All+Some) → nothing definite follows",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 14,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8400,
      "version": 1,
      "versionNonce": 84,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "traps"
      ],
      "containerId": null,
      "originalText": "TRAP 1: \"All A are B\" does NOT mean \"All B are A\" — only \"Some B are A\" follows\nTRAP 2: \"Some A are not B\" (O-type) CANNOT be converted — no valid converse exists\nTRAP 3: Two particular premises (Some+Some) → NO definite conclusion ever\nTRAP 4: \"Only A are B\" means \"All B are A\" (REVERSE!) — not \"All A are B\"\nTRAP 5: Confusing POSSIBLE with DEFINITE — possible=CAN be true, definite=MUST be true\nTRAP 6: Forgetting Either-Or rule — if neither I nor E follows, check complementary pair\nTRAP 7: \"All A are B\" makes \"Some A are B\" DEFINITE, not just possible\nTRAP 8: Middle term not distributed (Some+Some, All+Some) → nothing definite follows",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
