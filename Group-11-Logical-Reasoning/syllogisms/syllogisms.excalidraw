      "width": 462,
      "height": 25,
      "text": "COMMON TRAPS TO AVOID",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 20,
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
