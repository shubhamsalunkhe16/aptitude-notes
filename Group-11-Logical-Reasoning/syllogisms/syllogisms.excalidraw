    {
      "id": "el_13",
      "type": "text",
      "x": 65,
      "y": 409,
      "width": 300,
      "height": 22,
      "text": "Conversion Rules",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 17,
      "strokeColor": "#7048e8",
      "backgroundColor": "transparent",
