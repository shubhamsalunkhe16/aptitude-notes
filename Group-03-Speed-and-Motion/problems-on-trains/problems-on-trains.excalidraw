    },
    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 657,
      "width": 310,
      "height": 216,
      "text": "LOGIC:\nStep 1: Pole has no length → D=train length\n  Speed = 150/15 = 10 m/s\nStep 2: Convert: 10 × 18/5 = 36 km/h\n\nTRICK:\nTrain→Pole: D=L only (pole=point)\nSpeed = L/T, then ×18/5 for km/h\n\n  ┌─────────────────┐\n  │  Train (150m)    │───→ S=?\n  └─────────────────┘\n           |  pole\n\nAnswer: 36 km/h ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Pole has no length → D=train length\n  Speed = 150/15 = 10 m/s\nStep 2: Convert: 10 × 18/5 = 36 km/h\n\nTRICK:\nTrain→Pole: D=L only (pole=point)\nSpeed = L/T, then ×18/5 for km/h\n\n  ┌─────────────────┐\n  │  Train (150m)    │───→ S=?\n  └─────────────────┘\n           |  pole\n\nAnswer: 36 km/h ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
