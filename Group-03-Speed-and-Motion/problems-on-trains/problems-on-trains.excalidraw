    {
      "id": "el_68",
      "type": "text",
      "x": 535,
      "y": 1786,
      "width": 787,
      "height": 65,
      "text": "Two trains running at 36 km/h and 54 km/h in opposite\ndirections cross each other in 10 seconds. If the first\ntrain is 100 meters long, find the length of the second\ntrain.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
