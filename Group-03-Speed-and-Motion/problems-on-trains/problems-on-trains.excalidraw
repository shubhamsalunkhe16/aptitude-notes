    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 372,
      "width": 258,
      "height": 125,
      "text": "Speed change → inverse time ratio\nS1:S2 = a:b → T1:T2 = b:a\n\nEqual trains cross pole T1,T2:\n  Opp: 2×T1×T2/(T1+T2)\n  Same: 2×T1×T2/(T1-T2)\n\nLate/Early → D=S1×S2×ΔT/(S2-S1)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1400,
      "version": 1,
      "versionNonce": 14,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f3"
      ],
      "containerId": null,
      "originalText": "Speed change → inverse time ratio\nS1:S2 = a:b → T1:T2 = b:a\n\nEqual trains cross pole T1,T2:\n  Opp: 2×T1×T2/(T1+T2)\n  Same: 2×T1×T2/(T1-T2)\n\nLate/Early → D=S1×S2×ΔT/(S2-S1)",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
