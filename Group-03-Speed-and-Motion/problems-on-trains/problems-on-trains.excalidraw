    {
      "id": "el_18",
      "type": "text",
      "x": 65,
      "y": 592,
      "width": 816,
      "height": 33,
      "text": "A train 150 meters long passes a pole in 15 seconds. Find\nthe speed of the train in km/h.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
