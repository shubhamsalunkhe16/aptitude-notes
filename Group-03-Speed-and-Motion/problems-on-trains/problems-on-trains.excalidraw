    {
      "id": "el_70",
      "type": "text",
      "x": 535,
      "y": 1883,
      "width": 296,
      "height": 188,
      "text": "LOGIC:\nStep 1: Opposite→Rel=36+54=90 km/h=25 m/s\n  Total dist=25×10=250m\nStep 2: L2 = 250-L1 = 250-100 = 150m\n\nTRICK:\nL2 = Rel(m/s)×T - L1\n= 25×10 - 100 = 150m\n\n  ──→ (100m)    (? m) ←──\n   36 km/h     54 km/h\n\nAnswer: 150m ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7000,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Opposite→Rel=36+54=90 km/h=25 m/s\n  Total dist=25×10=250m\nStep 2: L2 = 250-L1 = 250-100 = 150m\n\nTRICK:\nL2 = Rel(m/s)×T - L1\n= 25×10 - 100 = 150m\n\n  ──→ (100m)    (? m) ←──\n   36 km/h     54 km/h\n\nAnswer: 150m ✓",
      "autoResize": true,
