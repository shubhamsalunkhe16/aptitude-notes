    },
    {
      "id": "el_56",
      "type": "text",
      "x": 535,
      "y": 1545,
      "width": 830,
      "height": 49,
      "text": "A person walking at 4 km/h reaches the office 10 minutes\nlate, but walking at 6 km/h reaches 10 minutes early. Find\nthe distance to the office.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5600,
      "version": 1,
      "versionNonce": 56,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "A person walking at 4 km/h reaches the office 10 minutes\nlate, but walking at 6 km/h reaches 10 minutes early. Find\nthe distance to the office.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_57",
      "type": "text",
      "x": 535,
      "y": 1604,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5700,
      "version": 1,
      "versionNonce": 57,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_58",
      "type": "text",
      "x": 535,
      "y": 1626,
      "width": 288,
      "height": 231,
      "text": "LOGIC:\nStep 1: Let D=dist, T=actual time\n  D/4 = T+10/60 and D/6 = T-10/60\n  Subtract: D/4-D/6 = 20/60 = 1/3\nStep 2: D(3-2)/12 = 1/3 вҶ’ D/12=1/3 вҶ’ D=4\n\nTRICK (formula):\nD = S1Г—S2Г—О”T/(S2-S1)\nО”T = late+early = 10+10 = 20min = 1/3hr\nD = 4Г—6Г—(1/3)/(6-4) = 8/2 = 4 km\n\n  Home в”Җв”Җв”Җв”Җв”Җв”Җ D в”Җв”Җв”Җв”Җв”Җв”Җ Office\n  в”Җв”ҖвҶ’ 4km/h ... 10 min LATE\n  в”Җв”ҖвҶ’ 6km/h ... 10 min EARLY\n\nAnswer: 4 km вң“",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5800,
      "version": 1,
      "versionNonce": 58,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Let D=dist, T=actual time\n  D/4 = T+10/60 and D/6 = T-10/60\n  Subtract: D/4-D/6 = 20/60 = 1/3\nStep 2: D(3-2)/12 = 1/3 вҶ’ D/12=1/3 вҶ’ D=4\n\nTRICK (formula):\nD = S1Г—S2Г—О”T/(S2-S1)\nО”T = late+early = 10+10 = 20min = 1/3hr\nD = 4Г—6Г—(1/3)/(6-4) = 8/2 = 4 km\n\n  Home в”Җв”Җв”Җв”Җв”Җв”Җ D в”Җв”Җв”Җв”Җв”Җв”Җ Office\n  в”Җв”ҖвҶ’ 4km/h ... 10 min LATE\n  в”Җв”ҖвҶ’ 6km/h ... 10 min EARLY\n\nAnswer: 4 km вң“",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
