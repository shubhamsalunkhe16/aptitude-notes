    },
    {
      "id": "el_88",
      "type": "text",
      "x": 535,
      "y": 2436,
      "width": 317,
      "height": 231,
      "text": "LOGIC:\nStep 1: A goes N: 4Г—2=8km. B goes E: 3Г—2=6km\nStep 2: Right angle вҶ’ Pythagoras\n  Dist = вҲҡ(8ВІ+6ВІ) = вҲҡ(64+36) = вҲҡ100 = 10\n\nTRICK (Pythagorean triplets):\n3,4,5 вҶ’ Г—2 вҶ’ 6,8,10\nRecognize triplet instantly!\n\n       A (North)\n       вҶ‘ 8 km\n       |\n  Start+в”Җв”Җв”Җв”ҖвҶ’ B (East)\n          6 km\n\nAnswer: 10 km вң“",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8800,
      "version": 1,
      "versionNonce": 88,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_14"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A goes N: 4Г—2=8km. B goes E: 3Г—2=6km\nStep 2: Right angle вҶ’ Pythagoras\n  Dist = вҲҡ(8ВІ+6ВІ) = вҲҡ(64+36) = вҲҡ100 = 10\n\nTRICK (Pythagorean triplets):\n3,4,5 вҶ’ Г—2 вҶ’ 6,8,10\nRecognize triplet instantly!\n\n       A (North)\n       вҶ‘ 8 km\n       |\n  Start+в”Җв”Җв”Җв”ҖвҶ’ B (East)\n          6 km\n\nAnswer: 10 km вң“",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
