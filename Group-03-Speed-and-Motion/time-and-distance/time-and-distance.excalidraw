      "type": "text",
      "x": 1005,
      "y": 2371,
      "width": 801,
      "height": 49,
      "text": "A person covers half the distance walking at 20 km/h and\nthe other half riding at 40 km/h. Find the average speed\nfor the whole journey.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 9100,
      "version": 1,
      "versionNonce": 91,
      "isDeleted": false,
      "boundElements": null,
