    {
      "id": "el_46",
      "type": "text",
      "x": 1005,
      "y": 1161,
      "width": 801,
      "height": 49,
      "text": "The speeds of A and B are in the ratio 3:4. A takes 20\nminutes more than B to cover the same distance. Find the\ntime taken by each.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4600,
      "version": 1,
      "versionNonce": 46,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "The speeds of A and B are in the ratio 3:4. A takes 20\nminutes more than B to cover the same distance. Find the\ntime taken by each.",
