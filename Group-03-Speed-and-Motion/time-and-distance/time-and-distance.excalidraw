    },
    {
      "id": "el_83",
      "type": "text",
      "x": 65,
      "y": 2436,
      "width": 260,
      "height": 202,
      "text": "LOGIC:\nStep 1: SГ—T=constant. New S=1.25Г—old\n  New T = old/1.25 = 0.8Г—old = 80%\nStep 2: Decrease = 100%-80% = 20%\n\nTRICK (% formula):\nSpeed вҶ‘x% вҶ’ Time вҶ“ by x/(100+x)Г—100\n= 25/125 Г— 100 = 20%\n\nQuick reference:\nвҶ‘10%вҶ’вҶ“9.09%  вҶ‘25%вҶ’вҶ“20%\nвҶ‘50%вҶ’вҶ“33.3%  вҶ‘100%вҶ’вҶ“50%\n\nAnswer: Time decreases by 20% вң“",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8300,
      "version": 1,
      "versionNonce": 83,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_13"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: SГ—T=constant. New S=1.25Г—old\n  New T = old/1.25 = 0.8Г—old = 80%\nStep 2: Decrease = 100%-80% = 20%\n\nTRICK (% formula):\nSpeed вҶ‘x% вҶ’ Time вҶ“ by x/(100+x)Г—100\n= 25/125 Г— 100 = 20%\n\nQuick reference:\nвҶ‘10%вҶ’вҶ“9.09%  вҶ‘25%вҶ’вҶ“20%\nвҶ‘50%вҶ’вҶ“33.3%  вҶ‘100%вҶ’вҶ“50%\n\nAnswer: Time decreases by 20% вң“",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
