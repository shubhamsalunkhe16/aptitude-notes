    {
      "id": "el_21",
      "type": "text",
      "x": 65,
      "y": 764,
      "width": 773,
      "height": 33,
      "text": "A car travels 240 km in 4 hours. Find the speed of the\ncar.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
