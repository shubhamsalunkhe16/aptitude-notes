    },
    {
      "id": "el_93",
      "type": "text",
      "x": 1005,
      "y": 2327,
      "width": 324,
      "height": 216,
      "text": "LOGIC:\nStep 1: Let total D. T1=(D/2)/20, T2=(D/2)/40\n  Total T = D/40+D/80 = 3D/80\nStep 2: Avg = D/(3D/80) = 80/3 = 26.67\n\nTRICK (Harmonic Mean):\nSame dist → Avg = 2×S1×S2/(S1+S2)\n= 2×20×40/60 = 1600/60 = 26.67\n\n  |◄── D/2 ──►|◄── D/2 ──►|\n  |  Walk 20   |  Ride 40   |\n\nNOT 30! Simple avg is WRONG here\n\nAnswer: 26.67 km/h ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 9300,
      "version": 1,
      "versionNonce": 93,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_15"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Let total D. T1=(D/2)/20, T2=(D/2)/40\n  Total T = D/40+D/80 = 3D/80\nStep 2: Avg = D/(3D/80) = 80/3 = 26.67\n\nTRICK (Harmonic Mean):\nSame dist → Avg = 2×S1×S2/(S1+S2)\n= 2×20×40/60 = 1600/60 = 26.67\n\n  |◄── D/2 ──►|◄── D/2 ──►|\n  |  Walk 20   |  Ride 40   |\n\nNOT 30! Simple avg is WRONG here\n\nAnswer: 26.67 km/h ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
