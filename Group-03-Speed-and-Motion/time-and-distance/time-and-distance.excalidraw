    {
      "id": "el_83",
      "type": "text",
      "x": 65,
      "y": 2311,
      "width": 260,
      "height": 202,
      "text": "LOGIC:\nStep 1: S×T=constant. New S=1.25×old\n  New T = old/1.25 = 0.8×old = 80%\nStep 2: Decrease = 100%-80% = 20%\n\nTRICK (% formula):\nSpeed ↑x% → Time ↓ by x/(100+x)×100\n= 25/125 × 100 = 20%\n\nQuick reference:\n↑10%→↓9.09%  ↑25%→↓20%\n↑50%→↓33.3%  ↑100%→↓50%\n\nAnswer: Time decreases by 20% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8300,
      "version": 1,
      "versionNonce": 83,
      "isDeleted": false,
