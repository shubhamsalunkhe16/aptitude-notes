    },
    {
      "id": "el_57",
      "type": "text",
      "x": 535,
      "y": 1479,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
