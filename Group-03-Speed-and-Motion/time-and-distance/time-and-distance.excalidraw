      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: S×T=constant. New S=1.25×old\n  New T = old/1.25 = 0.8×old = 80%\nStep 2: Decrease = 100%-80% = 20%\n\nTRICK (% formula):\nSpeed ↑x% → Time ↓ by x/(100+x)×100\n= 25/125 × 100 = 20%\n\nQuick reference:\n↑10%→↓9.09%  ↑25%→↓20%\n↑50%→↓33.3%  ↑100%→↓50%\n\nAnswer: Time decreases by 20% ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
