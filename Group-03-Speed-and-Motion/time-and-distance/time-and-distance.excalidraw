    {
      "id": "el_86",
      "type": "text",
      "x": 535,
      "y": 2371,
      "width": 801,
      "height": 33,
      "text": "A walks north at 4 km/h and B walks east at 3 km/h. Find\nthe distance between them after 2 hours.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8600,
      "version": 1,
      "versionNonce": 86,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_14"
      ],
      "containerId": null,
      "originalText": "A walks north at 4 km/h and B walks east at 3 km/h. Find\nthe distance between them after 2 hours.",
