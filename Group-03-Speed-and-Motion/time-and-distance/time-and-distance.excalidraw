    },
    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 450,
      "width": 273,
      "height": 219,
      "text": "Same dir (chase/overtake):\n  в”Җв”ҖвҶ’  в”Җв”ҖвҶ’  Rel = S1 - S2\n\nOpposite dir (meeting):\n  в”Җв”ҖвҶ’  вҶҗв”Җв”Җ  Rel = S1 + S2\n\nCatch-up time = Gap / Rel speed\n\nWHY: Objects approach each other;\n  gap closes at combined rate (opp)\n  or difference rate (same dir).\n\nEx: S1=60, S2=40 вҶ’ Rel_opp=100,\n  Rel_same=20 km/h",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1400,
      "version": 1,
      "versionNonce": 14,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f3"
      ],
      "containerId": null,
      "originalText": "Same dir (chase/overtake):\n  в”Җв”ҖвҶ’  в”Җв”ҖвҶ’  Rel = S1 - S2\n\nOpposite dir (meeting):\n  в”Җв”ҖвҶ’  вҶҗв”Җв”Җ  Rel = S1 + S2\n\nCatch-up time = Gap / Rel speed\n\nWHY: Objects approach each other;\n  gap closes at combined rate (opp)\n  or difference rate (same dir).\n\nEx: S1=60, S2=40 вҶ’ Rel_opp=100,\n  Rel_same=20 km/h",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
