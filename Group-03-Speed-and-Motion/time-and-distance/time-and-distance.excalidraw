    {
      "id": "el_41",
      "type": "text",
      "x": 535,
      "y": 1161,
      "width": 787,
      "height": 33,
      "text": "A person covers 120 km at 40 km/h and then 180 km at 60\nkm/h. Find the average speed for the entire journey.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4100,
