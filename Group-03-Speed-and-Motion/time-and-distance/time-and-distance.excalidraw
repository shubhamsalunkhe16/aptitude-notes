    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 258,
      "height": 219,
      "text": "Same Distance вҶ’ S вҲқ 1/T (inverse)\n  S1/S2 = T2/T1\n  Double speed = Half time\n\nSame Time вҶ’ S вҲқ D (direct)\n  Double speed = Double distance\n\nSame Speed вҶ’ D вҲқ T (direct)\n\nWHY: D=SГ—T. Fix one variable,\n  the other two relate directly\n  or inversely.\n\nEx: S=3:5, same D вҶ’ T=5:3",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "Same Distance вҶ’ S вҲқ 1/T (inverse)\n  S1/S2 = T2/T1\n  Double speed = Half time\n\nSame Time вҶ’ S вҲқ D (direct)\n  Double speed = Double distance\n\nSame Speed вҶ’ D вҲқ T (direct)\n\nWHY: D=SГ—T. Fix one variable,\n  the other two relate directly\n  or inversely.\n\nEx: S=3:5, same D вҶ’ T=5:3",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
