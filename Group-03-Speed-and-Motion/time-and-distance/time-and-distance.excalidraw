      "roundness": null
    },
    {
      "id": "el_48",
      "type": "text",
      "x": 1005,
      "y": 1242,
      "width": 310,
      "height": 202,
      "text": "LOGIC:\nStep 1: Speed A:B=3:4, same dist вҶ’ Time=4:3\n  Let A=4x, B=3x. Diff: 4x-3x=20 вҶ’ x=20\nStep 2: A=80 min, B=60 min\n  Check: 80-60=20 вң“\n\nTRICK (inverse ratio):\nSame dist вҶ’ Time ratio = inverse of Speed\nS=3:4 вҶ’ T=4:3, diff=1 part=20 min\nA=4Г—20=80, B=3Г—20=60\n\nSlower speed = more time (INVERSE!)\n\nAnswer: A = 80 min, B = 60 min вң“",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4800,
      "version": 1,
      "versionNonce": 48,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_6"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Speed A:B=3:4, same dist вҶ’ Time=4:3\n  Let A=4x, B=3x. Diff: 4x-3x=20 вҶ’ x=20\nStep 2: A=80 min, B=60 min\n  Check: 80-60=20 вң“\n\nTRICK (inverse ratio):\nSame dist вҶ’ Time ratio = inverse of Speed\nS=3:4 вҶ’ T=4:3, diff=1 part=20 min\nA=4Г—20=80, B=3Г—20=60\n\nSlower speed = more time (INVERSE!)\n\nAnswer: A = 80 min, B = 60 min вң“",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
