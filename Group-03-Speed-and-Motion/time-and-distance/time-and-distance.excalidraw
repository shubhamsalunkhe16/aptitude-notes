      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_28",
      "type": "text",
      "x": 535,
      "y": 829,
      "width": 288,
      "height": 188,
      "text": "LOGIC:\nStep 1: 18 km/h = 18Г—1000/3600 = 5 m/s\nStep 2: Dist = SpeedГ—Time = 5Г—30 = 150 m\n\nTRICK (Г—5/18 shortcut):\nkm/h вҶ’ m/s: multiply by 5/18\n18 Г— 5/18 = 5 m/s\nm/s вҶ’ km/h: multiply by 18/5\nOr: km/h Г· 3.6 = m/s\n\nDist = 5Г—30 = 150 m\n\nAnswer: 5 m/s, 150 m вң“",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2800,
      "version": 1,
      "versionNonce": 28,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 18 km/h = 18Г—1000/3600 = 5 m/s\nStep 2: Dist = SpeedГ—Time = 5Г—30 = 150 m\n\nTRICK (Г—5/18 shortcut):\nkm/h вҶ’ m/s: multiply by 5/18\n18 Г— 5/18 = 5 m/s\nm/s вҶ’ km/h: multiply by 18/5\nOr: km/h Г· 3.6 = m/s\n\nDist = 5Г—30 = 150 m\n\nAnswer: 5 m/s, 150 m вң“",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
