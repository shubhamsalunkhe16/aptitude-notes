    {
      "id": "el_26",
      "type": "text",
      "x": 535,
      "y": 764,
      "width": 801,
      "height": 33,
      "text": "A man runs at 18 km/h. Express his speed in m/s and find\nthe distance he covers in 30 seconds.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
