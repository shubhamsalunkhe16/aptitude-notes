    {
      "id": "el_88",
      "type": "text",
      "x": 535,
      "y": 2311,
      "width": 317,
      "height": 231,
      "text": "LOGIC:\nStep 1: A goes N: 4×2=8km. B goes E: 3×2=6km\nStep 2: Right angle → Pythagoras\n  Dist = √(8²+6²) = √(64+36) = √100 = 10\n\nTRICK (Pythagorean triplets):\n3,4,5 → ×2 → 6,8,10\nRecognize triplet instantly!\n\n       A (North)\n       ↑ 8 km\n       |\n  Start+────→ B (East)\n          6 km\n\nAnswer: 10 km ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8800,
      "version": 1,
      "versionNonce": 88,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_14"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: A goes N: 4×2=8km. B goes E: 3×2=6km\nStep 2: Right angle → Pythagoras\n  Dist = √(8²+6²) = √(64+36) = √100 = 10\n\nTRICK (Pythagorean triplets):\n3,4,5 → ×2 → 6,8,10\nRecognize triplet instantly!\n\n       A (North)\n       ↑ 8 km\n       |\n  Start+────→ B (East)\n          6 km\n\nAnswer: 10 km ✓",
      "autoResize": true,
      "lineHeight": 1.2,
