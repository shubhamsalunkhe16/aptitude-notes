      "x": 535,
      "y": 1420,
      "width": 830,
      "height": 49,
      "text": "A person walking at 4 km/h reaches the office 10 minutes\nlate, but walking at 6 km/h reaches 10 minutes early. Find\nthe distance to the office.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5600,
