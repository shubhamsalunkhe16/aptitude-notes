    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 242,
      "height": 250,
      "text": "       D\n      / \\\n     /   \\\n    S  Г—  T\n\nCover D вҶ’ S Г— T\nCover S вҶ’ D / T\nCover T вҶ’ D / S\n\nkm/h вҶ’ m/s : Г— 5/18\nm/s вҶ’ km/h : Г— 18/5\n\nWHY: 1 km=1000m, 1 hr=3600s\n  1 km/h = 1000/3600 = 5/18 m/s\n\nEx: 72 km/h = 72Г—5/18 = 20 m/s",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 500,
      "version": 1,
      "versionNonce": 5,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f0"
      ],
      "containerId": null,
      "originalText": "       D\n      / \\\n     /   \\\n    S  Г—  T\n\nCover D вҶ’ S Г— T\nCover S вҶ’ D / T\nCover T вҶ’ D / S\n\nkm/h вҶ’ m/s : Г— 5/18\nm/s вҶ’ km/h : Г— 18/5\n\nWHY: 1 km=1000m, 1 hr=3600s\n  1 km/h = 1000/3600 = 5/18 m/s\n\nEx: 72 km/h = 72Г—5/18 = 20 m/s",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
