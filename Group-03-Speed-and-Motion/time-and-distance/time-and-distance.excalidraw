    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 258,
      "height": 125,
      "text": "Same Distance → S ∝ 1/T (inverse)\n  S1/S2 = T2/T1\n  Double speed = Half time\n\nSame Time → S ∝ D (direct)\n  Double speed = Double distance\n\nSame Speed → D ∝ T (direct)",
      "fontSize": 13,
      "fontFamily": 3,
