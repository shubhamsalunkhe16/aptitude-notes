    {
      "id": "el_66",
      "type": "text",
      "x": 65,
      "y": 1833,
      "width": 816,
      "height": 49,
      "text": "A thief runs at 8 km/h. A policeman starts chasing him 30\nminutes later at 12 km/h. How long will it take the\npoliceman to catch the thief?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
