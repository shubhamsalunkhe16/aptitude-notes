    {
      "id": "el_28",
      "type": "text",
      "x": 535,
      "y": 704,
      "width": 288,
      "height": 188,
      "text": "LOGIC:\nStep 1: 18 km/h = 18×1000/3600 = 5 m/s\nStep 2: Dist = Speed×Time = 5×30 = 150 m\n\nTRICK (×5/18 shortcut):\nkm/h → m/s: multiply by 5/18\n18 × 5/18 = 5 m/s\nm/s → km/h: multiply by 18/5\nOr: km/h ÷ 3.6 = m/s\n\nDist = 5×30 = 150 m\n\nAnswer: 5 m/s, 150 m ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2800,
      "version": 1,
      "versionNonce": 28,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_2"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: 18 km/h = 18×1000/3600 = 5 m/s\nStep 2: Dist = Speed×Time = 5×30 = 150 m\n\nTRICK (×5/18 shortcut):\nkm/h → m/s: multiply by 5/18\n18 × 5/18 = 5 m/s\nm/s → km/h: multiply by 18/5\nOr: km/h ÷ 3.6 = m/s\n\nDist = 5×30 = 150 m\n\nAnswer: 5 m/s, 150 m ✓",
      "autoResize": true,
