    {
      "id": "el_81",
      "type": "text",
      "x": 65,
      "y": 2371,
      "width": 816,
      "height": 33,
      "text": "If the speed is increased by 25%, by what percentage does\nthe time taken to cover the same distance decrease?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
