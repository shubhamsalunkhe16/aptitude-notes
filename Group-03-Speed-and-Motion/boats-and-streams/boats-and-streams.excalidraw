    },
    {
      "id": "el_65",
      "type": "text",
      "x": 65,
      "y": 2056,
      "width": 267,
      "height": 231,
      "text": "LOGIC:\nStep 1: Same dist → (15+S)×4=(15-S)×6\n  60+4S=90-6S → 10S=30 → S=3\nStep 2: Verify: 18×4=72, 12×6=72 ✓\n\nTRICK (ratio method):\nSame dist → T ∝ 1/Speed\nT1:T2=4:6=2:3 → Speed ratio=3:2\nDown:Up=3:2 → (B+S):(B-S)=3:2\n3(B-S)=2(B+S) → B=5S → S=15/5=3\n\n  START ═══════ D ═══════ PLACE\n    GO:   B+S=18 ──→  4 hrs\n    BACK: B-S=12 ←──  6 hrs\n\nAnswer: Stream speed = 3 km/h ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6500,
      "version": 1,
      "versionNonce": 65,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Same dist → (15+S)×4=(15-S)×6\n  60+4S=90-6S → 10S=30 → S=3\nStep 2: Verify: 18×4=72, 12×6=72 ✓\n\nTRICK (ratio method):\nSame dist → T ∝ 1/Speed\nT1:T2=4:6=2:3 → Speed ratio=3:2\nDown:Up=3:2 → (B+S):(B-S)=3:2\n3(B-S)=2(B+S) → B=5S → S=15/5=3\n\n  START ═══════ D ═══════ PLACE\n    GO:   B+S=18 ──→  4 hrs\n    BACK: B-S=12 ←──  6 hrs\n\nAnswer: Stream speed = 3 km/h ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
