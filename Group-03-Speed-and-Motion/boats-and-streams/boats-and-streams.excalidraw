    {
      "id": "el_33",
      "type": "text",
      "x": 65,
      "y": 1148,
      "width": 415,
      "height": 65,
      "text": "A boat takes 3 hours to travel downstream and 5 hours to\ntravel upstream over the same distance. If the boat speed\nin still water is 8 km/h and the stream speed is 2 km/h,\nfind the distance.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3300,
      "version": 1,
      "versionNonce": 33,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "A boat takes 3 hours to travel downstream and 5 hours to\ntravel upstream over the same distance. If the boat speed\nin still water is 8 km/h and the stream speed is 2 km/h,\nfind the distance.",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
