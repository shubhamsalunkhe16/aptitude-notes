    {
      "id": "el_43",
      "type": "text",
      "x": 1005,
      "y": 1148,
      "width": 415,
      "height": 49,
      "text": "A boat takes 2 hours to travel 20 km downstream and 4\nhours to return the same distance upstream. Find the speed\nof the stream.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
