    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 845,
      "width": 267,
      "height": 188,
      "text": "LOGIC:\nStep 1: D=B+S=13, U=B-S=9\n  Add: 2B=22→B=11. Subtract: 2S=4→S=2\nStep 2: Verify: 11+2=13, 11-2=9 ✓\n\nTRICK (formula):\nB = (D+U)/2 = (13+9)/2 = 11\nS = (D-U)/2 = (13-9)/2 = 2\n\n  --> Boat --> Stream (down=13)\n  --> Boat <-- Stream (up=9)\n\nAnswer: Boat=11 km/h, Stream=2 km/h ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: D=B+S=13, U=B-S=9\n  Add: 2B=22→B=11. Subtract: 2S=4→S=2\nStep 2: Verify: 11+2=13, 11-2=9 ✓\n\nTRICK (formula):\nB = (D+U)/2 = (13+9)/2 = 11\nS = (D-U)/2 = (13-9)/2 = 2\n\n  --> Boat --> Stream (down=13)\n  --> Boat <-- Stream (up=9)\n\nAnswer: Boat=11 km/h, Stream=2 km/h ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
