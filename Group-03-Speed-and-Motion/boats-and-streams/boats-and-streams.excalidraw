      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_35",
      "type": "text",
      "x": 65,
      "y": 1245,
      "width": 267,
      "height": 202,
      "text": "LOGIC:\nStep 1: Down=B+S=10, Up=B-S=6\nStep 2: D=Down×T_down=10×3=30 km\n  Verify: D=Up×T_up=6×5=30 ✓\n\nTRICK:\nSame dist → (B+S)×T_down = (B-S)×T_up\nUse either side to find D:\nD = 10×3 = 30 km\n\n  --> down=10, 3hrs → 30km\n  --> up=6, 5hrs → 30km ✓\n\nAnswer: Distance = 30 km ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3500,
      "version": 1,
      "versionNonce": 35,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Down=B+S=10, Up=B-S=6\nStep 2: D=Down×T_down=10×3=30 km\n  Verify: D=Up×T_up=6×5=30 ✓\n\nTRICK:\nSame dist → (B+S)×T_down = (B-S)×T_up\nUse either side to find D:\nD = 10×3 = 30 km\n\n  --> down=10, 3hrs → 30km\n  --> up=6, 5hrs → 30km ✓\n\nAnswer: Distance = 30 km ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
