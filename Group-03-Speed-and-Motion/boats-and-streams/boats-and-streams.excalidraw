    {
      "id": "el_18",
      "type": "text",
      "x": 65,
      "y": 764,
      "width": 415,
      "height": 49,
      "text": "A man can row downstream at 13 km/h and upstream at 9\nkm/h. Find the speed of the man in still water and the\nspeed of the stream.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
