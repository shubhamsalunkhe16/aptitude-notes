    {
      "id": "el_68",
      "type": "text",
      "x": 535,
      "y": 1975,
      "width": 415,
      "height": 49,
      "text": "A boat travels at 10 km/h in still water and the stream\nspeed is 2 km/h. If the upstream journey takes 2 hours\nmore than the downstream journey, find the distance.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6800,
      "version": 1,
      "versionNonce": 68,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "A boat travels at 10 km/h in still water and the stream\nspeed is 2 km/h. If the upstream journey takes 2 hours\nmore than the downstream journey, find the distance.",
