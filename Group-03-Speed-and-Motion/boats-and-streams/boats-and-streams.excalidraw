    {
      "id": "el_40",
      "type": "text",
      "x": 535,
      "y": 1229,
      "width": 224,
      "height": 216,
      "text": "LOGIC:\nStep 1: Down=48/4=12, Up=36/6=6\n  D=B+S=12, U=B-S=6\nStep 2: 2B=18→B=9, 2S=6→S=3\n  Verify: 9+3=12, 9-3=6 ✓\n\nTRICK (formula):\nB=(D+U)/2=(12+6)/2=9\nS=(D-U)/2=(12-6)/2=3\n\n  ~~~ DOWN ~~~     ~~~ UP ~~~\n  48km / 4hrs      36km / 6hrs\n  =12 km/h         =6 km/h\n\nAnswer: B=9 km/h, S=3 km/h ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 4000,
      "version": 1,
      "versionNonce": 40,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_5"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Down=48/4=12, Up=36/6=6\n  D=B+S=12, U=B-S=6\nStep 2: 2B=18→B=9, 2S=6→S=3\n  Verify: 9+3=12, 9-3=6 ✓\n\nTRICK (formula):\nB=(D+U)/2=(12+6)/2=9\nS=(D-U)/2=(12-6)/2=3\n\n  ~~~ DOWN ~~~     ~~~ UP ~~~\n  48km / 4hrs      36km / 6hrs\n  =12 km/h         =6 km/h\n\nAnswer: B=9 km/h, S=3 km/h ✓",
      "autoResize": true,
      "lineHeight": 1.2,
