      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6900,
      "version": 1,
      "versionNonce": 69,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_70",
      "type": "text",
      "x": 535,
      "y": 2056,
      "width": 310,
      "height": 188,
      "text": "LOGIC:\nStep 1: Down=12, Up=8\n  D/8-D/12=2 → (3D-2D)/24=2 → D=48\nStep 2: Verify: 48/12=4h, 48/8=6h, diff=2 ✓\n\nTRICK (formula):\nD = ΔT×(B²-S²)/(2S)\n= 2×(100-4)/(2×2) = 2×96/4 = 48\n\nOr: D=ΔT×Down×Up/(Down-Up)\n= 2×12×8/(12-8) = 192/4 = 48\n\nAnswer: Distance = 48 km ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7000,
      "version": 1,
      "versionNonce": 70,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Down=12, Up=8\n  D/8-D/12=2 → (3D-2D)/24=2 → D=48\nStep 2: Verify: 48/12=4h, 48/8=6h, diff=2 ✓\n\nTRICK (formula):\nD = ΔT×(B²-S²)/(2S)\n= 2×(100-4)/(2×2) = 2×96/4 = 48\n\nOr: D=ΔT×Down×Up/(Down-Up)\n= 2×12×8/(12-8) = 192/4 = 48\n\nAnswer: Distance = 48 km ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
