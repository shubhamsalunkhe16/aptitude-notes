    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 336,
      "height": 203,
      "text": "Boat speed in still water = B\nStream (current) speed = S\n\nDownstream speed = B + S  (current helps)\nUpstream speed   = B - S  (current opposes)\n\n──→ Boat ──→ Stream = DOWNSTREAM\n──→ Boat ←── Stream = UPSTREAM\n\nWHY: Current adds to boat's speed\n  going with it, subtracts against.\n\nEx: B=10, S=3 → Down=13, Up=7",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 500,
      "version": 1,
      "versionNonce": 5,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f0"
      ],
      "containerId": null,
      "originalText": "Boat speed in still water = B\nStream (current) speed = S\n\nDownstream speed = B + S  (current helps)\nUpstream speed   = B - S  (current opposes)\n\n──→ Boat ──→ Stream = DOWNSTREAM\n──→ Boat ←── Stream = UPSTREAM\n\nWHY: Current adds to boat's speed\n  going with it, subtracts against.\n\nEx: B=10, S=3 → Down=13, Up=7",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
