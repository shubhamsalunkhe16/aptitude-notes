    {
      "id": "el_7",
      "type": "text",
      "x": 535,
      "y": 100,
      "width": 262,
      "height": 22,
      "text": "Deriving B & S",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 17,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 700,
      "version": 1,
      "versionNonce": 7,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "Deriving B & S",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 242,
      "height": 172,
      "text": "If Downstream = D, Upstream = U\n\nBoat speed  B = (D + U) / 2\nStream speed S = (D - U) / 2\n\nWHY: D=B+S, U=B-S\n  D+U=2B → B=(D+U)/2\n  D-U=2S → S=(D-U)/2\n\nEx: Down=14, Up=8 →\n  B=(14+8)/2=11, S=(14-8)/2=3",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "If Downstream = D, Upstream = U\n\nBoat speed  B = (D + U) / 2\nStream speed S = (D - U) / 2\n\nWHY: D=B+S, U=B-S\n  D+U=2B → B=(D+U)/2\n  D-U=2S → S=(D-U)/2\n\nEx: Down=14, Up=8 →\n  B=(14+8)/2=11, S=(14-8)/2=3",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
