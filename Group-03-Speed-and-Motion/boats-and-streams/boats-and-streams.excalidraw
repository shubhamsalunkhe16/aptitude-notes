    {
      "id": "el_28",
      "type": "text",
      "x": 1005,
      "y": 764,
      "width": 415,
      "height": 49,
      "text": "A boat can travel at 8 km/h in still water. The speed of\nthe stream is 4 km/h. How long does it take to go 24 km\ndownstream and return?",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2800,
      "version": 1,
      "versionNonce": 28,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "A boat can travel at 8 km/h in still water. The speed of\nthe stream is 4 km/h. How long does it take to go 24 km\ndownstream and return?",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_29",
      "type": "text",
      "x": 1005,
      "y": 823,
      "width": 129,
      "height": 17,
      "text": "Solution:",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#e8590c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2900,
      "version": 1,
      "versionNonce": 29,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "Solution:",
      "autoResize": true,
      "lineHeight": 1.25,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_30",
      "type": "text",
      "x": 1005,
      "y": 845,
      "width": 238,
      "height": 202,
      "text": "LOGIC:\nStep 1: Down=B+S=12, Up=B-S=4\n  T_down=24/12=2h, T_up=24/4=6h\nStep 2: Total = 2+6 = 8 hours\n\nTRICK (round trip formula):\nT = 2DB/(B²-S²)\n= 2×24×8/(64-16) = 384/48 = 8 hrs\n\n  START <--- 24 km ---> PLACE\n  GO:   12 km/h → 2 hrs\n  BACK:  4 km/h → 6 hrs\n\nAnswer: Total = 8 hours ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 3000,
      "version": 1,
      "versionNonce": 30,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_3"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Down=B+S=12, Up=B-S=4\n  T_down=24/12=2h, T_up=24/4=6h\nStep 2: Total = 2+6 = 8 hours\n\nTRICK (round trip formula):\nT = 2DB/(B²-S²)\n= 2×24×8/(64-16) = 384/48 = 8 hrs\n\n  START <--- 24 km ---> PLACE\n  GO:   12 km/h → 2 hrs\n  BACK:  4 km/h → 6 hrs\n\nAnswer: Total = 8 hours ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
