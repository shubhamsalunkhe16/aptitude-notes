    {
      "id": "el_55",
      "type": "text",
      "x": 535,
      "y": 1629,
      "width": 281,
      "height": 245,
      "text": "LOGIC:\nStep 1: Same time → D ∝ Speed\n  6:10 = (B-S):(B+S)\n  6(B+S)=10(B-S) → 16S=4B → B=4S\nStep 2: S=2 → B=8 km/h\n  Verify: Up=6, Down=10, 6/6=10/10=1h ✓\n\nTRICK (ratio):\nUp:Down dist = (B-S):(B+S)\n6:10 = 3:5. So B-S=3k, B+S=5k\nB=4k, S=k. Given S=2→k=2→B=8\n\n  ──→ 10 km (downstream) ──→\n  ←── 6 km  (upstream)   ←──\n       Same time T\n\nAnswer: Boat speed = 8 km/h ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5500,
      "version": 1,
      "versionNonce": 55,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_8"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Same time → D ∝ Speed\n  6:10 = (B-S):(B+S)\n  6(B+S)=10(B-S) → 16S=4B → B=4S\nStep 2: S=2 → B=8 km/h\n  Verify: Up=6, Down=10, 6/6=10/10=1h ✓\n\nTRICK (ratio):\nUp:Down dist = (B-S):(B+S)\n6:10 = 3:5. So B-S=3k, B+S=5k\nB=4k, S=k. Given S=2→k=2→B=8\n\n  ──→ 10 km (downstream) ──→\n  ←── 6 km  (upstream)   ←──\n       Same time T\n\nAnswer: Boat speed = 8 km/h ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
