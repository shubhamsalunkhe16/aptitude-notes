    {
      "id": "el_63",
      "type": "text",
      "x": 65,
      "y": 1975,
      "width": 415,
      "height": 49,
      "text": "A boat travels at 15 km/h in still water. It takes 4 hours\nto go downstream and 6 hours to return the same distance.\nFind the speed of the stream.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 6300,
