      "versionNonce": 41,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_4"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: tan30°=20/d → d=20√3\nStep 2: tan60°=(20+t)/d\n  √3=(20+t)/20√3\n  60=20+t → t=40\n\nTRICK:\nTotal/Hill = tanα/tanβ\n= tan60°/tan30° = √3/(1/√3) = 3\nTotal = 3×20 = 60, Tower = 60-20 = 40\n\n       T  ← tower top\n  t=?  |     60°\n       H  ← hill top ──\n  20m  |     30°       |\n       B──────────────O\n       base     d=20√3\n\nAnswer: Tower = 40 m ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
