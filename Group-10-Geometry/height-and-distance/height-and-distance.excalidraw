      "frameId": null,
      "roundness": null
    },
    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 450,
      "width": 344,
      "height": 188,
      "text": "Two points, same side, gap = d:\n  h = d×tanα×tanβ / (tanα - tanβ)\n  (α > β, α is closer angle)\n\nTower on hill (angles α, β):\n  tower = d × (tan α - tan β)\n  hill  = d × tan β\n\nWHY: Express distances as h/tanα and h/tanβ.\n  Their difference = gap d. Solve for h.\n\nEx: α=60°,β=30°,d=40 → h=20√3=34.64m",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1400,
      "version": 1,
      "versionNonce": 14,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f3"
      ],
      "containerId": null,
      "originalText": "Two points, same side, gap = d:\n  h = d×tanα×tanβ / (tanα - tanβ)\n  (α > β, α is closer angle)\n\nTower on hill (angles α, β):\n  tower = d × (tan α - tan β)\n  hill  = d × tan β\n\nWHY: Express distances as h/tanα and h/tanβ.\n  Their difference = gap d. Solve for h.\n\nEx: α=60°,β=30°,d=40 → h=20√3=34.64m",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
