    {
      "id": "el_26",
      "type": "text",
      "x": 65,
      "y": 813,
      "width": 202,
      "height": 231,
      "text": "LOGIC:\nStep 1: tan60° = h/40\nStep 2: √3 = h/40 → h = 40√3\n  = 40×1.732 = 69.28 m\n\nTRICK:\n60° → multiply base by √3\n30° → divide base by √3\n45° → height = base\n\n         T\n   h=?   |\\ 60°\n         |__\\\n        B 40m O\n\nAnswer: 69.28 m ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2600,
      "version": 1,
      "versionNonce": 26,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: tan60° = h/40\nStep 2: √3 = h/40 → h = 40√3\n  = 40×1.732 = 69.28 m\n\nTRICK:\n60° → multiply base by √3\n30° → divide base by √3\n45° → height = base\n\n         T\n   h=?   |\\ 60°\n         |__\\\n        B 40m O\n\nAnswer: 69.28 m ✓",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
