    {
      "id": "el_81",
      "type": "text",
      "x": 1005,
      "y": 2133,
      "width": 216,
      "height": 260,
      "text": "LOGIC:\nStep 1: d1=100√3 (30° side)\n  d2=100 (45° side)\nStep 2: Opposite sides → ADD\n  = 100√3+100 = 100(√3+1)\n\nTRICK:\nSame side → subtract distances\nOpposite sides → add distances\n= 100(1.732+1) = 273.2\n\n          Lighthouse\n  S1 30°  |  45° S2\n  ────────|────────\n  d1=100√3 d2=100\n  Total = d1 + d2 (opposite)\n\nAnswer: 273.2 m ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8100,
      "version": 1,
      "versionNonce": 81,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: d1=100√3 (30° side)\n  d2=100 (45° side)\nStep 2: Opposite sides → ADD\n  = 100√3+100 = 100(√3+1)\n\nTRICK:\nSame side → subtract distances\nOpposite sides → add distances\n= 100(1.732+1) = 273.2\n\n          Lighthouse\n  S1 30°  |  45° S2\n  ────────|────────\n  d1=100√3 d2=100\n  Total = d1 + d2 (opposite)\n\nAnswer: 273.2 m ✓",
      "autoResize": true,
