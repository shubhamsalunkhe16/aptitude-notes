    {
      "id": "el_71",
      "type": "text",
      "x": 65,
      "y": 2133,
      "width": 274,
      "height": 245,
      "text": "LOGIC:\nStep 1: tan45°=h/d → d=h\n  tan30°=h/(h+30)\nStep 2: h+30=h√3 → h(√3-1)=30\n  h = 30/(√3-1) = 15(√3+1)\n\nTRICK:\nRationalize: multiply by (√3+1)/(√3+1)\n= 30(√3+1)/2 = 15×2.732 = 40.98\n\n       T\n  h=?  |\\ 45°    30°\n       | \\────────/\n       |__\\_______/\n       B  A  30m  B\n\nAnswer: 40.98 m ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7100,
      "version": 1,
      "versionNonce": 71,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_10"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: tan45°=h/d → d=h\n  tan30°=h/(h+30)\nStep 2: h+30=h√3 → h(√3-1)=30\n  h = 30/(√3-1) = 15(√3+1)\n\nTRICK:\nRationalize: multiply by (√3+1)/(√3+1)\n= 30(√3+1)/2 = 15×2.732 = 40.98\n\n       T\n  h=?  |\\ 45°    30°\n       | \\────────/\n       |__\\_______/\n       B  A  30m  B\n\nAnswer: 40.98 m ✓",
      "autoResize": true,
