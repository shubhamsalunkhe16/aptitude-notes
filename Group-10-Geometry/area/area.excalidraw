    {
      "id": "el_76",
      "type": "text",
      "x": 535,
      "y": 2013,
      "width": 252,
      "height": 231,
      "text": "LOGIC:\nStep 1: Area = (√3/4)×14² = 49√3\n  = 84.87 cm²\nStep 2: h = (√3/2)×14 = 7√3 = 12.12\n\nTRICK:\nArea = (√3/4)a² = (a/2)²×√3\nHeight = (√3/2)×a\n√3 ≈ 1.732\n\n       /\\\n   14 / h \\ 14\n     /____\\\n       14\n\nAnswer: Area=84.87cm², h=12.12cm ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 7600,
      "version": 1,
      "versionNonce": 76,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_11"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: Area = (√3/4)×14² = 49√3\n  = 84.87 cm²\nStep 2: h = (√3/2)×14 = 7√3 = 12.12\n\nTRICK:\nArea = (√3/4)a² = (a/2)²×√3\nHeight = (√3/2)×a\n√3 ≈ 1.732\n\n       /\\\n   14 / h \\ 14\n     /____\\\n       14\n\nAnswer: Area=84.87cm², h=12.12cm ✓",
      "autoResize": true,
