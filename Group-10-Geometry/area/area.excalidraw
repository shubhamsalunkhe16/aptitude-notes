    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 414,
      "height": 219,
      "text": "RECTANGLE (L × B):\n  Area = L × B\n  Perimeter = 2(L + B)\n  Diagonal = √(L² + B²)\n\nSQUARE (side a):\n  Area = a²\n  Perimeter = 4a\n  Diagonal = a√2,  Area = d²/2\n\nWHY: Rectangle = L rows of B unit squares.\n  Square diagonal splits into two 45-45-90 triangles.\n\nEx: L=8, B=5 → Area=40, Peri=26, Diag=√89",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 500,
      "version": 1,
      "versionNonce": 5,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f0"
      ],
      "containerId": null,
      "originalText": "RECTANGLE (L × B):\n  Area = L × B\n  Perimeter = 2(L + B)\n  Diagonal = √(L² + B²)\n\nSQUARE (side a):\n  Area = a²\n  Perimeter = 4a\n  Diagonal = a√2,  Area = d²/2\n\nWHY: Rectangle = L rows of B unit squares.\n  Square diagonal splits into two 45-45-90 triangles.\n\nEx: L=8, B=5 → Area=40, Peri=26, Diag=√89",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
