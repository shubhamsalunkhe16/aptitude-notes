    },
    {
      "id": "el_11",
      "type": "text",
      "x": 1005,
      "y": 125,
      "width": 312,
      "height": 203,
      "text": "Circle: Area = πr², Circum = 2πr\nSemicircle: Area = πr²/2\n  Perimeter = πr + 2r\nQuadrant: Area = πr²/4\n  Perimeter = πr/2 + 2r\n\nRing: Area = π(R² - r²)\n    = π(R+r)(R-r)\n\nWHY: Circle area = sum of infinite thin\n  rings from center to edge, giving πr².\n\nEx: r=7 → Area=22/7×49=154, C=44",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1100,
      "version": 1,
      "versionNonce": 11,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f2"
      ],
      "containerId": null,
      "originalText": "Circle: Area = πr², Circum = 2πr\nSemicircle: Area = πr²/2\n  Perimeter = πr + 2r\nQuadrant: Area = πr²/4\n  Perimeter = πr/2 + 2r\n\nRing: Area = π(R² - r²)\n    = π(R+r)(R-r)\n\nWHY: Circle area = sum of infinite thin\n  rings from center to edge, giving πr².\n\nEx: r=7 → Area=22/7×49=154, C=44",
      "autoResize": true,
      "lineHeight": 1.2,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null
    },
