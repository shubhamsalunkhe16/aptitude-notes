    {
      "id": "el_81",
      "type": "text",
      "x": 1005,
      "y": 2013,
      "width": 267,
      "height": 245,
      "text": "LOGIC:\nStep 1: New area = 1.20 × 0.90 = 1.08\nStep 2: Change = 8% increase\n\nTRICK:\nNet% = a + b + ab/100\n= 20 + (-10) + (20×-10)/100\n= 10 - 2 = +8%\nBoth ↑x%: area ↑(2x+x²/100)%\n\n  L×1.20  B×0.90\n  ┌────────┐\n  │New area│ = 1.08 × old\n  └────────┘\n  Net change = +8%\n\nAnswer: Area increases by 8% ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 8100,
      "version": 1,
      "versionNonce": 81,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_12"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: New area = 1.20 × 0.90 = 1.08\nStep 2: Change = 8% increase\n\nTRICK:\nNet% = a + b + ab/100\n= 20 + (-10) + (20×-10)/100\n= 10 - 2 = +8%\nBoth ↑x%: area ↑(2x+x²/100)%\n\n  L×1.20  B×0.90\n  ┌────────┐\n  │New area│ = 1.08 × old\n  └────────┘\n  Net change = +8%\n\nAnswer: Area increases by 8% ✓",
      "autoResize": true,
