    {
      "id": "el_5",
      "type": "text",
      "x": 65,
      "y": 125,
      "width": 266,
      "height": 156,
      "text": "CUBE (side a):\n  Volume = a^3\n  TSA = 6a^2,  LSA = 4a^2\n  Diagonal = a*sqrt(3)\n\nCUBOID (l x b x h):\n  Volume = l*b*h\n  TSA = 2(lb + bh + hl)\n  LSA = 2h(l + b)\n  Diagonal = sqrt(l^2 + b^2 + h^2)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 500,
      "version": 1,
      "versionNonce": 5,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
