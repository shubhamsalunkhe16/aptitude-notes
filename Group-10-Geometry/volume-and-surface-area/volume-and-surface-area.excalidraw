    {
      "id": "el_8",
      "type": "text",
      "x": 535,
      "y": 125,
      "width": 195,
      "height": 156,
      "text": "CYLINDER (r, h):\n  Volume = pi*r^2*h\n  CSA = 2*pi*r*h\n  TSA = 2*pi*r(r + h)\n\nCONE (r, h, slant l):\n  l = sqrt(r^2 + h^2)\n  Volume = (1/3)*pi*r^2*h\n  CSA = pi*r*l\n  TSA = pi*r(r + l)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 800,
      "version": 1,
      "versionNonce": 8,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f1"
      ],
      "containerId": null,
      "originalText": "CYLINDER (r, h):\n  Volume = pi*r^2*h\n  CSA = 2*pi*r*h\n  TSA = 2*pi*r(r + h)\n\nCONE (r, h, slant l):\n  l = sqrt(r^2 + h^2)\n  Volume = (1/3)*pi*r^2*h\n  CSA = pi*r*l\n  TSA = pi*r(r + l)",
