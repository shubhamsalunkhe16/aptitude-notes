    {
      "id": "el_14",
      "type": "text",
      "x": 65,
      "y": 372,
      "width": 234,
      "height": 172,
      "text": "FRUSTUM (R, r, h):\n  V = (pi*h/3)(R^2 + r^2 + Rr)\n  l = sqrt(h^2 + (R-r)^2)\n  CSA = pi(R+r)*l\n\nSCALING by factor k:\n  New Volume = k^3 x old\n  New SA = k^2 x old\n\nMelting: Vol(old) = Vol(new)\nSphere in cube: r = side/2",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 13,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1400,
      "version": 1,
      "versionNonce": 14,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "f3"
      ],
      "containerId": null,
      "originalText": "FRUSTUM (R, r, h):\n  V = (pi*h/3)(R^2 + r^2 + Rr)\n  l = sqrt(h^2 + (R-r)^2)\n  CSA = pi(R+r)*l\n\nSCALING by factor k:\n  New Volume = k^3 x old\n  New SA = k^2 x old\n\nMelting: Vol(old) = Vol(new)\nSphere in cube: r = side/2",
      "autoResize": true,
