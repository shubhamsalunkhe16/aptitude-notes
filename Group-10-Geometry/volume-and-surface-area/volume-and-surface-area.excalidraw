    {
      "id": "el_20",
      "type": "text",
      "x": 65,
      "y": 688,
      "width": 224,
      "height": 202,
      "text": "LOGIC:\nStep 1: V = 6³ = 216\nStep 2: TSA = 6×36 = 216\n  Diag = 6√3 = 10.39\n\nTRICK:\nCube: V=a³, TSA=6a², Diag=a√3\nFun fact: when a=6, V=TSA=216!\n\n  ┌─────┐\n  │CUBE │ a=6\n  └─────┘\n\nAnswer: V=216, TSA=216, D=6√3 ✓",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 12,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000,
      "version": 1,
      "versionNonce": 20,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "groupIds": [
        "type_1"
      ],
      "containerId": null,
      "originalText": "LOGIC:\nStep 1: V = 6³ = 216\nStep 2: TSA = 6×36 = 216\n  Diag = 6√3 = 10.39\n\nTRICK:\nCube: V=a³, TSA=6a², Diag=a√3\nFun fact: when a=6, V=TSA=216!\n\n  ┌─────┐\n  │CUBE │ a=6\n  └─────┘\n\nAnswer: V=216, TSA=216, D=6√3 ✓",
      "autoResize": true,
